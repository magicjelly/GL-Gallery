enum class FluidState { IDLE, MAGNETIC_HOLD }

@RequiresApi(Build.VERSION_CODES.TIRAMISU)
@Composable
fun NotificationSyncPrototype() {
    val context = LocalContext.current
    val density = LocalDensity.current
    val config = LocalConfiguration.current
    val coroutineScope = rememberCoroutineScope()
    
    val sensorManager = remember { context.getSystemService(Context.SENSOR_SERVICE) as SensorManager }
    var rawGravityX by remember { mutableFloatStateOf(0f) }
    var rawGravityY by remember { mutableFloatStateOf(0f) }

    DisposableEffect(Unit) {
        val gravitySensor = sensorManager.getDefaultSensor(Sensor.TYPE_GRAVITY)
        val listener = object : SensorEventListener {
            override fun onSensorChanged(event: SensorEvent?) {
                event?.let {
                    rawGravityX = it.values[0] / 9.81f
                    rawGravityY = it.values[1] / 9.81f
                }
            }
            override fun onAccuracyChanged(sensor: Sensor?, accuracy: Int) {}
        }
        sensorManager.registerListener(listener, gravitySensor, SensorManager.SENSOR_DELAY_GAME)
        onDispose { sensorManager.unregisterListener(listener) }
    }
    
    val fluidMomentumX by animateFloatAsState(targetValue = -rawGravityX, animationSpec = spring(dampingRatio = 0.5f, stiffness = 25f), label = "fluid_x")
    val fluidMomentumY by animateFloatAsState(targetValue = rawGravityY, animationSpec = spring(dampingRatio = 0.5f, stiffness = 25f), label = "fluid_y")

    var fluidState by remember { mutableStateOf(FluidState.IDLE) }
    var fluidVolumeTarget by remember { mutableFloatStateOf(1f) }
    var transferDirection by remember { mutableFloatStateOf(1f) }
    
    var touchX by remember { mutableFloatStateOf(0f) }
    var touchY by remember { mutableFloatStateOf(0f) }
    var isScreenTouched by remember { mutableStateOf(false) }
    
    val isMagneticPullActive = isScreenTouched || fluidState == FluidState.MAGNETIC_HOLD
    val magneticTouchStrength by animateFloatAsState(
        targetValue = if (isMagneticPullActive) 1f else 0f,
        animationSpec = if (isMagneticPullActive) tween(600, easing = FastOutSlowInEasing) else spring(dampingRatio = 0.75f, stiffness = 40f),
        label = "magnetic_pull"
    )
    
    val fluidVolume by animateFloatAsState(
        targetValue = fluidVolumeTarget,
        animationSpec = tween(1500, easing = LinearOutSlowInEasing),
        label = "fluid_volume"
    )
    
    var hardwareCornerRadius by remember { mutableFloatStateOf(120f) }
    var isNotificationActive by remember { mutableStateOf(false) }
    var flowSpeed by remember { mutableFloatStateOf(1.5f) }
    var thickness by remember { mutableFloatStateOf(40f) }
    var amplitude by remember { mutableFloatStateOf(80f) }
    var noiseScale by remember { mutableFloatStateOf(3.0f) }
    
    var effectPosX by remember { mutableFloatStateOf(0.5f) } 
    var effectPosY by remember { mutableFloatStateOf(0.0f) } 
    var effectSize by remember { mutableFloatStateOf(0.18f) } 
    
    var selectedCategory by remember { mutableIntStateOf(1) } // 0: Notifications, 1: Send/Receive, 2: Media Player
    var selectedNotificationIndex by remember { mutableIntStateOf(4) } 
    var selectedPhysicsIndex by remember { mutableIntStateOf(0) } 
    
    val activeShaderString = when (selectedCategory) {
        0 -> when (selectedNotificationIndex) {
            0 -> LAVA_SHADER; 1 -> GLINT_SHADER; 2 -> PRISMATIC_SHADER; 3 -> SPARK_SHADER; 
            4 -> AURA_SHADER; else -> SUNLIGHT_SHADER
        }
        1 -> when (selectedPhysicsIndex) {
            0 -> MENISCUS_SHADER; 1 -> STATE_CHANGE_SHADER; else -> WORMHOLE_SHADER
        }
        else -> WAVE_SHADER
    }

    val appColors = listOf(Color(0xFF1999FF), Color(0xFF25D366), Color(0xFFEA4335), Color(0xFFFFFC00), Color(0xFFFFFFFF))
    var selectedAppColor by remember { mutableStateOf(appColors[0]) }

    val pillOffsetY by animateDpAsState(targetValue = if (isNotificationActive) 32.dp else (-100).dp, animationSpec = spring(dampingRatio = 0.7f, stiffness = 400f), label = "pill")
    
    val masterAlpha by animateFloatAsState(
        targetValue = if (selectedCategory != 0 || isNotificationActive) 1f else 0f, 
        animationSpec = tween(durationMillis = 300, easing = LinearOutSlowInEasing), 
        label = "alpha"
    )

    val screenWidthPx = with(density) { config.screenWidthDp.dp.toPx() }
    val screenHeightPx = with(density) { config.screenHeightDp.dp.toPx() }
    val pillWidthPx = screenWidthPx * 0.9f
    val pillHeightPx = with(density) { 64.dp.toPx() }
    val pillCenterYPx = with(density) { pillOffsetY.toPx() + (64.dp.toPx() / 2f) }

    val activeTouchX = if (selectedCategory == 1) effectPosX * screenWidthPx else touchX
    val activeTouchY = if (selectedCategory == 1) effectPosY * screenHeightPx else touchY

    Box(
        modifier = Modifier
            .fillMaxSize()
            .pointerInput(Unit) {
                awaitPointerEventScope {
                    while (true) {
                        val event = awaitPointerEvent(PointerEventPass.Initial)
                        val change = event.changes.firstOrNull()
                        if (change != null) {
                            if (fluidState == FluidState.IDLE) {
                                touchX = change.position.x
                                touchY = change.position.y
                            }
                            isScreenTouched = change.pressed
                        }
                    }
                }
            }
            .pointerInput(Unit) {
                detectTapGestures(onTap = { isNotificationActive = true }, onDoubleTap = { isNotificationActive = false })
            }
    ) {
        AmbientEdgeLighting(
            modifier = Modifier.fillMaxSize(),
            shaderString = activeShaderString,
            cornerRadius = hardwareCornerRadius, appColor = selectedAppColor,
            speed = flowSpeed, thickness = thickness, amplitude = amplitude, noiseScale = noiseScale,
            masterAlpha = masterAlpha,
            pillCenterY = pillCenterYPx, pillWidth = pillWidthPx, pillHeight = pillHeightPx,
            gravityX = fluidMomentumX, gravityY = fluidMomentumY,
            touchX = activeTouchX, touchY = activeTouchY, touchActive = magneticTouchStrength,
            fluidVolume = fluidVolume,
            transferDirection = transferDirection,
            effectSize = effectSize
        ) {
            Image(
                painter = painterResource(id = android.R.drawable.sym_def_app_icon), 
                contentDescription = "Background", 
                contentScale = ContentScale.Crop, 
                modifier = Modifier.fillMaxSize()
            )
        }

        if (selectedCategory == 0) {
            Card(
                modifier = Modifier.align(Alignment.TopCenter).offset(y = pillOffsetY).alpha(masterAlpha).fillMaxWidth(0.9f).height(64.dp),
                shape = RoundedCornerShape(32.dp), colors = CardDefaults.cardColors(containerColor = MaterialTheme.colorScheme.surface.copy(alpha = 0.95f)),
                elevation = CardDefaults.cardElevation(defaultElevation = 0.dp) 
            ) {}
        }

        Column(
            modifier = Modifier
                .align(Alignment.BottomCenter)
                .fillMaxWidth()
                .padding(bottom = 24.dp, start = 16.dp, end = 16.dp),
            verticalArrangement = Arrangement.spacedBy(16.dp)
        ) {
            
            // Scrollable Control Area (Sits comfortably above the fixed Tab Bar)
            Column(
                modifier = Modifier
                    .fillMaxHeight(0.55f)
                    .verticalScroll(rememberScrollState()),
                verticalArrangement = Arrangement.spacedBy(8.dp)
            ) {
                
                if (selectedCategory == 1) {
                    Row(modifier = Modifier.fillMaxWidth(), horizontalArrangement = Arrangement.spacedBy(8.dp)) {
                        Button(onClick = { coroutineScope.launch { transferDirection = 1f; touchX = screenWidthPx / 2f; touchY = 0f; fluidState = FluidState.MAGNETIC_HOLD; fluidVolumeTarget = 1f } }, modifier = Modifier.weight(1f), colors = ButtonDefaults.buttonColors(containerColor = MaterialTheme.colorScheme.primary)) {
                            Icon(Icons.Default.Send, contentDescription = null, modifier = Modifier.size(18.dp)); Spacer(modifier = Modifier.width(4.dp)); Text("Send", fontWeight = FontWeight.Bold)
                        }
                        Button(onClick = { coroutineScope.launch { transferDirection = -1f; touchX = screenWidthPx / 2f; touchY = 0f; fluidState = FluidState.MAGNETIC_HOLD; fluidVolumeTarget = 1f } }, modifier = Modifier.weight(1f), colors = ButtonDefaults.buttonColors(containerColor = MaterialTheme.colorScheme.secondary)) {
                            Icon(Icons.Default.CallReceived, contentDescription = null, modifier = Modifier.size(18.dp)); Spacer(modifier = Modifier.width(4.dp)); Text("Receive", fontWeight = FontWeight.Bold)
                        }
                        Button(onClick = { fluidVolumeTarget = 0f; fluidState = FluidState.IDLE }, modifier = Modifier.weight(1f), colors = ButtonDefaults.buttonColors(containerColor = MaterialTheme.colorScheme.error)) {
                            Icon(Icons.Default.Close, contentDescription = null, modifier = Modifier.size(18.dp)); Spacer(modifier = Modifier.width(4.dp)); Text("Fail", fontWeight = FontWeight.Bold)
                        }
                    }
                }

                Card(colors = CardDefaults.cardColors(containerColor = MaterialTheme.colorScheme.surface.copy(alpha = 0.9f))) {
                    Row(modifier = Modifier.fillMaxWidth().horizontalScroll(rememberScrollState()).padding(8.dp), horizontalArrangement = Arrangement.SpaceEvenly) {
                        val currentEffects = when (selectedCategory) {
                            0 -> listOf("Lava", "Glint", "Prism", "Sparks", "Aura", "Rays")
                            1 -> listOf("Magnetic Meniscus", "OLED State-Change", "Cinematic Wormhole")
                            else -> listOf("Haptic Wave")
                        }
                        val currentIndex = when (selectedCategory) {
                            0 -> selectedNotificationIndex
                            1 -> selectedPhysicsIndex
                            else -> 0
                        }

                        currentEffects.forEachIndexed { index, name ->
                            val isSelected = currentIndex == index
                            TextButton(onClick = { 
                                when (selectedCategory) {
                                    0 -> selectedNotificationIndex = index
                                    1 -> selectedPhysicsIndex = index
                                }
                                isNotificationActive = selectedCategory == 0 
                            }, colors = ButtonDefaults.textButtonColors(contentColor = if (isSelected) MaterialTheme.colorScheme.primary else MaterialTheme.colorScheme.onSurface), contentPadding = PaddingValues(horizontal = 8.dp)) {
                                Text(name, fontWeight = if (isSelected) FontWeight.Bold else FontWeight.Normal, style = MaterialTheme.typography.labelMedium)
                            }
                        }
                    }
                }

                Card(colors = CardDefaults.cardColors(containerColor = MaterialTheme.colorScheme.surface.copy(alpha = 0.9f))) {
                    Row(modifier = Modifier.fillMaxWidth().padding(16.dp), horizontalArrangement = Arrangement.SpaceEvenly) {
                        appColors.forEach { color ->
                            val interactionSource = remember(color) { MutableInteractionSource() }
                            Box(modifier = Modifier.size(40.dp).background(color, CircleShape).border(width = if (selectedAppColor == color) 3.dp else 1.dp, color = if (selectedAppColor == color) MaterialTheme.colorScheme.primary else Color.Gray, shape = CircleShape).clickable(interactionSource = interactionSource, indication = null) { selectedAppColor = color; isNotificationActive = selectedCategory == 0 })
                        }
                    }
                }

                // DYNAMIC SLIDERS: Only show what is physically relevant for the current tab
                if (selectedCategory == 0 || selectedCategory == 2) {
                    TuningSlider("Speed", flowSpeed, 0.1f..5.0f) { flowSpeed = it }
                    TuningSlider("Thickness", thickness, 10f..100f) { thickness = it }
                    TuningSlider("Amplitude", amplitude, 10f..200f) { amplitude = it }
                    TuningSlider("Noise Scale", noiseScale, 0.5f..10.0f) { noiseScale = it }
                } else if (selectedCategory == 1) {
                    TuningSlider("Speed", flowSpeed, 0.1f..5.0f) { flowSpeed = it }
                    TuningSlider("Effect X Position", effectPosX, 0.0f..1.0f) { effectPosX = it }
                    TuningSlider("Effect Y Position", effectPosY, 0.0f..1.0f) { effectPosY = it }
                    TuningSlider("Effect Size Base", effectSize, 0.05f..0.4f) { effectSize = it }
                }
            }
            
            // Fixed Bottom Tab Bar
            Card(
                colors = CardDefaults.cardColors(containerColor = MaterialTheme.colorScheme.surface.copy(alpha = 0.9f)),
                elevation = CardDefaults.cardElevation(defaultElevation = 8.dp)
            ) {
                TabRow(selectedTabIndex = selectedCategory, containerColor = Color.Transparent, indicator = { tabPositions -> TabRowDefaults.SecondaryIndicator(Modifier.tabIndicatorOffset(tabPositions[selectedCategory]), color = MaterialTheme.colorScheme.primary) }) {
                    Tab(selected = selectedCategory == 0, onClick = { selectedCategory = 0; isNotificationActive = true }, text = { Text("Notifications", fontWeight = FontWeight.Bold, style = MaterialTheme.typography.labelMedium) })
                    Tab(selected = selectedCategory == 1, onClick = { selectedCategory = 1; isNotificationActive = false }, text = { Text("Send/Receive", fontWeight = FontWeight.Bold, style = MaterialTheme.typography.labelMedium) })
                    Tab(selected = selectedCategory == 2, onClick = { selectedCategory = 2; isNotificationActive = false }, text = { Text("Media Player", fontWeight = FontWeight.Bold, style = MaterialTheme.typography.labelMedium) })
                }
            }
        }
    }
}

@Composable
fun TuningSlider(label: String, value: Float, range: ClosedFloatingPointRange<Float>, onValueChange: (Float) -> Unit) {
    Card(colors = CardDefaults.cardColors(containerColor = MaterialTheme.colorScheme.surface.copy(alpha = 0.9f))) {
        Column(modifier = Modifier.padding(horizontal = 16.dp, vertical = 8.dp)) {
            Text("$label: ${String.format("%.2f", value)}", style = MaterialTheme.typography.labelMedium)
            Slider(value = value, onValueChange = onValueChange, valueRange = range)
        }
    }
}

@RequiresApi(Build.VERSION_CODES.TIRAMISU)
@Composable
fun AmbientEdgeLighting(
    modifier: Modifier = Modifier, shaderString: String, cornerRadius: Float = 120f,
    appColor: Color, speed: Float, thickness: Float, amplitude: Float, noiseScale: Float, masterAlpha: Float,
    pillCenterY: Float, pillWidth: Float, pillHeight: Float, gravityX: Float, gravityY: Float,
    touchX: Float, touchY: Float, touchActive: Float, fluidVolume: Float, transferDirection: Float,
    effectSize: Float,
    content: @Composable () -> Unit
) {
    var time by remember { mutableFloatStateOf(0f) }
    var wavePhase by remember { mutableFloatStateOf(0f) }
    
    LaunchedEffect(Unit) {
        val startTime = System.nanoTime()
        var lastTime = startTime
        while (true) {
            awaitFrame()
            val currentTime = System.nanoTime()
            val dt = (currentTime - lastTime) / 1_000_000_000f
            lastTime = currentTime
            
            time = (currentTime - startTime) / 1_000_000_000f
            wavePhase += (dt * speed * 15f) * fluidVolume
        }
    }

    val shader = remember(shaderString) { 
        RuntimeShader(shaderString.filter { it.code in 0..127 }) 
    }

    Box(
        modifier = modifier.graphicsLayer {
            shader.setFloatUniform("in_Resolution", size.width, size.height)
            shader.setFloatUniform("in_Time", time)
            shader.setFloatUniform("in_WavePhase", wavePhase) 
            shader.setFloatUniform("in_CornerRadius", cornerRadius)
            shader.setFloatUniform("in_AppColor", appColor.red, appColor.green, appColor.blue)
            shader.setFloatUniform("in_Speed", speed)
            shader.setFloatUniform("in_Spread", thickness)
            shader.setFloatUniform("in_Amplitude", amplitude)
            shader.setFloatUniform("in_NoiseScale", noiseScale)
            shader.setFloatUniform("in_MasterAlpha", masterAlpha) 
            shader.setFloatUniform("in_PillCenterY", pillCenterY)
            shader.setFloatUniform("in_PillWidth", pillWidth)
            shader.setFloatUniform("in_PillHeight", pillHeight)
            shader.setFloatUniform("in_Gravity", gravityX, gravityY)
            shader.setFloatUniform("in_TouchPos", touchX, touchY)
            shader.setFloatUniform("in_TouchActive", touchActive)
            shader.setFloatUniform("in_FluidVolume", fluidVolume)
            shader.setFloatUniform("in_TransferDirection", transferDirection)
            shader.setFloatUniform("in_EffectSize", effectSize)
            
            renderEffect = RenderEffect.createRuntimeShaderEffect(shader, "in_Background").asComposeRenderEffect()
            clip = true
        }
    ) {
        content()
    }
}
