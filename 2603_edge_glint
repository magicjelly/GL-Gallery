const val FLUID_SHADER = """
    uniform float2 in_Resolution; uniform float in_Time; uniform float in_CornerRadius; 
    uniform half3 in_AppColor; uniform float in_Speed; uniform float in_Spread; 
    uniform float in_Amplitude; uniform float in_NoiseScale; uniform float in_MasterAlpha; 
    uniform float in_PillCenterY; uniform float in_PillWidth; uniform float in_PillHeight;
    uniform float2 in_Gravity;
    
    // NEW: The Magnetic Touch Attractor
    uniform float2 in_TouchPos; 
    uniform float in_TouchActive; 

    float sdRoundRect(vec2 p, vec2 b, float r) {
        vec2 d = abs(p) - b + vec2(r); return min(max(d.x, d.y), 0.0) + length(max(d, 0.0)) - r;
    }

    half4 main(in float2 fragCoord) {
        vec2 p = fragCoord - (in_Resolution.xy * 0.5); vec2 b = in_Resolution.xy * 0.5;
        float distFromEdge = -sdRoundRect(p, b, in_CornerRadius); 
        float clampedDist = max(distFromEdge, 0.0);
        
        float time = in_Time * in_Speed * 0.5;
        vec2 physicalGravity = vec2(in_Gravity.x, -in_Gravity.y) * 0.6; 
        
        float fluidDensity = 0.0;
        for(float i = 1.0; i <= 5.0; i++) {
            // 1. Natural Hardware Gravity Drift
            vec2 gravityDriftPos = vec2(
                sin(time * 1.1 * i) * 0.3 + 0.5 + physicalGravity.x,
                cos(time * 0.9 * i) * 0.3 + 0.5 + physicalGravity.y
            ) * in_Resolution.xy;
            
            // 2. The NFC Magnetic Swarm
            // This calculates an organic "swarming" circle around the exact touch coordinate
            vec2 swarmOffset = vec2(sin(time * 3.0 + i * 1.5), cos(time * 2.5 + i * 1.5)) * (25.0 * i);
            vec2 magneticTouchPos = in_TouchPos + swarmOffset;
            
            // 3. The Physical Bridge 
            // Smoothly interpolate between falling due to gravity and flying towards the finger
            vec2 finalDropPos = mix(gravityDriftPos, magneticTouchPos, in_TouchActive);
            
            float distToDrop = length(fragCoord - finalDropPos);
            fluidDensity += (in_NoiseScale * 1500.0) / (distToDrop * distToDrop);
        }
        
        float threshold = 1.0 - (in_Amplitude / 200.0); 
        float viscousFluid = smoothstep(threshold, threshold + 0.05, fluidDensity);
        
        // When touch is active, let the fluid break slightly away from the absolute edge
        // so it can reach out toward the "connecting device"
        float magneticPullOffEdge = mix(0.5, 0.2, in_TouchActive);
        float decayFactor = 1.0 / max(in_Spread, 1.0);
        float edgeCore = exp(-clampedDist * decayFactor * magneticPullOffEdge);   
        
        float finalPresence = viscousFluid * edgeCore * 1.5;
        
        vec3 deepColor = mix(vec3(0.0, 0.1, 0.2), vec3(in_AppColor), fluidDensity);
        vec3 pureColor = mix(deepColor, vec3(1.0), smoothstep(threshold + 0.2, threshold + 0.5, fluidDensity));
        
        float screenMask = clamp(distFromEdge * 10.0, 0.0, 1.0);
        float finalAlpha = clamp(finalPresence, 0.0, 1.0) * screenMask * in_MasterAlpha;
        
        return half4(pureColor * finalAlpha, finalAlpha);
    }
"""

const val WAVE_SHADER = """
    uniform float2 in_Resolution; uniform float in_Time; uniform float in_CornerRadius; 
    uniform half3 in_AppColor; uniform float in_Speed; uniform float in_Spread; 
    uniform float in_Amplitude; uniform float in_NoiseScale; uniform float in_MasterAlpha; 
    uniform float in_PillCenterY; uniform float in_PillWidth; uniform float in_PillHeight;
    uniform float2 in_Gravity; uniform float2 in_TouchPos; uniform float in_TouchActive;

    const float PI = 3.14159265359;
    float sdRoundRect(vec2 p, vec2 b, float r) {
        vec2 d = abs(p) - b + vec2(r); return min(max(d.x, d.y), 0.0) + length(max(d, 0.0)) - r;
    }
    half4 main(in float2 fragCoord) {
        vec2 p = fragCoord - (in_Resolution.xy * 0.5); vec2 b = in_Resolution.xy * 0.5;
        vec2 centered = (fragCoord / in_Resolution.xy) - 0.5;
        float angle = (atan(-centered.y, centered.x) + PI) / (2.0 * PI);
        float time = in_Time * in_Speed * 3.0;

        float freq1 = sin(angle * (in_NoiseScale * 10.0) + time) * 0.5; 
        float freq2 = cos(angle * (in_NoiseScale * 5.0) - time * 0.8) * 0.3; 
        float beat = sin(time * 2.0) * 0.2; 
        float audioWaveform = (freq1 + freq2 + beat) * (in_Amplitude * 0.5);
        
        float rawDist = -sdRoundRect(p, b, in_CornerRadius); 
        float warpedDist = max(rawDist - audioWaveform, 0.0);
        float decayFactor = 1.0 / max(in_Spread, 1.0);
        
        float edgeCore = exp(-max(rawDist, 0.0) * decayFactor * 2.0); 
        float rippleGlow = exp(-warpedDist * decayFactor); 
        float finalPresence = max(edgeCore, rippleGlow);
        
        vec3 pureColor = mix(vec3(in_AppColor), vec3(1.0), clamp(audioWaveform * 0.02, 0.0, 1.0));
        float finalAlpha = clamp(finalPresence, 0.0, 1.0) * clamp(rawDist * 10.0, 0.0, 1.0) * in_MasterAlpha;
        
        return half4(pureColor * finalAlpha, finalAlpha);
    }
"""

