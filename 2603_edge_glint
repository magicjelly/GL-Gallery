enum class FluidState { IDLE, MAGNETIC_HOLD, RELEASE }

class EngineState {
    var selectedCategory by mutableIntStateOf(2)
    var isNotificationActive by mutableStateOf(false)
    var selectedNotificationIndex by mutableIntStateOf(4)
    var selectedPhysicsIndex by mutableIntStateOf(0)
    
    var touchX by mutableFloatStateOf(0f)
    var touchY by mutableFloatStateOf(0f)
    var isScreenTouched by mutableStateOf(false)
    var fluidState by mutableStateOf(FluidState.IDLE)
    
    var fluidVolumeTarget by mutableFloatStateOf(1f)
    var flowSpeed by mutableFloatStateOf(1.5f)
    var thickness by mutableFloatStateOf(40f)
    var amplitude by mutableFloatStateOf(80f)
    var noiseScale by mutableFloatStateOf(3.0f)
    
    var transferDirection by mutableFloatStateOf(1f)
    var effectSize by mutableFloatStateOf(0.18f)
    var effectPosX by mutableFloatStateOf(0.5f)
    var effectPosY by mutableFloatStateOf(0f)
    
    var selectedAppColor by mutableStateOf(Color(0xFF1999FF))
    val appColors = listOf(Color(0xFF1999FF), Color(0xFF25D366), Color(0xFFFFFC00), Color(0xFFFFFFFF))
    
    // Media Player State
    var isPlaying by mutableStateOf(false)
    var currentPosition by mutableIntStateOf(0)
    var mediaDuration by mutableIntStateOf(10000)
    var currentTrackName by mutableStateOf("Unknown Track")
    var mediaAlbumArt by mutableStateOf<ImageBitmap?>(null)
    var extractedMediaColor by mutableStateOf(Color(0x00111111))
    var isMediaUiVisible by mutableStateOf(true)
}

