        return mix(mix(hash(i), hash(i + vec2(1.0, 0.0)), f.x), mix(hash(i + vec2(0.0, 1.0)), hash(i + vec2(1.0, 1.0)), f.x), f.y);
    }
    float sdRoundRect(vec2 p, vec2 b, float r) {
        vec2 d = abs(p) - b + vec2(r); return min(max(d.x, d.y), 0.0) + length(max(d, 0.0)) - r;
    }
    half4 main(in float2 fragCoord) {
        vec2 pillCenter = vec2(in_Resolution.x * 0.5, in_PillCenterY);
        vec2 p = fragCoord - pillCenter;
        float d = sdRoundRect(p, vec2(in_PillWidth * 0.5, in_PillHeight * 0.5), in_PillHeight * 0.5);
        float distFromPill = max(d, 0.0);
        float angle = atan(-p.y, p.x); float time = in_Time * in_Speed * 0.15;
        vec2 uv1 = vec2(cos(angle + time), sin(angle + time)) * max(in_NoiseScale, 1.0) * 1.5;
        vec2 uv2 = vec2(cos(angle - time * 0.8), sin(angle - time * 0.8)) * max(in_NoiseScale, 1.0) * 3.0;
        float rays = pow(noise(uv1) * noise(uv2), 1.8) * (in_Amplitude * 0.05);
        float decay = 1.0 / max(in_Spread, 1.0);
        float rayBloom = rays * exp(-distFromPill * decay * 0.4); 
        float coreBloom = exp(-distFromPill * decay * 1.5) * 0.4; 
        vec3 pureColor = mix(vec3(in_AppColor), vec3(1.0), clamp(rayBloom * 1.5, 0.0, 1.0));
        float finalAlpha = clamp(coreBloom + rayBloom, 0.0, 1.0) * smoothstep(0.0, 2.0, d) * in_MasterAlpha;
        return half4(pureColor * finalAlpha, finalAlpha);
    }
"""

// ==========================================
// SHADER 6: BIOLUMINESCENT FLUID (Gravity/Gyro)
// ==========================================
const val FLUID_SHADER = """
    uniform float2 in_Resolution; uniform float in_Time; uniform float in_CornerRadius; 
    uniform half3 in_AppColor; uniform float in_Speed; uniform float in_Spread; 
    uniform float in_Amplitude; uniform float in_NoiseScale; uniform float in_MasterAlpha; 
    uniform float in_PillCenterY; uniform float in_PillWidth; uniform float in_PillHeight;

    float sdRoundRect(vec2 p, vec2 b, float r) {
        vec2 d = abs(p) - b + vec2(r); return min(max(d.x, d.y), 0.0) + length(max(d, 0.0)) - r;
    }

    half4 main(in float2 fragCoord) {
        vec2 p = fragCoord - (in_Resolution.xy * 0.5); vec2 b = in_Resolution.xy * 0.5;
        float distFromEdge = -sdRoundRect(p, b, in_CornerRadius); 
        float clampedDist = max(distFromEdge, 0.0);
        vec2 uv = fragCoord / in_Resolution.xy;
        
        float time = in_Time * in_Speed * 0.5;
        
        // Simulating Hardware Gyroscope / Gravity vector sloshing
        vec2 simulatedGravity = vec2(sin(time * 0.8) * 0.3, cos(time * 0.5) * 0.3);
        
        // Generate metaball "droplets" that drift along the edge
        float fluidDensity = 0.0;
        for(float i = 1.0; i <= 5.0; i++) {
            // Calculate drifting positions for droplets, influenced by "gravity"
            vec2 dropPos = vec2(
                sin(time * 1.1 * i) * 0.4 + 0.5 + simulatedGravity.x,
                cos(time * 0.9 * i) * 0.4 + 0.5 + simulatedGravity.y
            ) * in_Resolution.xy;
            
            float distToDrop = length(fragCoord - dropPos);
            // Inverse square falloff creates the "sticky" metaball merging effect
            fluidDensity += (in_NoiseScale * 1000.0) / (distToDrop * distToDrop);
        }
        
        // Gate the density to create hard, viscous fluid surfaces
        float threshold = 1.0 - (in_Amplitude / 200.0); 
        float viscousFluid = smoothstep(threshold, threshold + 0.05, fluidDensity);
        
        // Constrain the fluid physically to the hardware bezel
        float decayFactor = 1.0 / max(in_Spread, 1.0);
        float edgeCore = exp(-clampedDist * decayFactor * 0.5);   
        
        // Multiply the fluid by the edge glow so it only exists on the physical glass curve
        float finalPresence = viscousFluid * edgeCore * 1.5;
        
        // Deep bioluminescent coloring
        vec3 deepColor = mix(vec3(0.0, 0.1, 0.2), vec3(in_AppColor), fluidDensity);
        vec3 pureColor = mix(deepColor, vec3(1.0), smoothstep(threshold + 0.2, threshold + 0.5, fluidDensity));
        
        float screenMask = clamp(distFromEdge * 10.0, 0.0, 1.0);
        float finalAlpha = clamp(finalPresence, 0.0, 1.0) * screenMask * in_MasterAlpha;
        
        return half4(pureColor * finalAlpha, finalAlpha);
    }
"""

// ==========================================
// SHADER 7: RESONANT CYMATICS (Haptic Soundwave)
// ==========================================
const val WAVE_SHADER = """
    uniform float2 in_Resolution; uniform float in_Time; uniform float in_CornerRadius; 
    uniform half3 in_AppColor; uniform float in_Speed; uniform float in_Spread; 
    uniform float in_Amplitude; uniform float in_NoiseScale; uniform float in_MasterAlpha; 
    uniform float in_PillCenterY; uniform float in_PillWidth; uniform float in_PillHeight;

    const float PI = 3.14159265359;

    float sdRoundRect(vec2 p, vec2 b, float r) {
        vec2 d = abs(p) - b + vec2(r); return min(max(d.x, d.y), 0.0) + length(max(d, 0.0)) - r;
    }

    half4 main(in float2 fragCoord) {
        vec2 p = fragCoord - (in_Resolution.xy * 0.5); vec2 b = in_Resolution.xy * 0.5;
        
        vec2 centered = (fragCoord / in_Resolution.xy) - 0.5;
        float angle = (atan(-centered.y, centered.x) + PI) / (2.0 * PI);
        float time = in_Time * in_Speed * 3.0;

        // SYNTHETIC AUDIO FFT GENERATOR
        // This simulates a complex music soundwave bouncing along the bezel
        float freq1 = sin(angle * (in_NoiseScale * 10.0) + time) * 0.5; // High freq
        float freq2 = cos(angle * (in_NoiseScale * 5.0) - time * 0.8) * 0.3; // Mid freq
        float beat = sin(time * 2.0) * 0.2; // Low frequency bass thump
        
        // Combine frequencies into an audio waveform displacement value
        float audioWaveform = (freq1 + freq2 + beat) * (in_Amplitude * 0.5);
        
        // Calculate the physical distance, but subtract the audio waveform
        // This violently warps the distance field to the beat of the "music"
        float rawDist = -sdRoundRect(p, b, in_CornerRadius); 
        float warpedDist = max(rawDist - audioWaveform, 0.0);
        
        float decayFactor = 1.0 / max(in_Spread, 1.0);
        
        // The core hardware edge remains steady, but the glow ripples outward
        float edgeCore = exp(-max(rawDist, 0.0) * decayFactor * 2.0); 
        float rippleGlow = exp(-warpedDist * decayFactor); 
        
        float finalPresence = max(edgeCore, rippleGlow);
        
        // High-contrast color mapping for a sharp, kinetic visualizer look
        vec3 pureColor = mix(vec3(in_AppColor), vec3(1.0), clamp(audioWaveform * 0.02, 0.0, 1.0));
        
        float screenMask = clamp(rawDist * 10.0, 0.0, 1.0);
        float finalAlpha = clamp(finalPresence, 0.0, 1.0) * screenMask * in_MasterAlpha;
        
        return half4(pureColor * finalAlpha, finalAlpha);
    }
"""


