// 3. The Interactive UI Prototype Screen
@RequiresApi(Build.VERSION_CODES.TIRAMISU)
@Composable
fun NotificationSyncPrototype() {
    val density = LocalDensity.current
    val config = LocalConfiguration.current
    
    var hardwareCornerRadius by remember { mutableFloatStateOf(120f) }
    var isNotificationActive by remember { mutableStateOf(false) }
    
    var flowSpeed by remember { mutableFloatStateOf(1.5f) }
    var thickness by remember { mutableFloatStateOf(40f) }
    var amplitude by remember { mutableFloatStateOf(80f) }
    var noiseScale by remember { mutableFloatStateOf(3.0f) }
    
    val effects = listOf("Lava", "Glint", "Prism", "Sparks", "Aura", "Rays", "Fluid", "Wave")
    var selectedEffectIndex by remember { mutableIntStateOf(6) } 
    val activeShaderString = when(selectedEffectIndex) {
        0 -> LAVA_SHADER
        1 -> GLINT_SHADER
        2 -> PRISMATIC_SHADER
        3 -> SPARK_SHADER
        4 -> AURA_SHADER
        5 -> SUNLIGHT_SHADER
        6 -> FLUID_SHADER
        else -> WAVE_SHADER
    }
    
    val appColors = listOf(Color(0xFF1999FF), Color(0xFF25D366), Color(0xFFEA4335), Color(0xFFFFFC00), Color(0xFFFFFFFF))
    var selectedAppColor by remember { mutableStateOf(appColors[0]) }

    val pillOffsetY by animateDpAsState(targetValue = if (isNotificationActive) 32.dp else (-100).dp, animationSpec = spring(dampingRatio = 0.7f, stiffness = 400f), label = "pill")
    val masterAlpha by animateFloatAsState(targetValue = if (isNotificationActive) 1f else 0f, animationSpec = tween(durationMillis = 300, easing = LinearOutSlowInEasing), label = "alpha")

    val screenWidthPx = with(density) { config.screenWidthDp.dp.toPx() }
    val pillWidthPx = screenWidthPx * 0.9f
    val pillHeightPx = with(density) { 64.dp.toPx() }
    val pillCenterYPx = with(density) { pillOffsetY.toPx() + (64.dp.toPx() / 2f) }

    Box(
        modifier = Modifier.fillMaxSize().pointerInput(Unit) {
            detectTapGestures(onTap = { isNotificationActive = true }, onDoubleTap = { isNotificationActive = false })
        }
    ) {
        // --- LAYER 1: Background ---
        Image(
            painter = painterResource(id = android.R.drawable.sym_def_app_icon),
            contentDescription = "Background", contentScale = ContentScale.Crop, modifier = Modifier.fillMaxSize()
        )

        // --- LAYER 2: GPU Render Engine ---
        AmbientEdgeLighting(
            modifier = Modifier.fillMaxSize(),
            shaderString = activeShaderString,
            cornerRadius = hardwareCornerRadius, appColor = selectedAppColor,
            speed = flowSpeed, thickness = thickness, amplitude = amplitude, noiseScale = noiseScale,
            masterAlpha = masterAlpha,
            pillCenterY = pillCenterYPx, pillWidth = pillWidthPx, pillHeight = pillHeightPx 
        )

        // --- LAYER 3: Notification Pill ---
        Card(
            modifier = Modifier.align(Alignment.TopCenter).offset(y = pillOffsetY).alpha(masterAlpha).fillMaxWidth(0.9f).height(64.dp),
            shape = RoundedCornerShape(32.dp), colors = CardDefaults.cardColors(containerColor = MaterialTheme.colorScheme.surface.copy(alpha = 0.95f)),
            elevation = CardDefaults.cardElevation(defaultElevation = 0.dp) 
        ) {
            Row(modifier = Modifier.fillMaxSize().padding(horizontal = 12.dp), verticalAlignment = Alignment.CenterVertically) {
                Box(modifier = Modifier.size(40.dp).background(selectedAppColor, CircleShape), contentAlignment = Alignment.Center) {
                    val innerTint = if (selectedAppColor == Color(0xFFFFFFFF)) Color.Black else Color.White
                    Box(modifier = Modifier.size(20.dp).background(innerTint, RoundedCornerShape(4.dp)))
                }
                Spacer(modifier = Modifier.width(16.dp))
                Column(verticalArrangement = Arrangement.Center) {
                    Box(modifier = Modifier.width(120.dp).height(12.dp).background(MaterialTheme.colorScheme.onSurface.copy(alpha = 0.8f), RoundedCornerShape(4.dp)))
                    Spacer(modifier = Modifier.height(6.dp))
                    Box(modifier = Modifier.width(80.dp).height(10.dp).background(MaterialTheme.colorScheme.onSurface.copy(alpha = 0.4f), RoundedCornerShape(4.dp)))
                }
            }
        }

        // --- LAYER 4: Tuning Rig Controls ---
        Column(
            modifier = Modifier.align(Alignment.BottomCenter).fillMaxHeight(0.6f).fillMaxWidth()
                .padding(horizontal = 16.dp, vertical = 24.dp).verticalScroll(rememberScrollState()),
            horizontalAlignment = Alignment.CenterHorizontally, verticalArrangement = Arrangement.spacedBy(8.dp)
        ) {
            Card(colors = CardDefaults.cardColors(containerColor = MaterialTheme.colorScheme.surface.copy(alpha = 0.9f))) {
                // ADDED horizontalScroll so all 8 buttons fit gracefully
                Row(
                    modifier = Modifier.fillMaxWidth().horizontalScroll(rememberScrollState()).padding(8.dp), 
                    horizontalArrangement = Arrangement.spacedBy(8.dp)
                ) {
                    effects.forEachIndexed { index, name ->
                        val isSelected = selectedEffectIndex == index
                        TextButton(
                            onClick = { selectedEffectIndex = index; isNotificationActive = true },
                            colors = ButtonDefaults.textButtonColors(contentColor = if (isSelected) MaterialTheme.colorScheme.primary else MaterialTheme.colorScheme.onSurface),
                            contentPadding = PaddingValues(horizontal = 8.dp) 
                        ) {
                            Text(name, fontWeight = if (isSelected) FontWeight.Bold else FontWeight.Normal, style = MaterialTheme.typography.labelMedium)
                        }
                    }
                }
            }

            Card(colors = CardDefaults.cardColors(containerColor = MaterialTheme.colorScheme.surface.copy(alpha = 0.9f))) {
                Row(modifier = Modifier.fillMaxWidth().padding(16.dp), horizontalArrangement = Arrangement.SpaceEvenly) {
                    appColors.forEach { color ->
                        val interactionSource = remember(color) { MutableInteractionSource() }
                        Box(
                            modifier = Modifier.size(40.dp).background(color, CircleShape)
                                .border(width = if (selectedAppColor == color) 3.dp else 1.dp, color = if (selectedAppColor == color) MaterialTheme.colorScheme.primary else Color.Gray, shape = CircleShape)
                                .clickable(interactionSource = interactionSource, indication = null) { selectedAppColor = color; isNotificationActive = true }
                        )
                    }
                }
            }

            TuningSlider("Speed / Time Scale", flowSpeed, 0.1f..5.0f) { flowSpeed = it }
            TuningSlider("Spread / Thickness", thickness, 10f..150f) { thickness = it }
            TuningSlider("Amplitude / Density", amplitude, 0f..200f) { amplitude = it }
            TuningSlider("Noise / Freq / Radius", noiseScale, 1.0f..10.0f) { noiseScale = it }
        }
    }
}

@Composable
fun TuningSlider(label: String, value: Float, range: ClosedFloatingPointRange<Float>, onValueChange: (Float) -> Unit) {
    Card(colors = CardDefaults.cardColors(containerColor = MaterialTheme.colorScheme.surface.copy(alpha = 0.9f))) {
        Column(modifier = Modifier.padding(horizontal = 16.dp, vertical = 8.dp)) {
            Text("$label: ${String.format("%.1f", value)}", style = MaterialTheme.typography.labelMedium)
            Slider(value = value, onValueChange = onValueChange, valueRange = range)
        }
    }
}

@RequiresApi(Build.VERSION_CODES.TIRAMISU)
@Composable
fun AmbientEdgeLighting(
    modifier: Modifier = Modifier, shaderString: String, cornerRadius: Float = 120f,
    appColor: Color, speed: Float, thickness: Float, amplitude: Float, noiseScale: Float, masterAlpha: Float,
    pillCenterY: Float, pillWidth: Float, pillHeight: Float 
) {
    var time by remember { mutableFloatStateOf(0f) }
    
    LaunchedEffect(Unit) {
        val startTime = System.nanoTime()
        while (true) {
            awaitFrame()
            time = (System.nanoTime() - startTime) / 1_000_000_000f
        }
    }

    val shader = remember(shaderString) { 
        val safeString = shaderString.filter { it.code in 0..127 }
        RuntimeShader(safeString) 
    }
    val shaderBrush = remember(shader) { ShaderBrush(shader) }

    Box(
        modifier = modifier
            .drawWithCache {
                shader.setFloatUniform("in_Resolution", size.width, size.height)
                shader.setFloatUniform("in_Time", time)
                shader.setFloatUniform("in_CornerRadius", cornerRadius)
                shader.setFloatUniform("in_AppColor", appColor.red, appColor.green, appColor.blue)
                shader.setFloatUniform("in_Speed", speed)
                shader.setFloatUniform("in_Spread", thickness)
                shader.setFloatUniform("in_Amplitude", amplitude)
                shader.setFloatUniform("in_NoiseScale", noiseScale)
                shader.setFloatUniform("in_MasterAlpha", masterAlpha) 
                
                shader.setFloatUniform("in_PillCenterY", pillCenterY)
                shader.setFloatUniform("in_PillWidth", pillWidth)
                shader.setFloatUniform("in_PillHeight", pillHeight)
                
                onDrawBehind { drawRect(brush = shaderBrush, blendMode = BlendMode.Plus) }
            }
    )
}
