const val LAVA_SHADER = """
    uniform float2 in_Resolution; uniform float in_Time; uniform float in_CornerRadius; 
    uniform half3 in_AppColor; uniform float in_Speed; uniform float in_Spread; 
    uniform float in_Amplitude; uniform float in_NoiseScale; uniform float in_MasterAlpha; 
    uniform float in_PillCenterY; uniform float in_PillWidth; uniform float in_PillHeight;
    uniform float2 in_Gravity; uniform float2 in_TouchPos; uniform float in_TouchActive;
    
    float hash(vec2 p) { return fract(sin(dot(p, vec2(12.9898, 78.233))) * 43758.5453); }
    float noise(vec2 p) {
        vec2 i = floor(p); vec2 f = fract(p); f = f * f * (3.0 - 2.0 * f);
        return mix(mix(hash(i), hash(i + vec2(1.0, 0.0)), f.x), mix(hash(i + vec2(0.0, 1.0)), hash(i + vec2(1.0, 1.0)), f.x), f.y);
    }
    float fBm(vec2 p) {
        float f = 0.0; f += 0.5000 * noise(p); p = p * 2.02; f += 0.2500 * noise(p); p = p * 2.03; f += 0.1250 * noise(p); p = p * 2.01; return f / 0.875;
    }
    float sdRoundRect(vec2 p, vec2 b, float r) {
        vec2 d = abs(p) - b + vec2(r); return min(max(d.x, d.y), 0.0) + length(max(d, 0.0)) - r;
    }
    half4 main(in float2 fragCoord) {
        vec2 p = fragCoord - (in_Resolution.xy * 0.5); vec2 b = in_Resolution.xy * 0.5;
        float d = -sdRoundRect(p, b, in_CornerRadius); float clampedDist = max(d, 0.0);
        vec2 uv = fragCoord / in_Resolution.xy;
        vec2 noiseUV = uv * vec2(max(in_NoiseScale, 1.0), max(in_NoiseScale, 1.0) * 2.0); 
        float time = in_Time * in_Speed; 
        float flow1 = fBm(noiseUV + vec2(time * 0.5, -time * 0.8));
        float flow2 = fBm(noiseUV * 1.5 - vec2(-time * 0.3, time * 1.1));
        float complexNoise = pow((flow1 + flow2) * 0.5, 2.0); 
        float distortedDist = max(clampedDist - (complexNoise * in_Amplitude), 0.0);
        float decayFactor = 1.0 / max(in_Spread, 1.0);
        float baseGlow = exp(-distortedDist * decayFactor); float edgeCore = exp(-clampedDist * 0.5);   
        float finalLavaPresence = max(baseGlow, edgeCore);
        vec3 deepRootColor = mix(vec3(in_AppColor) * 0.25, vec3(0.0, 0.0, 0.1), 0.3); 
        vec3 midRangeColor = mix(deepRootColor, vec3(in_AppColor), 1.0 - smoothstep(0.0, in_Spread * 2.0, distortedDist));
        vec3 pureColor = mix(vec3(1.0), midRangeColor, smoothstep(0.0, 2.0, clampedDist));
        float pixelAlpha = finalLavaPresence * mix(0.15, 1.0, uv.y) * 0.95; 
        float finalAlpha = pixelAlpha * clamp(d * 10.0, 0.0, 1.0) * in_MasterAlpha;
        return half4(pureColor * finalAlpha, finalAlpha);
    }
"""

const val GLINT_SHADER = """
    uniform float2 in_Resolution; uniform float in_Time; uniform float in_CornerRadius; 
    uniform half3 in_AppColor; uniform float in_Speed; uniform float in_Spread; 
    uniform float in_Amplitude; uniform float in_NoiseScale; uniform float in_MasterAlpha; 
    uniform float in_PillCenterY; uniform float in_PillWidth; uniform float in_PillHeight;
    uniform float2 in_Gravity; uniform float2 in_TouchPos; uniform float in_TouchActive;
    
    const float PI = 3.14159265359;
    float sdRoundRect(vec2 p, vec2 b, float r) {
        vec2 d = abs(p) - b + vec2(r); return min(max(d.x, d.y), 0.0) + length(max(d, 0.0)) - r;
    }
    half4 main(in float2 fragCoord) {
        vec2 p = fragCoord - (in_Resolution.xy * 0.5); vec2 b = in_Resolution.xy * 0.5;
        float d = -sdRoundRect(p, b, in_CornerRadius); float clampedDist = max(d, 0.0);
        vec2 centered = (fragCoord / in_Resolution.xy) - 0.5;
        float angle = (atan(-centered.y, centered.x) + PI) / (2.0 * PI);
        float sweep = fract(in_Time * in_Speed * 0.3);
        float angularDist = fract(sweep - angle); float distForward = fract(angle - sweep); 
        float tail = exp(-angularDist * (1.0 / max(in_Amplitude * 0.005, 0.05))); 
        float front = exp(-distForward * 100.0); float dropShape = max(tail, front); 
        float spatialDist = min(angularDist, distForward) * ((in_Resolution.x + in_Resolution.y) * 1.5); 
        float headGlow = exp(-length(vec2(spatialDist, clampedDist)) / max(in_NoiseScale * 2.0, 2.0));
        float baseGlow = exp(-clampedDist * (1.0 / max(in_Spread, 1.0))); 
        vec3 pureColor = mix(mix(vec3(0.0), vec3(in_AppColor), tail), vec3(1.0), min(headGlow * 1.5, 1.0));
        float finalAlpha = clamp(baseGlow * dropShape + headGlow, 0.0, 1.0) * clamp(d * 10.0, 0.0, 1.0) * in_MasterAlpha;
        return half4(pureColor * finalAlpha, finalAlpha);
    }
"""

