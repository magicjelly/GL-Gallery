    float sdRoundRect(vec2 p, vec2 b, float r) {
        vec2 d = abs(p) - b + vec2(r); return min(max(d.x, d.y), 0.0) + length(max(d, 0.0)) - r;
    }
    
    float hash(vec2 p) { return fract(sin(dot(p, vec2(12.9898, 78.233))) * 43758.5453); }

    half4 main(in float2 fragCoord) {
        vec2 p = fragCoord - (in_Resolution.xy * 0.5); vec2 b = in_Resolution.xy * 0.5;
        float distFromEdge = -sdRoundRect(p, b, in_CornerRadius); 
        float screenMask = clamp(distFromEdge * 10.0, 0.0, 1.0) * in_MasterAlpha;
        
        vec2 touchVec = fragCoord - in_TouchPos;
        float distToTouch = length(touchVec);
        float tensionWidth = in_Resolution.x * in_EffectSize * 4.5; 

        float elevation = exp(-(distToTouch * distToTouch) / (tensionWidth * tensionWidth)) * in_TouchActive * in_FluidVolume;

        vec3 blurredBG = vec3(0.0);
        float samples = 12.0;
        float blurRadius = elevation * 40.0; 
        
        for(float i = 0.0; i < 12.0; i++) {
            float angle = (i * 6.28318 / samples); 
            float crystalShatter = hash(fragCoord + i) * 15.0 * elevation;
            vec2 offset = vec2(cos(angle), sin(angle)) * (blurRadius + crystalShatter);

            float r = in_Background.eval(fragCoord + offset * 1.05).r;
            float g = in_Background.eval(fragCoord + offset).g;
            float b = in_Background.eval(fragCoord + offset * 0.95).b;
            blurredBG += vec3(r, g, b);
        }
        blurredBG /= samples;

        float luma = dot(blurredBG, vec3(0.299, 0.587, 0.114));
        vec3 frostedIce = mix(blurredBG, vec3(luma), elevation * 0.90);

        float vignette = smoothstep(tensionWidth * 3.0, tensionWidth * 0.1, distToTouch);
        frostedIce *= mix(1.0, vignette, in_FluidVolume * 0.7);

        float pulse = (sin(in_WavePhase * 0.8 * -in_TransferDirection - (distToTouch * 0.005)) + 1.0) * 0.5;
        float coreGlow = exp(-pow(distToTouch / (tensionWidth * 0.6), 2.0)) * elevation;

        vec3 glowColor = mix(vec3(in_AppColor), vec3(1.0), 0.4); 
        vec3 finalGlow = glowColor * coreGlow * (0.1 + pulse * 0.4);
        
        float iceSpec = exp(-(distToTouch * distToTouch) / (tensionWidth * tensionWidth * 0.2)) * elevation;

        vec3 finalColor = frostedIce + finalGlow + (vec3(1.0) * iceSpec * 0.15);
        
        return half4(half3(finalColor * screenMask), half(screenMask));
    }
"""

 // SHADER C: CINEMATIC WORMHOLE (Anchored Edges & Safety Clamp)
const val WORMHOLE_SHADER = """
    uniform shader in_Background; uniform float2 in_Resolution; uniform float in_Time; uniform float in_WavePhase; uniform float in_CornerRadius; 
    uniform half3 in_AppColor; uniform float in_Speed; uniform float in_Spread; 
    uniform float in_Amplitude; uniform float in_NoiseScale; uniform float in_MasterAlpha; 
    uniform float in_PillCenterY; uniform float in_PillWidth; uniform float in_PillHeight;
    uniform float2 in_Gravity; uniform float2 in_TouchPos; uniform float in_TouchActive; 
    uniform float in_FluidVolume; uniform float in_TransferDirection; uniform float in_EffectSize;

    float sdRoundRect(vec2 p, vec2 b, float r) {
        vec2 d = abs(p) - b + vec2(r); return min(max(d.x, d.y), 0.0) + length(max(d, 0.0)) - r;
    }

    vec3 drawCinematicOrbs(vec2 uv, float time, float phase, float direction, float elevation, half3 appColor, float lumaAdapt, float effectSize) {
        float starlight = 0.0;
        
        for (float i = 0.0; i < 24.0; i++) {
            float h1 = fract(sin(i * 7.13) * 268.53);
            float h2 = fract(sin(i * 13.7) * 412.11);
            
            float rawProgress = fract(h1 + (phase * 0.008));
            float gravityFall = pow(rawProgress, 5.0); 
            
            float startR = (direction > 0.0) ? 2.2 : 0.0;
            float endR = (direction > 0.0) ? 0.0 : 2.2;
            
            float currentR = mix(startR, endR, gravityFall);
            
            float currentAngle = (h2 * 6.28318) + (time * 0.05) - (1.5 / (currentR + 0.2));
            
            vec2 orbPos = vec2(cos(currentAngle), sin(currentAngle)) * currentR;
            float dist = length(uv - orbPos);
            
            float scaleBase = mix(1.0, 0.3, gravityFall);
            
            float core = exp(-dist * mix(50.0, 80.0, h1) / scaleBase) * 3.5;
            float halo = exp(-dist * mix(12.0, 30.0, h2) / scaleBase) * 1.5;
            
            float fadeOutInner = smoothstep(effectSize * 0.7, effectSize * 2.5, currentR);
            float fadeInOuter = smoothstep(2.2, 1.5, currentR);
            float orbMask = fadeOutInner * fadeInOuter;
            
            starlight += (core + halo) * orbMask;
        }
        
        vec3 hotWhite = vec3(1.0, 0.98, 0.95);
        vec3 finalOrbColor = mix(vec3(appColor), hotWhite, 0.8);
        
        return finalOrbColor * starlight * elevation * (1.0 + lumaAdapt);
    }

    half4 main(in float2 fragCoord) {
        vec2 p = fragCoord - (in_Resolution.xy * 0.5); vec2 b = in_Resolution.xy * 0.5;
        float distFromEdge = -sdRoundRect(p, b, in_CornerRadius); 
        float screenMask = clamp(distFromEdge * 10.0, 0.0, 1.0) * in_MasterAlpha;
        
        vec2 touchVec = fragCoord - in_TouchPos;
        float tensionWidth = in_Resolution.x * 0.28; 
        float distToTouch = length(touchVec);
        
        float rawElevation = exp(-(distToTouch * distToTouch) / (tensionWidth * tensionWidth)) * in_TouchActive * in_FluidVolume;
        float elevation = rawElevation * smoothstep(tensionWidth * 1.5, tensionWidth * 1.0, distToTouch);

        float voidRadius = tensionWidth * in_EffectSize;
        float eventHorizon = 1.0 - smoothstep(voidRadius, voidRadius + 8.0, distToTouch);
        
        float dentWidth = voidRadius * 1.5;
        float dent = exp(-(distToTouch * distToTouch) / (dentWidth * dentWidth));
        
        // EDGE ANCHOR FIX: Lock the left, right, and bottom edges of the screen.
        float distToLeftRight = min(fragCoord.x, in_Resolution.x - fragCoord.x);
        float distToBottom = in_Resolution.y - fragCoord.y;
        float edgeAnchor = smoothstep(0.0, in_Resolution.x * 0.1, distToLeftRight) * smoothstep(0.0, in_Resolution.y * 0.1, distToBottom);

        vec2 gradient = -2.0 * touchVec / (tensionWidth * tensionWidth) * elevation;
        gradient += -10.0 * (touchVec / dentWidth) * dent * elevation * (1.0 - eventHorizon);
        
        // Flatten normals at the edge to prevent weird specular highlights on the bezels
        gradient *= edgeAnchor; 
        
        vec3 normal = normalize(vec3(-gradient.x, -gradient.y, 0.008));
        float normalizedAngle = normal.z;

        // Apply anchor to refraction so it stops pulling near the bezels
        float baseRefraction = 400.0 * elevation * edgeAnchor; 
        float chromaticSpread = length(normal.xy) * (150.0 + (elevation * 200.0)) * elevation * edgeAnchor;
        
        vec2 safeNormal = normalize(normal.xy + vec2(0.0001)); 
        vec2 warpedCoordR = fragCoord + (normal.xy * baseRefraction) + (safeNormal * chromaticSpread);
        vec2 warpedCoordG = fragCoord + (normal.xy * baseRefraction);
        vec2 warpedCoordB = fragCoord + (normal.xy * baseRefraction) - (safeNormal * chromaticSpread);
        
        // CLAMP FIX: 3-pixel inset safety clamp
        vec2 minBounds = vec2(3.0);
        vec2 maxBounds = in_Resolution.xy - vec2(3.0);

        vec2 coordR = clamp(warpedCoordR, minBounds, maxBounds);
        vec2 coordG = clamp(warpedCoordG, minBounds, maxBounds);
        vec2 coordB = clamp(warpedCoordB, minBounds, maxBounds);

        float bgR = in_Background.eval(coordR).r;
        float bgG = in_Background.eval(coordG).g;
        float bgB = in_Background.eval(coordB).b;
        vec3 refractedBG = vec3(bgR, bgG, bgB);
        
        float luma = dot(refractedBG, vec3(0.299, 0.587, 0.114));
        float darknessAdaptation = smoothstep(0.4, 0.0, luma); 

        float vignette = smoothstep(tensionWidth * 3.5, tensionWidth * 0.5, distToTouch);
        refractedBG *= mix(1.0, vignette, elevation * 0.9);

        vec2 normalizedVec = touchVec / tensionWidth;
        vec3 starlight = drawCinematicOrbs(normalizedVec, in_Time, in_WavePhase, in_TransferDirection, elevation, in_AppColor, darknessAdaptation, in_EffectSize);

        vec3 lightDir = normalize(vec3(-1.0, -1.0, 1.0)); 
        float spec = pow(max(dot(normal, lightDir), 0.0), 80.0) * (2.0 + darknessAdaptation) * elevation;
        vec3 specularLight = vec3(1.0) * spec * (1.0 - eventHorizon); 
        
        float fresnel = pow(1.0 - normalizedAngle, 8.0);
        vec3 rimLight = vec3(in_AppColor) * fresnel * (4.0 + darknessAdaptation) * elevation * dent * (1.0 - eventHorizon);
        
        vec3 finalColor = refractedBG + starlight + specularLight + rimLight;
        finalColor = mix(finalColor, vec3(0.0, 0.0, 0.0), eventHorizon * elevation);
        
        return half4(half3(finalColor * screenMask), half(screenMask));
    }
"""

      

// ==========================================
// MEDIA PLAYER SHADERS
// ==========================================

// SHADER D: HAPTIC WAVE 
const val WAVE_SHADER = """
    uniform shader in_Background; uniform float2 in_Resolution; uniform float in_Time; uniform float in_WavePhase; uniform float in_CornerRadius; uniform half3 in_AppColor; uniform float in_Speed; uniform float in_Spread; uniform float in_Amplitude; uniform float in_NoiseScale; uniform float in_MasterAlpha; uniform float in_PillCenterY; uniform float in_PillWidth; uniform float in_PillHeight; uniform float2 in_Gravity; uniform float2 in_TouchPos; uniform float in_TouchActive; uniform float in_FluidVolume; uniform float in_TransferDirection; uniform float in_EffectSize;
    float sdRoundRect(vec2 p, vec2 b, float r) { vec2 d = abs(p) - b + vec2(r); return min(max(d.x, d.y), 0.0) + length(max(d, 0.0)) - r; }
    const float PI = 3.14159265359;
    half4 main(in float2 fragCoord) {
        vec2 p = fragCoord - (in_Resolution.xy * 0.5); vec2 b = in_Resolution.xy * 0.5; vec2 centered = (fragCoord / in_Resolution.xy) - 0.5; 
        float theta = atan(-centered.y, centered.x); float time = in_Time * in_Speed * 3.0;
        float f1 = floor(in_NoiseScale * 3.0) + 1.0; float f2 = floor(in_NoiseScale * 2.0) + 1.0;
        float freq1 = sin(theta * f1 + time) * 0.5; float freq2 = cos(theta * f2 - time * 0.8) * 0.3; float beat = sin(time * 2.0) * 0.2; 
        float audioWaveform = (freq1 + freq2 + beat) * (in_Amplitude * 0.5);
        float rawDist = -sdRoundRect(p, b, in_CornerRadius); float warpedDist = max(rawDist - audioWaveform, 0.0); float decayFactor = 1.0 / max(in_Spread, 1.0);
        float edgeCore = exp(-max(rawDist, 0.0) * decayFactor * 2.0); float rippleGlow = exp(-warpedDist * decayFactor); float finalPresence = max(edgeCore, rippleGlow);
        vec3 pureColor = mix(vec3(in_AppColor), vec3(1.0), clamp(audioWaveform * 0.02, 0.0, 1.0)); 
        float finalAlpha = clamp(finalPresence, 0.0, 1.0) * clamp(rawDist * 10.0, 0.0, 1.0) * in_MasterAlpha; 
        half4 bg = in_Background.eval(fragCoord); return half4(bg.rgb + (pureColor * finalAlpha), 1.0);
    }
"""

