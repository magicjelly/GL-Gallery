// ==========================================
// SHADER 1: THE SPECULAR GLINT (Sweeping)
// ==========================================
const val GLINT_SHADER = """
    uniform float2 in_Resolution; uniform float in_Time; uniform float in_CornerRadius; 
    uniform half3 in_AppColor; uniform float in_Speed; uniform float in_Spread; 
    uniform float in_Amplitude; uniform float in_NoiseScale; uniform float in_MasterAlpha; 
    const float PI = 3.14159265359;
    
    float sdRoundRect(vec2 p, vec2 b, float r) {
        vec2 d = abs(p) - b + vec2(r); return min(max(d.x, d.y), 0.0) + length(max(d, 0.0)) - r;
    }
    
    half4 main(in float2 fragCoord) {
        vec2 p = fragCoord - (in_Resolution.xy * 0.5); vec2 b = in_Resolution.xy * 0.5;
        float d = -sdRoundRect(p, b, in_CornerRadius); float clampedDist = max(d, 0.0);
        vec2 centered = (fragCoord / in_Resolution.xy) - 0.5;
        
        float angle = (atan(-centered.y, centered.x) + PI) / (2.0 * PI);
        float sweep = fract(in_Time * in_Speed * 0.3);
        
        // 1. ORGANIC DROPLET SHAPE (Fixes the sharp edge)
        float angularDist = fract(sweep - angle); // The long tail trailing behind
        float distForward = fract(angle - sweep); // The short slope pushing forward
        
        // Create a seamless volume that slopes down in front and trails off in back
        float tailLength = max(in_Amplitude * 0.005, 0.05); 
        float tail = exp(-angularDist * (1.0 / tailLength)); 
        float front = exp(-distForward * 100.0); // Steep, but completely smooth forward slope
        
        float dropShape = max(tail, front); // The seamless app-color footprint
        
        // 2. TRUE SPHERICAL HOTSPOT
        float approxPerimeter = (in_Resolution.x + in_Resolution.y) * 1.5; 
        float spatialDist = min(angularDist, distForward) * approxPerimeter; 
        
        float headRadius = max(in_NoiseScale * 2.0, 2.0); 
        float headGlow = exp(-length(vec2(spatialDist, clampedDist)) / headRadius);
        
        // 3. COMBINE
        float thicknessDecay = 1.0 / max(in_Spread, 1.0);
        float baseGlow = exp(-clampedDist * thicknessDecay); 
        
        float finalPresence = baseGlow * dropShape;
        
        // Color mix transitions perfectly from AppColor to Pure White at the spherical core
        vec3 pureColor = mix(vec3(in_AppColor), vec3(1.0), min(headGlow * 1.5, 1.0));
        
        float screenMask = clamp(d * 10.0, 0.0, 1.0);
        float finalAlpha = clamp(finalPresence + headGlow, 0.0, 1.0) * screenMask * in_MasterAlpha;
        
        return half4(pureColor * finalAlpha, finalAlpha);
    }
"""



// ==========================================
// SHADER 2: PRISMATIC REFRACTION (Aberration)
// ==========================================
const val PRISMATIC_SHADER = """
    uniform float2 in_Resolution; uniform float in_Time; uniform float in_CornerRadius; 
    uniform half3 in_AppColor; uniform float in_Speed; uniform float in_Spread; 
    uniform float in_Amplitude; uniform float in_NoiseScale; uniform float in_MasterAlpha; 
    float sdRoundRect(vec2 p, vec2 b, float r) {
        vec2 d = abs(p) - b + vec2(r); return min(max(d.x, d.y), 0.0) + length(max(d, 0.0)) - r;
    }
    half4 main(in float2 fragCoord) {
        vec2 p = fragCoord - (in_Resolution.xy * 0.5); vec2 b = in_Resolution.xy * 0.5;
        float d = -sdRoundRect(p, b, in_CornerRadius); 
        
        // Offset mapping: Creates the spatial split for the RGB channels
        float offset = (sin(in_Time * in_Speed) + 1.0) * 0.5 * in_Amplitude * 0.2 + (in_Spread * 0.05);
        float dR = max(d - offset, 0.0);
        float dG = max(d, 0.0);
        float dB = max(d + offset, 0.0);
        
        float decay = 1.0 / max(in_Spread, 1.0);
        float r = exp(-dR * decay);
        float g = exp(-dG * decay);
        float bl = exp(-dB * decay);
        
        // Mix the raw RGB split with the app color for a tinted glass look
        vec3 prismColor = vec3(r, g, bl);
        vec3 finalColor = mix(prismColor, vec3(in_AppColor) * prismColor, 0.6);
        
        float alpha = max(r, max(g, bl));
        float screenMask = clamp(d * 10.0, 0.0, 1.0);
        float finalAlpha = alpha * screenMask * in_MasterAlpha;
        return half4(finalColor * finalAlpha, finalAlpha);
    }
"""

// ==========================================
// SHADER 3: MAGNETIC SPARKS (Frosted Bokeh)
// ==========================================
const val SPARK_SHADER = """
    uniform float2 in_Resolution; uniform float in_Time; uniform float in_CornerRadius; 
    uniform half3 in_AppColor; uniform float in_Speed; uniform float in_Spread; 
    uniform float in_Amplitude; uniform float in_NoiseScale; uniform float in_MasterAlpha; 
    
    // Hash to generate random behaviors for each individual spark
    float hash(vec2 p) { return fract(sin(dot(p, vec2(12.9898, 78.233))) * 43758.5453); }
    
    float sdRoundRect(vec2 p, vec2 b, float r) {
        vec2 d = abs(p) - b + vec2(r); return min(max(d.x, d.y), 0.0) + length(max(d, 0.0)) - r;
    }
    
    half4 main(in float2 fragCoord) {
        vec2 p = fragCoord - (in_Resolution.xy * 0.5); vec2 b = in_Resolution.xy * 0.5;
        float d = -sdRoundRect(p, b, in_CornerRadius); float clampedDist = max(d, 0.0);
        
        // 1. CELLULAR GRID SYSTEM (Perfectly square cells independent of screen ratio)
        // Noise scale slider now controls the physical size of the grid boxes
        float cellSize = max(60.0 - (in_NoiseScale * 5.0), 15.0);
        vec2 particleUV = fragCoord / cellSize;
        
        // Push the entire grid upward to make sparks rise
        particleUV.y += in_Time * in_Speed * 1.5;
        // Add a gentle horizontal drift
        particleUV.x += sin(particleUV.y * 0.5) * 0.3;
        
        vec2 cellID = floor(particleUV); // The unique ID of this invisible box
        vec2 localPos = fract(particleUV); // Where we are inside the box (0.0 to 1.0)
        
        // 2. SPARK GENERATION
        float randomSeed = hash(cellID); // A random number just for this cell
        
        // Place the spark randomly inside the cell, but keep it away from the absolute edges
        vec2 sparkCenter = vec2(0.5) + 0.3 * vec2(sin(randomSeed * 100.0), cos(randomSeed * 100.0));
        float distToSpark = length(localPos - sparkCenter);
        
        // Make the spark twinkle dynamically based on its random seed and time
        float twinkle = (sin(in_Time * 5.0 + randomSeed * 50.0) + 1.0) * 0.5;
        
        // Gate the sparks: Amplitude slider controls how many boxes actually get a spark
        float threshold = clamp(1.0 - (in_Amplitude / 200.0), 0.05, 0.98);
        float isSparkAlive = step(threshold, randomSeed);
        
        // Draw a perfectly round, razor-sharp dot
        float sparkShape = exp(-distToSpark * 25.0) * isSparkAlive * twinkle;
        
        // 3. HARDWARE ROUTING
        float decay = 1.0 / max(in_Spread, 1.0);
        float baseGlow = exp(-clampedDist * decay) * 0.1; // Very dim base line
        
        // Sparks are only allowed to exist physically near the edge of the screen
        float edgeMask = exp(-clampedDist * 0.1); 
        float finalPresence = baseGlow + (sparkShape * edgeMask * 3.0);
        
        // Overexpose the color to white where the spark is brightest
        vec3 pureColor = mix(vec3(in_AppColor), vec3(1.0), clamp(sparkShape * 1.5, 0.0, 1.0));
        
        float screenMask = clamp(d * 10.0, 0.0, 1.0);
        float finalAlpha = clamp(finalPresence, 0.0, 1.0) * screenMask * in_MasterAlpha;
        
        return half4(pureColor * finalAlpha, finalAlpha);
    }
"""



