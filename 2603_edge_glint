// ==========================================
// SHADER 6: TOPOLOGICAL TENSION BRIDGE (Exaggerated Pull & Directional Pulses)
// ==========================================
const val FLUID_SHADER = """
    uniform shader in_Background;
    uniform float2 in_Resolution; uniform float in_Time; uniform float in_CornerRadius; 
    uniform half3 in_AppColor; uniform float in_Speed; uniform float in_Spread; 
    uniform float in_Amplitude; uniform float in_NoiseScale; uniform float in_MasterAlpha; 
    uniform float in_PillCenterY; uniform float in_PillWidth; uniform float in_PillHeight;
    uniform float2 in_Gravity; uniform float2 in_TouchPos; uniform float in_TouchActive; 
    uniform float in_FluidVolume; uniform float in_Direction;

    float sdRoundRect(vec2 p, vec2 b, float r) {
        vec2 d = abs(p) - b + vec2(r); return min(max(d.x, d.y), 0.0) + length(max(d, 0.0)) - r;
    }

    half4 main(in float2 fragCoord) {
        vec2 p = fragCoord - (in_Resolution.xy * 0.5); vec2 b = in_Resolution.xy * 0.5;
        float distFromEdge = -sdRoundRect(p, b, in_CornerRadius); 
        float screenMask = clamp(distFromEdge * 10.0, 0.0, 1.0) * in_MasterAlpha;
        
        float tensionWidth = max(250.0 - in_Amplitude, 40.0);
        
        vec2 touchVec = fragCoord - in_TouchPos;
        float distToTouch = length(touchVec);
        
        float elevation = exp(-(distToTouch * distToTouch) / (tensionWidth * tensionWidth)) * in_TouchActive * in_FluidVolume;

        // 1. BIDIRECTIONAL DATA PULSES
        // in_Direction flips the sine wave. 
        // 1.0 = Send (Wave moves TOWARDS touch point). -1.0 = Receive (Wave moves AWAY from touch point).
        float time = in_Time * in_Speed * 12.0;
        float dataPulse = (sin(distToTouch * 0.08 + (time * in_Direction)) * 0.5 + 0.5) * elevation * in_FluidVolume;
        
        elevation += (dataPulse * 0.15);

        // 2. EXAGGERATED NORMALS
        // Dropping the Z-value from 0.015 to 0.008 forces a much steeper mathematical curve.
        vec2 gradient = -2.0 * touchVec / (tensionWidth * tensionWidth) * elevation;
        vec3 normal = normalize(vec3(-gradient.x, -gradient.y, 0.008));

        // 3. THE SPATIAL PINCH + SEVERE REFRACTION
        // We dramatically increased the refraction multiplier (120 to 250)
        vec2 refractionOffset = normal.xy * 250.0 * elevation;
        // The Pinch: We literally suck the background pixels physically closer to the contact point
        vec2 pinchOffset = -touchVec * (elevation * 0.4); 
        
        vec2 warpedCoord = fragCoord + refractionOffset + pinchOffset;
        vec3 bg = in_Background.eval(warpedCoord).rgb;
        
        // 4. CAUSTIC LIGHTING (Sharpened for the steeper curve)
        vec3 lightDir = normalize(vec3(-1.0, -1.0, 1.0)); 
        
        // Specular Highlight is now much tighter and brighter
        float spec = pow(max(dot(normal, lightDir), 0.0), 60.0) * 2.5 * elevation;
        float fresnel = pow(1.0 - max(dot(normal, vec3(0.0, 0.0, 1.0)), 0.0), 4.0);
        vec3 rimLight = in_AppColor * fresnel * 3.0 * elevation;
        
        float shadow = max(dot(normal, -lightDir), 0.0) * 0.4 * elevation;
        bg = mix(bg, bg * 0.1, shadow);

        // 5. COMPOSITION (Boosted pulse visibility)
        vec3 finalColor = bg + vec3(spec) + rimLight + (in_AppColor * dataPulse * 0.8);
        
        return half4(finalColor * screenMask, screenMask);
    }
"""

const val WAVE_SHADER = """
