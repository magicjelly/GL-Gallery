// SHADER 6: THE FLAGSHIP ENGINE (CPU-Coupled Kinetics, Spacetime Bend, Adaptive Luma)
const val FLUID_SHADER = """
    uniform shader in_Background;
    uniform float2 in_Resolution; uniform float in_Time; uniform float in_WavePhase; uniform float in_CornerRadius; 
    uniform half3 in_AppColor; uniform float in_Speed; uniform float in_Spread; 
    uniform float in_Amplitude; uniform float in_NoiseScale; uniform float in_MasterAlpha; 
    uniform float in_PillCenterY; uniform float in_PillWidth; uniform float in_PillHeight;
    uniform float2 in_Gravity; uniform float2 in_TouchPos; uniform float in_TouchActive; 
    uniform float in_FluidVolume; uniform float in_TransferDirection; 

    float sdRoundRect(vec2 p, vec2 b, float r) {
        vec2 d = abs(p) - b + vec2(r); return min(max(d.x, d.y), 0.0) + length(max(d, 0.0)) - r;
    }

    half4 main(in float2 fragCoord) {
        vec2 p = fragCoord - (in_Resolution.xy * 0.5); vec2 b = in_Resolution.xy * 0.5;
        float distFromEdge = -sdRoundRect(p, b, in_CornerRadius); 
        float screenMask = clamp(distFromEdge * 10.0, 0.0, 1.0) * in_MasterAlpha;
        
        // 1. PERFECTLY STABLE GRAVITY WELL
        vec2 touchVec = fragCoord - in_TouchPos;
        float distToTouch = length(touchVec);
        float tensionWidth = in_Resolution.x * 0.28; 
        
        float elevation = exp(-(distToTouch * distToTouch) / (tensionWidth * tensionWidth)) * in_TouchActive * in_FluidVolume;

        // 2. ROCK-SOLID 3D NORMALS
        vec2 gradient = -2.0 * touchVec / (tensionWidth * tensionWidth) * elevation;
        vec3 normal = normalize(vec3(-gradient.x, -gradient.y, 0.008));
        float normalizedAngle = normal.z;

        // 3. CRANKED REFRACTION & CHROMATIC ABERRATION
        float baseRefraction = 350.0 * elevation; 
        float chromaticSpread = length(normal.xy) * (80.0 + (elevation * 100.0));
        
        vec2 safeNormal = normalize(normal.xy + vec2(0.0001)); 
        vec2 coordR = fragCoord + (normal.xy * baseRefraction) + (safeNormal * chromaticSpread);
        vec2 coordG = fragCoord + (normal.xy * baseRefraction);
        vec2 coordB = fragCoord + (normal.xy * baseRefraction) - (safeNormal * chromaticSpread);
        
        float bgR = in_Background.eval(coordR).r;
        float bgG = in_Background.eval(coordG).g;
        float bgB = in_Background.eval(coordB).b;
        vec3 refractedBG = vec3(bgR, bgG, bgB);
        
        // 4. ADAPTIVE LUMINANCE TRACKING
        float luma = dot(refractedBG, vec3(0.299, 0.587, 0.114));
        float darknessAdaptation = smoothstep(0.4, 0.0, luma); 

        // 5. SPACETIME OPTICAL RIPPLES (CPU-Coupled Kinetics)
        vec2 warpedTouchVec = fragCoord + (normal.xy * baseRefraction * 1.5) - in_TouchPos;
        float warpedDistToTouch = length(warpedTouchVec);
        
        float spatialCompression = 0.04 - (elevation * 0.015);
        
        // We use the pure, accumulated phase from Jetpack Compose for flawless acceleration/deceleration
        float localPhase = (warpedDistToTouch * spatialCompression) + (in_WavePhase * in_TransferDirection); 
        float energyPulse = pow(sin(localPhase) * 0.5 + 0.5, 3.0) * elevation;

        // 6. DYNAMIC CAUSTIC LIGHTING
        vec3 lightDir = normalize(vec3(-1.0, -1.0, 1.0)); 
        
        float spec = pow(max(dot(normal, lightDir), 0.0), 60.0) * (1.5 + darknessAdaptation) * elevation;
        vec3 specularLight = vec3(1.0) * spec;
        
        float glowMultiplier = 0.6 + (darknessAdaptation * 2.5); 
        vec3 frostedWave = mix(vec3(1.0), in_AppColor, 0.4) * energyPulse * glowMultiplier;
        
        float fresnel = pow(1.0 - normalizedAngle, 5.0);
        vec3 rimLight = in_AppColor * fresnel * (1.5 + darknessAdaptation) * elevation;
        
        refractedBG = mix(refractedBG, refractedBG * 0.2, elevation * (0.8 - (darknessAdaptation * 0.5)));
        float shadow = max(dot(normal, -lightDir), 0.0) * 0.5 * elevation * (1.0 - darknessAdaptation);
        refractedBG = mix(refractedBG, vec3(0.0), shadow);

        // 7. COMPOSITION
        vec3 finalColor = refractedBG + frostedWave + specularLight + rimLight;
        
        return half4(finalColor * screenMask, screenMask);
    }
"""

const val WAVE_SHADER = """
    uniform shader in_Background;
    uniform float2 in_Resolution; uniform float in_Time; uniform float in_WavePhase; uniform float in_CornerRadius; uniform half3 in_AppColor; uniform float in_Speed; uniform float in_Spread; uniform float in_Amplitude; uniform float in_NoiseScale; uniform float in_MasterAlpha; uniform float in_PillCenterY; uniform float in_PillWidth; uniform float in_PillHeight; uniform float2 in_Gravity; uniform float2 in_TouchPos; uniform float in_TouchActive; uniform float in_FluidVolume; uniform float in_TransferDirection;
    float sdRoundRect(vec2 p, vec2 b, float r) { vec2 d = abs(p) - b + vec2(r); return min(max(d.x, d.y), 0.0) + length(max(d, 0.0)) - r; }
    const float PI = 3.14159265359;
    half4 main(in float2 fragCoord) {
        vec2 p = fragCoord - (in_Resolution.xy * 0.5); vec2 b = in_Resolution.xy * 0.5; vec2 centered = (fragCoord / in_Resolution.xy) - 0.5; 
        float theta = atan(-centered.y, centered.x); float time = in_Time * in_Speed * 3.0;
        float f1 = floor(in_NoiseScale * 3.0) + 1.0; float f2 = floor(in_NoiseScale * 2.0) + 1.0;
        float freq1 = sin(theta * f1 + time) * 0.5; float freq2 = cos(theta * f2 - time * 0.8) * 0.3; float beat = sin(time * 2.0) * 0.2; 
        float audioWaveform = (freq1 + freq2 + beat) * (in_Amplitude * 0.5);
        float rawDist = -sdRoundRect(p, b, in_CornerRadius); float warpedDist = max(rawDist - audioWaveform, 0.0); float decayFactor = 1.0 / max(in_Spread, 1.0);
        float edgeCore = exp(-max(rawDist, 0.0) * decayFactor * 2.0); float rippleGlow = exp(-warpedDist * decayFactor); float finalPresence = max(edgeCore, rippleGlow);
        vec3 pureColor = mix(vec3(in_AppColor), vec3(1.0), clamp(audioWaveform * 0.02, 0.0, 1.0)); 
        float finalAlpha = clamp(finalPresence, 0.0, 1.0) * clamp(rawDist * 10.0, 0.0, 1.0) * in_MasterAlpha; 
        half4 bg = in_Background.eval(fragCoord); return half4(bg.rgb + (pureColor * finalAlpha), 1.0);
    }
"""

