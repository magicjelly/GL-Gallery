@UnstableApi
class AudioTrendEngine : TeeAudioProcessor.AudioBufferSink {
    var attackAlpha: Float = 0.05f
    var releaseAlpha: Float = 0.005f
    var audioGain: Float = 10.0f 

    private val _smoothedResonance = MutableStateFlow(0f)
    val smoothedResonance: StateFlow<Float> = _smoothedResonance 

    private val _immediateEnergy = MutableStateFlow(0f)
    val immediateEnergy: StateFlow<Float> = _immediateEnergy 

    private var currentEMAValue = 0f
    private var previousFilteredSample = 0f
    private val lpfAlpha = 0.05f 

    override fun flush(sampleRateHz: Int, channelCount: Int, encoding: Int) {
        currentEMAValue = 0f
        previousFilteredSample = 0f
        _smoothedResonance.value = 0f
        _immediateEnergy.value = 0f
    }

    override fun handleBuffer(buffer: ByteBuffer) {
        val limit = buffer.limit()
        if (limit == 0) return
        var sumSquares = 0.0
        var sampleCount = 0
        buffer.position(0)
        while (buffer.position() < limit - 1) {
            val rawSample = buffer.short.toFloat() / Short.MAX_VALUE
            val filteredSample = previousFilteredSample + lpfAlpha * (rawSample - previousFilteredSample)
            previousFilteredSample = filteredSample
            sumSquares += (filteredSample * filteredSample)
            sampleCount++
        }
        val rawRms = if (sampleCount > 0) sqrt(sumSquares / sampleCount).toFloat() else 0f
        val boostedRms = (rawRms * audioGain).coerceIn(0f, 1f)
        _immediateEnergy.value = boostedRms
        val alpha = if (boostedRms > currentEMAValue) attackAlpha else releaseAlpha
        currentEMAValue = (alpha * boostedRms) + ((1f - alpha) * currentEMAValue)
        _smoothedResonance.value = currentEMAValue.coerceIn(0f, 1f)
    }
}

// ==========================================
// 프리미엄 쉐이더: 시차(Parallax)와 고대비 보케 적용
// ==========================================
const val BOKEH_SHADER_SRC = """
    uniform float2 u_resolution;
    uniform float u_energy;
    uniform float u_resonance;
    uniform float3 u_artColor;
    uniform float u_posOffset;
    
    float hash21(float2 p) {
        p = fract(p*float2(234.34, 435.12));
        p += dot(p, p+34.23);
        return fract(p.x*p.y);
    }

    // 레이어 드로잉: 시차와 부드러움을 위한 파라미터 추가
    float drawLayer(float2 uv, float gridSize, float offset, float blur, float sizeBase, float flickerSeed) {
        float2 st = uv * gridSize;
        float2 gridId = floor(st);
        float2 localUv = fract(st) - 0.5;
        
        float rnd = hash21(gridId);
        float t = offset + rnd * 6.28;
        float2 p = float2(sin(t), cos(t)) * 0.35;
        
        float d = distance(localUv, p);
        
        // 유기적인 빛남(Shimmer)을 위한 사인파 적용
        float shimmer = 0.6 + 0.4 * sin(offset * 2.0 + rnd * 10.0);
        
        return smoothstep(sizeBase, sizeBase - blur, d) * shimmer;
    }

    half4 main(float2 fragCoord) {
        float2 uv = fragCoord / u_resolution;
        uv.x *= u_resolution.x / u_resolution.y;
        
        half3 finalColor = half3(0.0);
        
        // --- LAYER 1: 웅장한 백그라운드 보케 (Z-Plane Deep) ---
        // 크기를 3배로 키우고, 이동 속도를 전경의 30%로 제한하여 깊이감 형성
        float bokehSize = 0.15 + u_resonance * 0.45;
        float bokehBlur = 0.7; 
        float bokehLayer = drawLayer(uv, 5.0, u_posOffset * 0.3, bokehBlur, bokehSize, 1.0);
        finalColor += half3(u_artColor) * half(bokehLayer * 0.35);

        // --- LAYER 2: 선명한 전경 입자 (Energy Dust) ---
        // 미세하고 선명하며, 에너지에 반응하여 빠르게 움직임
        float dustSize = 0.03 + u_energy * 0.08;
        float dustBlur = 0.05; 
        float dustLayer = drawLayer(uv, 15.0, u_posOffset * 1.2, dustBlur, dustSize, 2.0);
        finalColor += half3(u_artColor) * half(dustLayer * (0.5 + u_energy * 1.0));
        
        // 배경 베이스 조명
        float dist = distance(fragCoord / u_resolution.xy, float2(0.5, 0.5));
        half3 baseBg = half3(u_artColor) * 0.08;
        finalColor += baseBg;
        
        // 비네팅 (중앙 앨범 아트 집중)
        finalColor *= smoothstep(1.2, 0.2, dist);

        return half4(finalColor, 1.0);
    }
"""

@OptIn(UnstableApi::class)
@Composable
fun FluidMediaPrototype() {
    val context = LocalContext.current
    val audioEngine = remember { AudioTrendEngine() }
    val exoPlayer = remember { setupExoPlayer(context, audioEngine) }
    
    var currentArtBitmap by remember { mutableStateOf<android.graphics.Bitmap?>(null) }
    var currentFluidColor by remember { mutableStateOf(Color.Cyan) }
    var accumulatedFlowOffset by remember { mutableFloatStateOf(0f) }
    var isPresentationMode by remember { mutableStateOf(false) }
    
    // 복원된 컨트롤 룸 상태
    var gainState by remember { mutableFloatStateOf(audioEngine.audioGain) }
    var attackState by remember { mutableFloatStateOf(audioEngine.attackAlpha) }
    var releaseState by remember { mutableFloatStateOf(audioEngine.releaseAlpha) }

    DisposableEffect(exoPlayer) {
        val listener = object : Player.Listener {
            override fun onMediaMetadataChanged(mediaMetadata: MediaMetadata) {
                val artworkBytes = mediaMetadata.artworkData
                if (artworkBytes != null) {
                    val bitmap = BitmapFactory.decodeByteArray(artworkBytes, 0, artworkBytes.size)
                    currentArtBitmap = bitmap
                    Palette.from(bitmap).generate { palette ->
                        val extracted = palette?.getVibrantColor(Color.Cyan.toArgb()) ?: Color.Cyan.toArgb()
                        currentFluidColor = Color(extracted)
                    }
                }
            }
        }
        exoPlayer.addListener(listener)
        onDispose { exoPlayer.release() }
    }

    val filePickerLauncher = rememberLauncherForActivityResult(ActivityResultContracts.GetContent()) { uri ->
        uri?.let {
            exoPlayer.setMediaItem(MediaItem.fromUri(it))
            exoPlayer.prepare()
            exoPlayer.playWhenReady = true
        }
    }

    val audioResonance by audioEngine.smoothedResonance.collectAsState()
    val audioEnergy by audioEngine.immediateEnergy.collectAsState()
    val bokehShader = remember { RuntimeShader(BOKEH_SHADER_SRC) }

    LaunchedEffect(Unit) {
        while (true) {
            withFrameMillis { 
                val targetEnergy = if (exoPlayer.isPlaying) audioEnergy else 0f
                // 부드러운 가속/감속 로직
                accumulatedFlowOffset += 0.003f + (targetEnergy * 0.018f)
            }
        }
    }

    Column(modifier = Modifier.fillMaxSize().background(Color.Black)) {
        Box(modifier = Modifier.weight(if (isPresentationMode) 1f else 0.5f).fillMaxWidth(), contentAlignment = Alignment.Center) {
            Canvas(modifier = Modifier.fillMaxSize()) {
                bokehShader.setFloatUniform("u_resolution", size.width, size.height)
                bokehShader.setFloatUniform("u_posOffset", accumulatedFlowOffset)
                bokehShader.setFloatUniform("u_artColor", currentFluidColor.red, currentFluidColor.green, currentFluidColor.blue)
                bokehShader.setFloatUniform("u_energy", if (exoPlayer.isPlaying) audioEnergy else 0.02f)
                bokehShader.setFloatUniform("u_resonance", if (exoPlayer.isPlaying) audioResonance else 0.02f)
                drawRect(brush = ShaderBrush(bokehShader))
            }
            
            if (currentArtBitmap != null) {
                Image(
                    bitmap = currentArtBitmap!!.asImageBitmap(), 
                    contentDescription = null, 
                    modifier = Modifier.size(if (isPresentationMode) 280.dp else 180.dp).clip(RoundedCornerShape(16.dp))
                )
            }
        }

        // --- 복원된 컨트롤 룸 UI ---
        AnimatedVisibility(visible = !isPresentationMode) {
            Column(modifier = Modifier.fillMaxWidth().background(Color(0xFF121212)).padding(24.dp)) {
                Row(modifier = Modifier.fillMaxWidth(), horizontalArrangement = Arrangement.SpaceBetween) {
                    Text("Control Room", color = Color.White, style = MaterialTheme.typography.titleMedium)
                    Button(onClick = { filePickerLauncher.launch("audio/*") }, colors = ButtonDefaults.buttonColors(containerColor = Color(0xFF4CAF50))) { Text("Pick MP3") }
                }
                
                Spacer(modifier = Modifier.height(16.dp))
                
                Text("Bass Boost (Gain): ${String.format("%.1fx", gainState)}", color = Color.Gray)
                Slider(gainState, { gainState = it; audioEngine.audioGain = it }, valueRange = 1f..20f)

                Text("Attack (Swell): ${String.format("%.3f", attackState)}", color = Color.Gray)
                Slider(attackState, { attackState = it; audioEngine.attackAlpha = it }, valueRange = 0.001f..0.5f)

                Text("Release (Fade): ${String.format("%.3f", releaseState)}", color = Color.Gray)
                Slider(releaseState, { releaseState = it; audioEngine.releaseAlpha = it }, valueRange = 0.001f..0.1f)
                
                Text("Design Note: Background bokeh moves at 30% speed of foreground dust for Z-depth parallax.", 
                    color = Color.DarkGray, style = MaterialTheme.typography.bodySmall)
            }
        }

        Box(modifier = Modifier.fillMaxWidth().padding(16.dp), contentAlignment = Alignment.Center) {
            Button(onClick = { isPresentationMode = !isPresentationMode }, colors = ButtonDefaults.buttonColors(containerColor = Color.DarkGray)) {
                Text(if (isPresentationMode) "Open Controls" else "Presentation Mode")
            }
        }
    }
}

@UnstableApi
fun setupExoPlayer(context: Context, audioEngine: AudioTrendEngine): ExoPlayer {
    val teeProcessor = TeeAudioProcessor(audioEngine)
    val audioSink = DefaultAudioSink.Builder().setAudioProcessors(arrayOf(teeProcessor)).build()
    val renderersFactory = object : DefaultRenderersFactory(context) {
        override fun buildAudioSink(c: Context, f: Boolean, a: Boolean, e: Boolean) = audioSink
    }
    return ExoPlayer.Builder(context, renderersFactory).build().apply { repeatMode = Player.REPEAT_MODE_ONE }
}
