// ==========================================
// 1. ENGINE: MOMENTUM & INERTIA LOGIC
// ==========================================
@UnstableApi
class AudioTrendEngine : TeeAudioProcessor.AudioBufferSink {
    var audioGain: Float = 30.0f 
    private val _realTimePeak = MutableStateFlow(0f)
    val realTimePeak: StateFlow<Float> = _realTimePeak 
    private val _momentum = MutableStateFlow(0f)
    val momentum: StateFlow<Float> = _momentum 

    private var currentMomentum = 0f
    private var prevFiltered = 0f

    override fun flush(sampleRateHz: Int, channelCount: Int, encoding: Int) {
        currentMomentum = 0f; prevFiltered = 0f
        _realTimePeak.value = 0f; _momentum.value = 0f
    }

    override fun handleBuffer(buffer: ByteBuffer) {
        val limit = buffer.limit()
        if (limit == 0) return
        var sumSq = 0.0
        buffer.position(0)
        while (buffer.position() < limit - 1) {
            val raw = buffer.short.toFloat() / Short.MAX_VALUE
            val filtered = prevFiltered + 0.05f * (raw - prevFiltered)
            prevFiltered = filtered
            sumSq += (filtered * filtered)
        }
        val rms = (sqrt(sumSq / (limit / 2)).toFloat() * audioGain).coerceIn(0f, 1f)
        _realTimePeak.value = rms
        
        // MOMENTUM LOGIC: The "Beat" accelerates the motion
        // Damping (0.96) ensures the motion "coasts" smoothly after the beat.
        currentMomentum = (currentMomentum * 0.96f) + (rms * 0.04f)
        _momentum.value = currentMomentum.coerceIn(0f, 1f)
    }
}

// ==========================================
// 2. THE MOMENTUM BOKEH SHADER (AGSL)
// ==========================================
const val BOKEH_SHADER_SRC = """
    uniform float2 u_resolution;
    uniform float u_energy;       // Peak
    uniform float u_momentum;     // Damped Momentum
    uniform float3 u_artColor;    
    uniform float u_time;    
    
    float hash21(float2 p) {
        p = fract(p*float2(234.34, 435.12));
        p += dot(p, p+34.23);
        return fract(p.x*p.y);
    }

    float2 getFloatingOffset(float2 id, float time) {
        float speed = 0.15 + hash21(id) * 0.25;
        return float2(
            sin(time * speed + id.x * 12.0),
            cos(time * speed * 0.9 + id.y * 18.0)
        ) * 0.5;
    }

    // UPDATED: ADDITIVE BLOOM DISC
    float drawLensOrb(float2 localUv, float rnd, float time, float energy, float momentum) {
        // Z-Depth cycling
        float zDepth = fract(rnd + time * 0.04);
        float focusDist = abs(zDepth - 0.5);
        
        // ENLARGED SIZE: Higher base size for density/overlap
        float size = 0.12 + (focusDist * 0.75) + (momentum * 0.15);
        float blur = 0.02 + (focusDist * 0.95);
        
        float alpha = smoothstep(0.0, 0.2, zDepth) * smoothstep(1.0, 0.7, zDepth);
        float d = distance(localUv, float2(0.0));
        
        // UNIFORM DISC: Strong flat center, very soft edge
        float mask = smoothstep(size, size - blur, d);
        
        // SHIMMER: Decoupled from erratic spikes, tied to momentum for smoothness
        float shimmer = (0.7 + 0.3 * sin(time * 2.5 + rnd * 30.0)) * (0.6 + momentum * 1.5);
        
        return mask * shimmer * alpha;
    }

    float getLayer(float2 uv, float gridSize, float time, float energy, float momentum) {
        float2 st = uv * gridSize;
        float2 i_st = floor(st);
        float2 f_st = fract(st) - 0.5;
        float layer = 0.0;
        
        // 3x3 Neighbor sampling is essential for the dense overlap look
        for(float y=-1.0; y<=1.0; y++) {
            for(float x=-1.0; x<=1.0; x++) {
                float2 neighbor = float2(x, y);
                float2 id = i_st + neighbor;
                float rnd = hash21(id);
                float2 p = neighbor + getFloatingOffset(id, time);
                
                // Additive accumulation: Overlapping orbs brighten the scene
                layer += drawLensOrb(f_st - p, rnd, time, energy, momentum);
            }
        }
        return layer;
    }

    half4 main(float2 fragCoord) {
        float2 uv = fragCoord / u_resolution;
        uv.x *= u_resolution.x / u_resolution.y;
        
        half3 finalColor = half3(0.0);
        
        // Atmosphere Orbs (Low density, very large for overlap)
        float l1 = getLayer(uv, 3.8, u_time, u_energy, u_momentum);
        finalColor += half3(u_artColor) * half(l1 * 0.45);

        // Foreground Specs (Higher density, crisp focus)
        float l2 = getLayer(uv, 10.0, u_time * 1.3, u_energy, u_momentum);
        finalColor += half3(u_artColor) * half(l2 * 0.7);
        
        float centerDist = distance(fragCoord / u_resolution.xy, float2(0.5, 0.5));
        finalColor += half3(u_artColor) * 0.12; 
        finalColor *= smoothstep(1.4, 0.3, centerDist);

        return half4(finalColor, 1.0);
    }
"""

// ==========================================
// 3. UI & PROTOTYPE SCREEN
// ==========================================
@OptIn(UnstableApi::class)
@Composable
fun FluidMediaPrototype() {
    val context = LocalContext.current
    val audioEngine = remember { AudioTrendEngine() }
    val exoPlayer = remember { setupExoPlayer(context, audioEngine) }
    
    var currentArtBitmap by remember { mutableStateOf<android.graphics.Bitmap?>(null) }
    var currentFluidColor by remember { mutableStateOf(Color(0xFF607D8B)) }
    var engineTime by remember { mutableFloatStateOf(0f) }
    var isPresentationMode by remember { mutableStateOf(false) }

    DisposableEffect(exoPlayer) {
        val listener = object : Player.Listener {
            override fun onMediaMetadataChanged(mediaMetadata: MediaMetadata) {
                mediaMetadata.artworkData?.let { data ->
                    val bitmap = BitmapFactory.decodeByteArray(data, 0, data.size)
                    currentArtBitmap = bitmap
                    Palette.from(bitmap).generate { p ->
                        val fallback = 0xFF607D8B.toInt()
                        currentFluidColor = Color(p?.getVibrantColor(p.getMutedColor(p.getDominantColor(fallback))) ?: fallback)
                    }
                }
            }
        }
        exoPlayer.addListener(listener)
        onDispose { exoPlayer.release() }
    }

    val filePicker = rememberLauncherForActivityResult(ActivityResultContracts.GetContent()) { uri ->
        uri?.let { exoPlayer.setMediaItem(MediaItem.fromUri(it)); exoPlayer.prepare(); exoPlayer.playWhenReady = true }
    }

    val peak by audioEngine.realTimePeak.collectAsState()
    val momentum by audioEngine.momentum.collectAsState()
    val bokehShader = remember { RuntimeShader(BOKEH_SHADER_SRC) }

    // PHYSICS-BASED TIME LOOP
    LaunchedEffect(Unit) {
        while (true) {
            withFrameMillis { 
                // Speed doesn't snap. It relies on the COASTING momentum.
                // 0.008f is the baseline "drift" speed.
                val driftSpeed = if (exoPlayer.isPlaying) (0.008f + momentum * 0.06f) else 0.004f
                engineTime += driftSpeed
            }
        }
    }

    Column(modifier = Modifier.fillMaxSize().background(Color.Black)) {
        Box(modifier = Modifier.weight(if (isPresentationMode) 1f else 0.62f).fillMaxWidth(), contentAlignment = Alignment.Center) {
            Canvas(modifier = Modifier.fillMaxSize()) {
                bokehShader.setFloatUniform("u_resolution", size.width, size.height)
                bokehShader.setFloatUniform("u_time", engineTime)
                bokehShader.setFloatUniform("u_artColor", currentFluidColor.red, currentFluidColor.green, currentFluidColor.blue)
                bokehShader.setFloatUniform("u_energy", if (exoPlayer.isPlaying) peak else 0.02f)
                bokehShader.setFloatUniform("u_momentum", if (exoPlayer.isPlaying) momentum else 0.02f)
                drawRect(brush = ShaderBrush(bokehShader))
            }
            if (currentArtBitmap != null) {
                Image(bitmap = currentArtBitmap!!.asImageBitmap(), contentDescription = null, 
                    modifier = Modifier.size(if (isPresentationMode) 280.dp else 200.dp).clip(RoundedCornerShape(32.dp)))
            }
        }

        AnimatedVisibility(visible = !isPresentationMode) {
            Column(modifier = Modifier.fillMaxWidth().background(Color(0xFF080808)).padding(24.dp)) {
                Row(modifier = Modifier.fillMaxWidth(), horizontalArrangement = Arrangement.SpaceBetween, verticalAlignment = Alignment.CenterVertically) {
                    Text("FLUID MOMENTUM ENGINE", color = Color.White, style = MaterialTheme.typography.titleSmall)
                    Button(onClick = { filePicker.launch("audio/*") }, colors = ButtonDefaults.buttonColors(containerColor = Color(0xFF2E7D32))) {
                        Text("OPEN TRACK", style = MaterialTheme.typography.labelSmall)
                    }
                }
                Spacer(modifier = Modifier.height(20.dp))
                TelemetryBar("INSTANT BEAT", peak, Color(0xFFFF5722))
                TelemetryBar("COASTING MOMENTUM", momentum, Color(0xFF00E5FF))
                
                Spacer(modifier = Modifier.height(16.dp))
                Text("Damping Gain: ${String.format("%.1fx", audioEngine.audioGain)}", color = Color.Gray, style = MaterialTheme.typography.labelSmall)
                Slider(audioEngine.audioGain, { audioEngine.audioGain = it }, valueRange = 1f..60f)
            }
        }
        
        Box(modifier = Modifier.fillMaxWidth().padding(16.dp), contentAlignment = Alignment.Center) {
            Button(onClick = { isPresentationMode = !isPresentationMode }, 
                colors = ButtonDefaults.buttonColors(containerColor = if (isPresentationMode) Color.DarkGray else currentFluidColor.copy(alpha = 0.5f))) {
                Text(if (isPresentationMode) "VIEW PHYSICS" else "PRESENTATION MODE")
            }
        }
    }
}

@Composable
fun TelemetryBar(label: String, value: Float, color: Color) {
    Row(verticalAlignment = Alignment.CenterVertically, modifier = Modifier.padding(vertical = 4.dp)) {
        Text(label, color = Color.Gray, style = MaterialTheme.typography.labelSmall, modifier = Modifier.width(140.dp))
        Canvas(modifier = Modifier.height(8.dp).weight(1f).clip(RoundedCornerShape(4.dp))) {
            drawRect(color = Color.DarkGray); drawRect(color = color, size = size.copy(width = size.width * value))
        }
    }
}

@UnstableApi
fun setupExoPlayer(context: Context, audioEngine: AudioTrendEngine): ExoPlayer {
    val teeProcessor = TeeAudioProcessor(audioEngine)
    val audioSink = DefaultAudioSink.Builder().setAudioProcessors(arrayOf(teeProcessor)).build()
    val renderersFactory = object : DefaultRenderersFactory(context) {
        override fun buildAudioSink(c: Context, f: Boolean, a: Boolean, e: Boolean) = audioSink
    }
    return ExoPlayer.Builder(context, renderersFactory).build().apply { repeatMode = Player.REPEAT_MODE_ONE }
}
