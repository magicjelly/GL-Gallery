// ==========================================
// 1. THE MATH ENGINE (LPF + EMA + GAIN)
// ==========================================
@UnstableApi
class AudioTrendEngine : TeeAudioProcessor.AudioBufferSink {
    var attackAlpha: Float = 0.05f
    var releaseAlpha: Float = 0.005f
    var useRawData: Boolean = false
    var audioGain: Float = 8.0f // Higher gain because LPF reduces signal amplitude

    private val _smoothedEnergy = MutableStateFlow(0f)
    val smoothedEnergy: StateFlow<Float> = _smoothedEnergy

    private val _rawEnergy = MutableStateFlow(0f)
    val rawEnergy: StateFlow<Float> = _rawEnergy

    private var currentTrend = 0f
    
    // Low-Pass Filter State
    private var previousFilteredSample = 0f
    private val lpfAlpha = 0.05f // Cutoff for bass/kick drum isolation

    override fun flush(sampleRateHz: Int, channelCount: Int, encoding: Int) {
        currentTrend = 0f
        previousFilteredSample = 0f
        _smoothedEnergy.value = 0f
        _rawEnergy.value = 0f
    }

    override fun handleBuffer(buffer: ByteBuffer) {
        val limit = buffer.limit()
        if (limit == 0) return

        var sumSquares = 0.0
        var sampleCount = 0

        buffer.position(0)
        while (buffer.position() < limit - 1) {
            val rawSample = buffer.short.toFloat() / Short.MAX_VALUE
            
            // First-Order IIR Low-Pass Filter
            val filteredSample = previousFilteredSample + lpfAlpha * (rawSample - previousFilteredSample)
            previousFilteredSample = filteredSample
            
            sumSquares += (filteredSample * filteredSample)
            sampleCount++
        }

        val rawRms = if (sampleCount > 0) sqrt(sumSquares / sampleCount).toFloat() else 0f
        val boostedRms = (rawRms * audioGain).coerceIn(0f, 1f)
        
        _rawEnergy.value = boostedRms

        if (useRawData) {
            currentTrend = boostedRms
        } else {
            val alpha = if (boostedRms > currentTrend) attackAlpha else releaseAlpha
            currentTrend = (alpha * boostedRms) + ((1f - alpha) * currentTrend)
        }

        _smoothedEnergy.value = currentTrend.coerceIn(0f, 1f)
    }
}

// ==========================================
// 2. THE AGSL SHADER (CONTINUOUS FLOW)
// ==========================================
const val FLUID_SHADER_SRC = """
    uniform float2 u_resolution;
    uniform float u_energy;
    uniform float3 u_artColor;
    uniform float u_flowOffset; 
    
    float random (in float2 _st) {
        return fract(sin(dot(_st.xy, float2(12.9898,78.233))) * 43758.5453123);
    }
    
    float noise (in float2 _st) {
        float2 i = floor(_st);
        float2 f = fract(_st);
        float a = random(i);
        float b = random(i + float2(1.0, 0.0));
        float c = random(i + float2(0.0, 1.0));
        float d = random(i + float2(1.0, 1.0));
        float2 u = f * f * (3.0 - 2.0 * f);
        return mix(a, b, u.x) + (c - a)* u.y * (1.0 - u.x) + (d - b) * u.x * u.y;
    }

    half4 main(float2 fragCoord) {
        float2 uv = fragCoord / u_resolution.xy;
        uv.x *= u_resolution.x / u_resolution.y;
        
        // Use accumulated flowOffset from CPU to ensure perfect continuity
        float2 pos = float2(uv.x * 2.5, uv.y * 2.5 - u_flowOffset);
        
        float n = noise(pos);
        n += noise(pos * 2.0) * 0.5;
        n += noise(pos * 4.0) * 0.25;
        n /= 1.75; 
        
        n = smoothstep(0.35, 0.65, n);
        
        half3 baseColor = half3(u_artColor) * 0.15; 
        half3 energyColor = half3(u_artColor) * (u_energy * 3.5); 
        
        half3 finalColor = mix(baseColor, baseColor + energyColor, n);
        
        float dist = distance(fragCoord / u_resolution.xy, float2(0.5, 0.5));
        finalColor *= smoothstep(1.0, 0.2, dist);

        return half4(finalColor, 1.0);
    }
"""

