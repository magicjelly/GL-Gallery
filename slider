// 3. UI & PROTOTYPE SCREEN
// ==========================================
@OptIn(UnstableApi::class)
@Composable
fun FluidMediaPrototype() {
    val context = LocalContext.current
    val audioEngine = remember { AudioTrendEngine() }
    val exoPlayer = remember { setupExoPlayer(context, audioEngine) }
    
    var currentArtBitmap by remember { mutableStateOf<android.graphics.Bitmap?>(null) }
    var currentFluidColor by remember { mutableStateOf(Color(0xFF607D8B)) }
    var engineTime by remember { mutableFloatStateOf(0f) }
    var isPresentationMode by remember { mutableStateOf(false) }

    var isPlaying by remember { mutableStateOf(false) }
    var playbackPosition by remember { mutableLongStateOf(0L) }
    var playbackDuration by remember { mutableLongStateOf(0L) }

    var smallDensity by remember { mutableFloatStateOf(12f) }
    var largeDensity by remember { mutableFloatStateOf(4.2f) }
    var blurIntensity by remember { mutableFloatStateOf(1.2f) }
    var turbulence by remember { mutableFloatStateOf(0.8f) }
    var activeMomentumMultiplier by remember { mutableFloatStateOf(1f) }

    DisposableEffect(exoPlayer) {
        val listener = object : Player.Listener {
            override fun onIsPlayingChanged(playing: Boolean) { isPlaying = playing }
            override fun onMediaMetadataChanged(mediaMetadata: MediaMetadata) {
                mediaMetadata.artworkData?.let { data ->
                    val bitmap = BitmapFactory.decodeByteArray(data, 0, data.size)
                    currentArtBitmap = bitmap
                    Palette.from(bitmap).generate { p ->
                        val fallback = 0xFF607D8B.toInt()
                        currentFluidColor = Color(p?.getVibrantColor(p.getMutedColor(p.getDominantColor(fallback))) ?: fallback)
                    }
                }
            }
            override fun onPlaybackStateChanged(state: Int) {
                if (state == Player.STATE_READY) playbackDuration = exoPlayer.duration
            }
        }
        exoPlayer.addListener(listener)
        onDispose { exoPlayer.release() }
    }

    LaunchedEffect(isPlaying) {
        while (isPlaying) {
            playbackPosition = exoPlayer.currentPosition
            delay(500)
        }
    }

    val filePicker = rememberLauncherForActivityResult(ActivityResultContracts.GetContent()) { uri ->
        uri?.let { exoPlayer.setMediaItem(MediaItem.fromUri(it)); exoPlayer.prepare(); exoPlayer.play() }
    }

    val peak by audioEngine.realTimePeak.collectAsState()
    val momentum by audioEngine.momentum.collectAsState()
    val bokehShader = remember { RuntimeShader(BOKEH_SHADER_SRC) }

    LaunchedEffect(Unit) {
        while (true) {
            withFrameMillis { 
                val targetMult = if (isPlaying) 1f else 0.1f
                activeMomentumMultiplier = (0.04f * targetMult) + (0.96f * activeMomentumMultiplier)
                val driftSpeed = (0.005f + (momentum * 0.05f)) * activeMomentumMultiplier
                engineTime += driftSpeed
            }
        }
    }

    Column(modifier = Modifier.fillMaxSize().background(Color.Black)) {
        Box(modifier = Modifier.weight(if (isPresentationMode) 1f else 0.58f).fillMaxWidth(), contentAlignment = Alignment.Center) {
            Canvas(modifier = Modifier.fillMaxSize()) {
                bokehShader.setFloatUniform("u_resolution", size.width, size.height)
                bokehShader.setFloatUniform("u_time", engineTime)
                bokehShader.setFloatUniform("u_artColor", currentFluidColor.red, currentFluidColor.green, currentFluidColor.blue)
                bokehShader.setFloatUniform("u_energy", peak * activeMomentumMultiplier)
                bokehShader.setFloatUniform("u_momentum", momentum * activeMomentumMultiplier)
                bokehShader.setFloatUniform("u_smallDensity", smallDensity)
                bokehShader.setFloatUniform("u_largeDensity", largeDensity)
                bokehShader.setFloatUniform("u_blurIntensity", blurIntensity)
                bokehShader.setFloatUniform("u_turbulence", turbulence)
                drawRect(brush = ShaderBrush(bokehShader))
            }
            if (currentArtBitmap != null) {
                Image(bitmap = currentArtBitmap!!.asImageBitmap(), contentDescription = null, 
                    modifier = Modifier.size(if (isPresentationMode) 280.dp else 200.dp).clip(RoundedCornerShape(36.dp)))
            }
        }

        Column(modifier = Modifier.fillMaxWidth().padding(horizontal = 24.dp, vertical = 8.dp), horizontalAlignment = Alignment.CenterHorizontally) {
            Slider(value = playbackPosition.toFloat(), onValueChange = { exoPlayer.seekTo(it.toLong()) },
                valueRange = 0f..(playbackDuration.toFloat().coerceAtLeast(1f)),
                colors = SliderDefaults.colors(thumbColor = currentFluidColor, activeTrackColor = currentFluidColor))
            Row(verticalAlignment = Alignment.CenterVertically, horizontalArrangement = Arrangement.spacedBy(24.dp)) {
                IconButton(onClick = { exoPlayer.seekTo(0); exoPlayer.play() }) { Icon(Icons.Default.Refresh, null, tint = Color.White) }
                FloatingActionButton(onClick = { if (isPlaying) exoPlayer.pause() else exoPlayer.play() }, containerColor = currentFluidColor, shape = CircleShape) {
                    Icon(if (isPlaying) Icons.Default.Close else Icons.Default.PlayArrow, null)
                }
                IconButton(onClick = { filePicker.launch("audio/*") }) { Icon(Icons.Default.Add, null, tint = Color.White) }
            }
        }

        AnimatedVisibility(visible = !isPresentationMode) {
            Column(modifier = Modifier.fillMaxWidth().background(Color(0xFF080808)).padding(20.dp)) {
                ControlSlider("Orb Softness", blurIntensity, 0.5f..2.5f) { blurIntensity = it }
                ControlSlider("Floating Speed", turbulence, 0.2f..2.0f) { turbulence = it }
                ControlSlider("Density", smallDensity, 6f..20f) { smallDensity = it }
            }
        }
        
        Box(modifier = Modifier.fillMaxWidth().padding(8.dp), contentAlignment = Alignment.Center) {
            TextButton(onClick = { isPresentationMode = !isPresentationMode }) {
                Text(if (isPresentationMode) "SHOW TUNER" else "HIDE TUNER", color = Color.Gray)
            }
        }
    }
}

@Composable
fun ControlSlider(label: String, value: Float, range: ClosedFloatingPointRange<Float>, onValueChange: (Float) -> Unit) {
    Row(verticalAlignment = Alignment.CenterVertically, modifier = Modifier.fillMaxWidth().height(36.dp)) {
        Text(label, color = Color.Gray, style = MaterialTheme.typography.labelSmall, modifier = Modifier.width(110.dp))
        Slider(value = value, onValueChange = onValueChange, valueRange = range, modifier = Modifier.weight(1f))
    }
}

@UnstableApi
fun setupExoPlayer(context: Context, audioEngine: AudioTrendEngine): ExoPlayer {
    val teeProcessor = TeeAudioProcessor(audioEngine)
    val audioSink = DefaultAudioSink.Builder().setAudioProcessors(arrayOf(teeProcessor)).build()
    val renderersFactory = object : DefaultRenderersFactory(context) {
        override fun buildAudioSink(c: Context, f: Boolean, a: Boolean, e: Boolean) = audioSink
    }
    return ExoPlayer.Builder(context, renderersFactory).build().apply { repeatMode = Player.REPEAT_MODE_ONE }
}
