// ==========================================
// 1. THE PHYSICS ENGINE: HEAVY MASS DAMPING
// ==========================================
@UnstableApi
class AudioTrendEngine : TeeAudioProcessor.AudioBufferSink {
    var audioGain: Float = 22.0f 
    
    private val _realTimePeak = MutableStateFlow(0f)
    val realTimePeak: StateFlow<Float> = _realTimePeak 
    
    private val _visualSwell = MutableStateFlow(0f)
    val visualSwell: StateFlow<Float> = _visualSwell 

    private var currentEMA = 0f
    private var visualDamping = 0f
    private var prevFiltered = 0f

    override fun flush(sampleRateHz: Int, channelCount: Int, encoding: Int) {
        currentEMA = 0f; visualDamping = 0f; prevFiltered = 0f
        _realTimePeak.value = 0f; _visualSwell.value = 0f
    }

    override fun handleBuffer(buffer: ByteBuffer) {
        val limit = buffer.limit()
        if (limit == 0) return
        var sumSq = 0.0
        buffer.position(0)
        while (buffer.position() < limit - 1) {
            val raw = buffer.short.toFloat() / Short.MAX_VALUE
            // Low pass filter at 0.05 alpha
            val filtered = prevFiltered + 0.05f * (raw - prevFiltered)
            prevFiltered = filtered
            sumSq += (filtered * filtered)
        }
        val rms = (sqrt(sumSq / (limit / 2)).toFloat() * audioGain).coerceIn(0f, 1f)
        
        _realTimePeak.value = rms
        
        // PREMIUM DAMPING: visualSwell has high inertia (98% retention)
        // This ensures orbs "breathe" slowly rather than twitching.
        visualDamping = (0.02f * rms) + (0.98f * visualDamping)
        _visualSwell.value = visualDamping.coerceIn(0f, 1f)
    }
}

// ==========================================
// 2. THE CINEMATIC SHADER: NEIGHBOR SAMPLED BOKEH
// ==========================================
const val BOKEH_SHADER_SRC = """
    uniform float2 u_resolution;
    uniform float u_energy;       // Real-time Peak (Sharp Layer)
    uniform float u_resonance;    // Heavy Swell (Bokeh Layer)
    uniform float3 u_artColor;    
    uniform float u_posOffset;    
    
    float hash21(float2 p) {
        p = fract(p*float2(234.34, 435.12));
        p += dot(p, p+34.23);
        return fract(p.x*p.y);
    }

    // DRAW LOGIC: Uniform Discs with focal softness
    float drawFocalOrb(float2 localUv, float rnd, float sizeM, float blurM) {
        float size = sizeM * (0.7 + rnd * 0.6);
        float d = distance(localUv, float2(0.0));
        // Flat intensity center with soft lens perimeter
        return smoothstep(size, size - blurM, d);
    }

    // GRID LOGIC: 3x3 Neighbor sampling removes grid-line artifacts
    float getLayer(float2 uv, float gridSize, float offset, float sizeM, float blurM, float driftSpeed) {
        float2 st = uv * gridSize;
        st.y += offset * driftSpeed; // Global cinematic drift
        
        float2 i_st = floor(st);
        float2 f_st = fract(st) - 0.5;
        float layer = 0.0;
        
        for(float y=-1.0; y<=1.0; y++) {
            for(float x=-1.0; x<=1.0; x++) {
                float2 neighbor = float2(x, y);
                float2 id = i_st + neighbor;
                float rnd = hash21(id);
                
                // Position jitter + subtle local oscillation
                float2 p = neighbor + float2(sin(offset * 0.4 + rnd * 6.28), cos(offset * 0.4 + rnd * 6.28)) * 0.25;
                
                layer += drawFocalOrb(f_st - p, rnd, sizeM, blurM);
            }
        }
        return layer;
    }

    half4 main(float2 fragCoord) {
        float2 uv = fragCoord / u_resolution;
        uv.x *= u_resolution.x / u_resolution.y;
        
        half3 finalColor = half3(0.0);
        
        // --- LAYER 1: THE ATMOSPHERE (Deep Focal Plane) ---
        // Large, 100% Blur, slow global drift
        float l1 = getLayer(uv, 3.2, u_posOffset, 0.28 + u_resonance * 0.35, 0.55, 0.12);
        finalColor += half3(u_artColor) * half(l1 * 0.35);

        // --- LAYER 2: THE ENERGY (The Sharpness Anchor) ---
        // Smaller, Sharp edges (0.02 blur), faster global drift
        // This anchors the viewer's eye and provides the "High-Def" feel.
        float l2 = getLayer(uv, 9.0, u_posOffset, 0.05 + u_energy * 0.08, 0.02, 0.45);
        finalColor += half3(u_artColor) * half(l2 * (0.35 + u_energy * 1.2));
        
        // Atmospheric Lift & Lens Vignette
        float centerDist = distance(fragCoord / u_resolution.xy, float2(0.5, 0.5));
        finalColor += half3(u_artColor) * 0.08; 
        finalColor *= smoothstep(1.5, 0.4, centerDist);

        return half4(finalColor, 1.0);
    }
"""

