@Composable
fun TelemetryMeter(rawEnergy: Float, smoothedEnergy: Float, showLightning: Boolean) {
    Column(modifier = Modifier.fillMaxWidth().padding(vertical = 8.dp)) {
        Text("LIVE DSP TELEMETRY", color = Color.Cyan, style = MaterialTheme.typography.labelMedium)
        Spacer(modifier = Modifier.height(8.dp))
        
        AnimatedVisibility(visible = showLightning) {
            Column {
                Row(verticalAlignment = Alignment.CenterVertically) {
                    Text("Raw Input (Spikes):   ", color = Color.Gray, modifier = Modifier.width(140.dp))
                    Canvas(modifier = Modifier.height(12.dp).weight(1f).clip(RoundedCornerShape(6.dp))) {
                        drawRect(color = Color.DarkGray)
                        drawRect(
                            color = Color(0xFFFF5722),
                            size = size.copy(width = size.width * rawEnergy)
                        )
                    }
                }
                Spacer(modifier = Modifier.height(8.dp))
            }
        }

        Row(verticalAlignment = Alignment.CenterVertically) {
            Text("Shader Input (Trend): ", color = Color.White, modifier = Modifier.width(140.dp))
            Canvas(modifier = Modifier.height(12.dp).weight(1f).clip(RoundedCornerShape(6.dp))) {
                drawRect(color = Color.DarkGray)
                drawRect(
                    color = Color(0xFF00E5FF),
                    size = size.copy(width = size.width * smoothedEnergy)
                )
            }
        }
    }
}

// ==========================================
// 4. MAIN PROTOTYPE COMPOSE SCREEN
// ==========================================
@Composable
fun FluidMediaPrototype() {
    val context = LocalContext.current
    
    val audioEngine = remember { AudioTrendEngine() }
    val exoPlayer = remember { setupExoPlayer(context, audioEngine) }

    DisposableEffect(Unit) {
        onDispose {
            exoPlayer.release()
        }
    }

    // --- NEW: File Picker State and Launcher ---
    var selectedAudioUri by remember { mutableStateOf<Uri?>(null) }
    val filePickerLauncher = rememberLauncherForActivityResult(
        contract = ActivityResultContracts.GetContent()
    ) { uri: Uri? ->
        selectedAudioUri = uri
    }

    // --- NEW: Pass the selected URI to ExoPlayer when it changes ---
    LaunchedEffect(selectedAudioUri) {
        selectedAudioUri?.let { uri ->
            exoPlayer.setMediaItem(MediaItem.fromUri(uri))
            exoPlayer.prepare()
            exoPlayer.playWhenReady = true
        }
    }

    val audioEnergy by audioEngine.smoothedEnergy.collectAsState()
    val rawEnergy by audioEngine.rawEnergy.collectAsState()
    
    var isPresentationMode by remember { mutableStateOf(false) }
    var attackState by remember { mutableStateOf(audioEngine.attackAlpha) }
    var releaseState by remember { mutableStateOf(audioEngine.releaseAlpha) }
    var useRawData by remember { mutableStateOf(audioEngine.useRawData) }
    var showLightningTelemetry by remember { mutableStateOf(false) }

    val fluidShader = remember { RuntimeShader(FLUID_SHADER_SRC) }
    var timeMillis by remember { mutableStateOf(0f) }

    LaunchedEffect(Unit) {
        while (true) {
            withFrameMillis { frameTime ->
                timeMillis = frameTime / 1000f
            }
        }
    }

    Column(modifier = Modifier.fillMaxSize().background(Color.Black)) {
        
        // --- TOP: The Visual Output ---
        Box(
            modifier = Modifier
                .weight(if (isPresentationMode) 1f else 0.5f)
                .fillMaxWidth(),
            contentAlignment = Alignment.Center
        ) {
            Canvas(modifier = Modifier.fillMaxSize()) {
                fluidShader.setFloatUniform("u_resolution", size.width, size.height)
                fluidShader.setFloatUniform("u_time", timeMillis)
                val targetEnergy = if (exoPlayer.isPlaying) audioEnergy else 0.02f
                fluidShader.setFloatUniform("u_energy", targetEnergy)

                drawRect(brush = ShaderBrush(fluidShader))
            }
            
            Box(
                modifier = Modifier
                    .size(if (isPresentationMode) 280.dp else 180.dp)
                    .clip(RoundedCornerShape(16.dp))
                    .background(Color.DarkGray.copy(alpha = 0.8f))
            )
        }

        // --- BOTTOM: The Control Room ---
        AnimatedVisibility(visible = !isPresentationMode) {
            Column(
                modifier = Modifier
                    .fillMaxWidth()
                    .background(Color(0xFF121212))
                    .padding(24.dp)
            ) {
                // --- NEW: Audio Selection UI ---
                Row(
                    modifier = Modifier.fillMaxWidth(), 
                    horizontalArrangement = Arrangement.SpaceBetween,
                    verticalAlignment = Alignment.CenterVertically
                ) {
                    Text("Control Room", color = Color.White, style = MaterialTheme.typography.titleMedium)
                    Button(
                        onClick = { filePickerLauncher.launch("audio/*") },
                        colors = ButtonDefaults.buttonColors(containerColor = Color(0xFF4CAF50))
                    ) {
                        Text("Select Audio File")
                    }
                }
                Spacer(modifier = Modifier.height(16.dp))

                TelemetryMeter(
                    rawEnergy = rawEnergy, 
                    smoothedEnergy = audioEnergy, 
                    showLightning = showLightningTelemetry
                )
                
                Spacer(modifier = Modifier.height(16.dp))

                Row(verticalAlignment = Alignment.CenterVertically) {
                    Switch(
                        checked = showLightningTelemetry,
                        onCheckedChange = { showLightningTelemetry = it }
                    )
                    Spacer(modifier = Modifier.width(8.dp))
                    Text("Show Raw Audio Telemetry (Lightning)", color = Color.LightGray)
                }

                Spacer(modifier = Modifier.height(8.dp))

                Row(verticalAlignment = Alignment.CenterVertically) {
                    Switch(
                        checked = useRawData,
                        onCheckedChange = { 
                            useRawData = it; audioEngine.useRawData = it 
                        }
                    )
                    Spacer(modifier = Modifier.width(8.dp))
                    Text("Bypass Smoothing (Feed spikes to shader)", color = Color.LightGray)
                }

                Spacer(modifier = Modifier.height(16.dp))
                
                Text("Attack (Swell): ${String.format("%.3f", attackState)}", color = Color.Gray)
                Slider(
                    value = attackState,
                    onValueChange = { attackState = it; audioEngine.attackAlpha = it },
                    valueRange = 0.001f..0.5f
                )

                Text("Release (Fade): ${String.format("%.3f", releaseState)}", color = Color.Gray)
                Slider(
                    value = releaseState,
                    onValueChange = { releaseState = it; audioEngine.releaseAlpha = it },
                    valueRange = 0.001f..0.1f
                )
            }
        }

        // Presentation Toggle Footer
        Box(
            modifier = Modifier
                .fillMaxWidth()
                .background(Color.Black)
                .padding(16.dp),
            contentAlignment = Alignment.Center
        ) {
            Button(
                onClick = { isPresentationMode = !isPresentationMode },
                colors = ButtonDefaults.buttonColors(containerColor = Color.DarkGray)
            ) {
                Text(if (isPresentationMode) "Open Control Room" else "Enter Presentation Mode")
            }
        }
    }
}

// ==========================================
// 5. EXOPLAYER FACTORY SETUP (UPDATED)
// ==========================================
fun setupExoPlayer(context: Context, audioEngine: AudioTrendEngine): ExoPlayer {
    val teeProcessor = TeeAudioProcessor(audioEngine)

    val audioSink = DefaultAudioSink.Builder()
        .setAudioProcessors(arrayOf(teeProcessor))
        .build()

    val renderersFactory = object : DefaultRenderersFactory(context) {
        override fun buildAudioSink(
            context: Context,
            enableFloatOutput: Boolean,
            enableAudioTrackPlaybackParams: Boolean,
            enableOffload: Boolean
        ): androidx.media3.exoplayer.audio.AudioSink {
            return audioSink
        }
    }

    // We no longer load a hardcoded file here. The player starts empty 
    // and waits for the user to pick a file from the UI.
    return ExoPlayer.Builder(context, renderersFactory).build().apply {
        repeatMode = ExoPlayer.REPEAT_MODE_ONE
    }
}
