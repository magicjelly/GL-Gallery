// ==========================================
// 1. AUDIO ENGINE: LPF + EMA + REAL-TIME DATA
// ==========================================
@UnstableApi
class AudioTrendEngine : TeeAudioProcessor.AudioBufferSink {
    var attackAlpha: Float = 0.05f
    var releaseAlpha: Float = 0.005f
    var audioGain: Float = 12.0f 
    var isLpfEnabled: Boolean = true
    var isSmoothingEnabled: Boolean = true

    private val _rawInput = MutableStateFlow(0f)
    val rawInput: StateFlow<Float> = _rawInput 

    private val _realTimePeak = MutableStateFlow(0f)
    val realTimePeak: StateFlow<Float> = _realTimePeak // Reactive Energy

    private val _smoothedResonance = MutableStateFlow(0f)
    val smoothedResonance: StateFlow<Float> = _smoothedResonance // Deep Atmosphere

    private var currentEMAValue = 0f
    private var previousFilteredSample = 0f
    private val lpfAlpha = 0.05f 

    override fun flush(sampleRateHz: Int, channelCount: Int, encoding: Int) {
        currentEMAValue = 0f
        previousFilteredSample = 0f
        _rawInput.value = 0f
        _realTimePeak.value = 0f
        _smoothedResonance.value = 0f
    }

    override fun handleBuffer(buffer: ByteBuffer) {
        val limit = buffer.limit()
        if (limit == 0) return
        var sumSquaresRaw = 0.0
        var sumSquaresFiltered = 0.0
        var sampleCount = 0
        
        buffer.position(0)
        while (buffer.position() < limit - 1) {
            val rawSample = buffer.short.toFloat() / Short.MAX_VALUE
            sumSquaresRaw += (rawSample * rawSample)
            
            val filteredSample = if (isLpfEnabled) {
                previousFilteredSample + lpfAlpha * (rawSample - previousFilteredSample)
            } else {
                rawSample
            }
            previousFilteredSample = filteredSample
            sumSquaresFiltered += (filteredSample * filteredSample)
            sampleCount++
        }

        val rawRms = if (sampleCount > 0) sqrt(sumSquaresRaw / sampleCount).toFloat() else 0f
        val filteredRms = if (sampleCount > 0) sqrt(sumSquaresFiltered / sampleCount).toFloat() else 0f
        val boostedRms = (filteredRms * audioGain).coerceIn(0f, 1f)

        _rawInput.value = rawRms.coerceIn(0f, 1f)
        _realTimePeak.value = boostedRms

        if (isSmoothingEnabled) {
            val alpha = if (boostedRms > currentEMAValue) attackAlpha else releaseAlpha
            currentEMAValue = (alpha * boostedRms) + ((1f - alpha) * currentEMAValue)
        } else {
            currentEMAValue = boostedRms
        }
        
        _smoothedResonance.value = currentEMAValue.coerceIn(0f, 1f)
    }
}

// ==========================================
// 2. THE CINEMATIC BOKEH SHADER (AGSL)
// ==========================================
const val BOKEH_SHADER_SRC = """
    uniform float2 u_resolution;
    uniform float u_energy;       // Real-time Peak
    uniform float u_resonance;    // Smoothed Swell
    uniform float3 u_artColor;    // Theme Primary
    uniform float u_posOffset;    // Physics Momentum
    
    float hash21(float2 p) {
        p = fract(p*float2(234.34, 435.12));
        p += dot(p, p+34.23);
        return fract(p.x*p.y);
    }

    // Advanced Layering: Creates the dense, overlapping orb feel from the reference image
    float drawLayer(float2 uv, float gridSize, float offset, float blur, float sizeBase, float brightness) {
        float2 st = uv * gridSize;
        float2 gridId = floor(st);
        float2 localUv = fract(st) - 0.5;
        
        float rnd = hash21(gridId);
        // Randomize initial position within cell for "natural clusters"
        float2 jitter = float2(hash21(gridId + 0.1), hash21(gridId + 0.2)) * 0.4 - 0.2;
        
        float t = offset + rnd * 12.56;
        float2 p = jitter + float2(sin(t * 0.8), cos(t * 0.5)) * 0.25;
        
        float d = distance(localUv, p);
        
        // Premium Falloff: Bright core with very soft edges
        float orb = smoothstep(sizeBase, sizeBase - blur, d);
        // Subtle shimmer based on time and individual randomness
        float shimmer = 0.5 + 0.5 * sin(offset * 1.5 + rnd * 20.0);
        
        return orb * shimmer * brightness;
    }

    half4 main(float2 fragCoord) {
        float2 uv = fragCoord / u_resolution;
        uv.x *= u_resolution.x / u_resolution.y;
        
        half3 finalColor = half3(0.0);
        
        // LAYER 1: Deep Background Bokeh (Huge, Soft, High Density)
        // Parallax speed: 20%
        float bokehSize = 0.2 + u_resonance * 0.5;
        float b1 = drawLayer(uv, 4.0, u_posOffset * 0.2, 0.8, bokehSize, 0.4);
        float b2 = drawLayer(uv + 0.5, 3.5, u_posOffset * 0.15, 0.9, bokehSize * 0.8, 0.3);
        finalColor += half3(u_artColor) * half(b1 + b2);

        // LAYER 2: Mid-ground "Identity" Orbs
        // Parallax speed: 50%
        float midSize = 0.1 + u_resonance * 0.2;
        float m1 = drawLayer(uv, 7.0, u_posOffset * 0.5, 0.4, midSize, 0.5);
        finalColor += half3(u_artColor) * half(m1);

        // LAYER 3: Foreground "Energy Dust" (Sharp, Fast, Reactive)
        // Parallax speed: 120%
        float dustSize = 0.02 + u_energy * 0.08;
        float d1 = drawLayer(uv, 16.0, u_posOffset * 1.2, 0.05, dustSize, 1.0);
        finalColor += half3(u_artColor) * half(d1 * (0.3 + u_energy * 1.5));
        
        // Final Color Correction
        float centerDist = distance(fragCoord / u_resolution.xy, float2(0.5, 0.5));
        half3 baseGlow = half3(u_artColor) * 0.12; // Atmospheric lift
        finalColor += baseGlow;
        finalColor *= smoothstep(1.2, 0.3, centerDist); // Vignette

        return half4(finalColor, 1.0);
    }
"""

