@Composable
fun DataBar(label: String, value: Float, color: Color) {
    Row(verticalAlignment = Alignment.CenterVertically, modifier = Modifier.padding(vertical = 2.dp)) {
        Text(label, color = Color.Gray, style = MaterialTheme.typography.labelSmall, modifier = Modifier.width(150.dp))
        Canvas(modifier = Modifier.height(6.dp).weight(1f).clip(RoundedCornerShape(3.dp))) {
            drawRect(color = Color.DarkGray)
            drawRect(color = color, size = size.copy(width = size.width * value))
        }
    }
}

// ==========================================
// 4. MAIN COMPOSE PROTOTYPE
// ==========================================
@OptIn(UnstableApi::class)
@Composable
fun FluidMediaPrototype() {
    val context = LocalContext.current
    val audioEngine = remember { AudioTrendEngine() }
    val exoPlayer = remember { setupExoPlayer(context, audioEngine) }
    
    var currentArtBitmap by remember { mutableStateOf<android.graphics.Bitmap?>(null) }
    var currentFluidColor by remember { mutableStateOf(Color(0xFFE91E63)) } // Default Vibrant
    var accumulatedFlowOffset by remember { mutableFloatStateOf(0f) }
    var isPresentationMode by remember { mutableStateOf(false) }

    // Control Room States
    var showTelemetry by remember { mutableStateOf(true) }
    var gainState by remember { mutableFloatStateOf(audioEngine.audioGain) }
    var attackState by remember { mutableFloatStateOf(audioEngine.attackAlpha) }
    var releaseState by remember { mutableFloatStateOf(audioEngine.releaseAlpha) }

    DisposableEffect(exoPlayer) {
        val listener = object : Player.Listener {
            override fun onMediaMetadataChanged(mediaMetadata: MediaMetadata) {
                mediaMetadata.artworkData?.let {
                    val bitmap = BitmapFactory.decodeByteArray(it, 0, it.size)
                    currentArtBitmap = bitmap
                    Palette.from(bitmap).generate { p ->
                        currentFluidColor = Color(p?.getVibrantColor(0xFFE91E63) ?: 0xFFE91E63)
                    }
                }
            }
        }
        exoPlayer.addListener(listener)
        onDispose { exoPlayer.release() }
    }

    val filePicker = rememberLauncherForActivityResult(ActivityResultContracts.GetContent()) { uri ->
        uri?.let { exoPlayer.setMediaItem(MediaItem.fromUri(it)); exoPlayer.prepare(); exoPlayer.playWhenReady = true }
    }

    val rawInput by audioEngine.rawInput.collectAsState()
    val realTimePeak by audioEngine.realTimePeak.collectAsState()
    val smoothedResonance by audioEngine.smoothedResonance.collectAsState()
    val bokehShader = remember { RuntimeShader(BOKEH_SHADER_SRC) }

    LaunchedEffect(Unit) {
        while (true) {
            withFrameMillis { 
                val target = if (exoPlayer.isPlaying) realTimePeak else 0f
                accumulatedFlowOffset += 0.003f + (target * 0.02f)
            }
        }
    }

    Column(modifier = Modifier.fillMaxSize().background(Color.Black)) {
        // RENDER AREA
        Box(modifier = Modifier.weight(if (isPresentationMode) 1f else 0.55f).fillMaxWidth(), contentAlignment = Alignment.Center) {
            Canvas(modifier = Modifier.fillMaxSize()) {
                bokehShader.setFloatUniform("u_resolution", size.width, size.height)
                bokehShader.setFloatUniform("u_posOffset", accumulatedFlowOffset)
                bokehShader.setFloatUniform("u_artColor", currentFluidColor.red, currentFluidColor.green, currentFluidColor.blue)
                bokehShader.setFloatUniform("u_energy", if (exoPlayer.isPlaying) realTimePeak else 0.02f)
                bokehShader.setFloatUniform("u_resonance", if (exoPlayer.isPlaying) smoothedResonance else 0.02f)
                drawRect(brush = ShaderBrush(bokehShader))
            }
            if (currentArtBitmap != null) {
                Image(bitmap = currentArtBitmap!!.asImageBitmap(), contentDescription = null, 
                    modifier = Modifier.size(if (isPresentationMode) 260.dp else 180.dp).clip(RoundedCornerShape(24.dp)))
            }
        }

        // CONTROL ROOM
        AnimatedVisibility(visible = !isPresentationMode) {
            Column(modifier = Modifier.fillMaxWidth().background(Color(0xFF0A0A0A)).padding(20.dp)) {
                Row(modifier = Modifier.fillMaxWidth(), horizontalArrangement = Arrangement.SpaceBetween, verticalAlignment = Alignment.CenterVertically) {
                    Text("CONTROL ROOM", color = Color.White, style = MaterialTheme.typography.titleSmall)
                    Button(onClick = { filePicker.launch("audio/*") }, colors = ButtonDefaults.buttonColors(containerColor = Color(0xFF2E7D32))) {
                        Text("OPEN TRACK", style = MaterialTheme.typography.labelSmall)
                    }
                }
                
                Spacer(modifier = Modifier.height(16.dp))
                
                if (showTelemetry) {
                    DataBar("RAW INPUT", rawInput, Color.DarkGray)
                    DataBar("REAL-TIME PEAK (BEAT)", realTimePeak, Color(0xFFFF5722))
                    DataBar("RESONANCE (SWELL)", smoothedResonance, Color(0xFF00E5FF))
                }
                
                Spacer(modifier = Modifier.height(16.dp))

                Row(verticalAlignment = Alignment.CenterVertically) {
                    Switch(showTelemetry, { showTelemetry = it }, modifier = Modifier.scale(0.7f))
                    Text("Show Live Telemetry", color = Color.LightGray, style = MaterialTheme.typography.bodySmall, modifier = Modifier.padding(start = 8.dp))
                }

                Text("Bass Gain: ${String.format("%.1fx", gainState)}", color = Color.Gray, style = MaterialTheme.typography.labelSmall, modifier = Modifier.padding(top = 8.dp))
                Slider(gainState, { gainState = it; audioEngine.audioGain = it }, valueRange = 1f..30f)

                Row(modifier = Modifier.fillMaxWidth()) {
                    Column(modifier = Modifier.weight(1f)) {
                        Text("Attack: ${String.format("%.2f", attackState)}", color = Color.Gray, style = MaterialTheme.typography.labelSmall)
                        Slider(attackState, { attackState = it; audioEngine.attackAlpha = it }, valueRange = 0.01f..0.5f)
                    }
                    Spacer(modifier = Modifier.width(16.dp))
                    Column(modifier = Modifier.weight(1f)) {
                        Text("Release: ${String.format("%.3f", releaseState)}", color = Color.Gray, style = MaterialTheme.typography.labelSmall)
                        Slider(releaseState, { releaseState = it; audioEngine.releaseAlpha = it }, valueRange = 0.001f..0.1f)
                    }
                }
            }
        }

        // BOTTOM TOGGLE
        Box(modifier = Modifier.fillMaxWidth().padding(16.dp), contentAlignment = Alignment.Center) {
            Button(onClick = { isPresentationMode = !isPresentationMode }, 
                colors = ButtonDefaults.buttonColors(containerColor = if (isPresentationMode) Color.DarkGray else currentFluidColor.copy(alpha = 0.4f))) {
                Text(if (isPresentationMode) "EXIT PRESENTATION" else "ENTER PRESENTATION MODE")
            }
        }
    }
}

@UnstableApi
fun setupExoPlayer(context: Context, audioEngine: AudioTrendEngine): ExoPlayer {
    val teeProcessor = TeeAudioProcessor(audioEngine)
    val audioSink = DefaultAudioSink.Builder().setAudioProcessors(arrayOf(teeProcessor)).build()
    val renderersFactory = object : DefaultRenderersFactory(context) {
        override fun buildAudioSink(c: Context, f: Boolean, a: Boolean, e: Boolean) = audioSink
    }
    return ExoPlayer.Builder(context, renderersFactory).build().apply { repeatMode = Player.REPEAT_MODE_ONE }
}