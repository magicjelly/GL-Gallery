const val AMBIENT_EDGE_SHADER = """
    uniform float2 in_Resolution;
    uniform float in_Time;
    uniform float in_CornerRadius; 
    uniform half3 in_AppColor; 

    float sdRoundRect(vec2 p, vec2 b, float r) {
        vec2 d = abs(p) - b + vec2(r);
        return min(max(d.x, d.y), 0.0) + length(max(d, 0.0)) - r;
    }

    half4 main(in float2 fragCoord) {
        vec2 p = fragCoord - (in_Resolution.xy * 0.5);
        vec2 b = in_Resolution.xy * 0.5;
        
        float d = sdRoundRect(p, b, in_CornerRadius);
        
        // Shift the light slightly inward (Bezel Bleed technique) so it sits 
        // thicker on the actual display pixels rather than hiding under the hardware bezel.
        float distFromEdge = -(d + 2.0); 
        
        vec2 uv = fragCoord / in_Resolution.xy;
        
        // 1. The Neon Tube: Three distinct exponential falloffs
        float core = exp(-max(distFromEdge, 0.0) * 0.8);       // Razor sharp, hot center
        float midGlow = exp(-max(distFromEdge, 0.0) * 0.15);   // Rich, vibrant color band
        float outerGlow = exp(-max(distFromEdge, 0.0) * 0.04); // Wide, luxurious soft tail
        
        float topBias = mix(0.15, 1.0, uv.y); 
        float breathAlpha = (sin(in_Time * 4.0) + 1.0) * 0.5; // Slightly sped up the breath
        
        // 2. Chromatic Layering
        // Create an artificially deeper root color to fight the white background washout
        vec3 deepRootColor = vec3(in_AppColor) * 0.4; 
        
        // Blend 1: Soft tail to Rich Mid-band
        vec3 colorStage1 = mix(deepRootColor, vec3(in_AppColor), midGlow);
        
        // Blend 2: Rich Mid-band to Hot White Core
        // We use pow(core, 1.5) to keep the white strictly in the absolute center
        vec3 pureColor = mix(colorStage1, vec3(1.0), pow(core, 1.5));
        
        // Combine the alpha presence
        float lightPresence = max(outerGlow, core);
        float pixelAlpha = lightPresence * breathAlpha * topBias;
        
        // Boost max opacity slightly for light backgrounds
        pixelAlpha *= 0.85; 
        
        float screenMask = step(0.0, distFromEdge);
        
        return half4(pureColor * pixelAlpha * screenMask, pixelAlpha * screenMask);
    }
"""


// 2. Main Activity
class MainActivity : ComponentActivity() {
    override fun onCreate(savedInstanceState: Bundle?) {
        super.onCreate(savedInstanceState)
        setContent {
            MaterialTheme {
                Surface(
                    modifier = Modifier.fillMaxSize(),
                    color = MaterialTheme.colorScheme.background
                ) {
                    if (Build.VERSION.SDK_INT >= Build.VERSION_CODES.TIRAMISU) {
                        NotificationSyncPrototype()
                    } else {
                        Box(modifier = Modifier.fillMaxSize(), contentAlignment = Alignment.Center) {
                            Text("AGSL requires Android 13+")
                        }
                    }
                }
            }
        }
    }
}

// 3. The Interactive UI Prototype Screen
@RequiresApi(Build.VERSION_CODES.TIRAMISU)
@Composable
fun NotificationSyncPrototype() {
    var hardwareCornerRadius by remember { mutableFloatStateOf(120f) }
    
    // Animation Trigger State
    var isNotificationActive by remember { mutableStateOf(false) }
    
    val appColors = listOf(
        Color(0xFF1999FF), Color(0xFF25D366), Color(0xFFEA4335), 
        Color(0xFFFFFC00), Color(0xFFE1306C)
    )
    var selectedAppColor by remember { mutableStateOf(appColors[0]) }

    // --- Animation Physics ---
    // Spring physics for the pill drop-down
    val pillOffsetY by animateDpAsState(
        targetValue = if (isNotificationActive) 32.dp else (-100).dp,
        animationSpec = spring(dampingRatio = 0.7f, stiffness = 400f),
        label = "pill_drop"
    )
    
    // Smooth fade for the edge lighting and pill opacity
    val masterAlpha by animateFloatAsState(
        targetValue = if (isNotificationActive) 1f else 0f,
        animationSpec = tween(durationMillis = 300, easing = LinearOutSlowInEasing),
        label = "master_alpha"
    )

    // Root Container with Tap Gestures
    Box(
        modifier = Modifier
            .fillMaxSize()
            .pointerInput(Unit) {
                detectTapGestures(
                    onTap = { isNotificationActive = true },
                    onDoubleTap = { isNotificationActive = false }
                )
            }
    ) {
        
        // Background App Context
        LazyColumn(
            modifier = Modifier.fillMaxSize(),
            contentPadding = PaddingValues(horizontal = 16.dp, vertical = 64.dp),
            verticalArrangement = Arrangement.spacedBy(12.dp)
        ) {
            items(20) { index ->
                Card(
                    modifier = Modifier.fillMaxWidth().height(80.dp),
                    colors = CardDefaults.cardColors(containerColor = MaterialTheme.colorScheme.surfaceVariant)
                ) {
                    Box(modifier = Modifier.fillMaxSize(), contentAlignment = Alignment.CenterStart) {
                        Text("Active App Content #$index", modifier = Modifier.padding(16.dp))
                    }
                }
            }
        }

        // The Edge Lighting Layer (Synced to tap state)
        AmbientEdgeLighting(
            modifier = Modifier
                .fillMaxSize()
                .graphicsLayer { alpha = masterAlpha },
            cornerRadius = hardwareCornerRadius,
            appColor = selectedAppColor
        )

        // The Brief Notification Pill
        Card(
            modifier = Modifier
                .align(Alignment.TopCenter)
                .offset(y = pillOffsetY)
                .alpha(masterAlpha)
                .fillMaxWidth(0.9f)
                .height(64.dp),
            shape = RoundedCornerShape(32.dp),
            colors = CardDefaults.cardColors(
                containerColor = MaterialTheme.colorScheme.surface.copy(alpha = 0.95f)
            ),
            elevation = CardDefaults.cardElevation(defaultElevation = 8.dp)
        ) {
            Row(
                modifier = Modifier.fillMaxSize().padding(horizontal = 12.dp),
                verticalAlignment = Alignment.CenterVertically
            ) {
                // Dynamic App Icon Circular Container
                Box(
                    modifier = Modifier
                        .size(40.dp)
                        .background(selectedAppColor, CircleShape),
                    contentAlignment = Alignment.Center
                ) {
                    // Placeholder for a real icon vector
                    Box(
                        modifier = Modifier
                            .size(20.dp)
                            .background(Color.White, RoundedCornerShape(4.dp))
                    )
                }
                
                Spacer(modifier = Modifier.width(16.dp))
                
                // Dummy Text Lines
                Column(verticalArrangement = Arrangement.Center) {
                    Box(modifier = Modifier.width(120.dp).height(12.dp).background(MaterialTheme.colorScheme.onSurface.copy(alpha = 0.8f), RoundedCornerShape(4.dp)))
                    Spacer(modifier = Modifier.height(6.dp))
                    Box(modifier = Modifier.width(80.dp).height(10.dp).background(MaterialTheme.colorScheme.onSurface.copy(alpha = 0.4f), RoundedCornerShape(4.dp)))
                }
            }
        }

        // Prototype Controls
        Column(
            modifier = Modifier
                .align(Alignment.BottomCenter)
                .padding(bottom = 48.dp)
                .fillMaxWidth(0.9f),
            horizontalAlignment = Alignment.CenterHorizontally,
            verticalArrangement = Arrangement.spacedBy(16.dp)
        ) {
            Card(colors = CardDefaults.cardColors(containerColor = MaterialTheme.colorScheme.surface.copy(alpha = 0.9f))) {
                Row(modifier = Modifier.fillMaxWidth().padding(16.dp), horizontalArrangement = Arrangement.SpaceEvenly) {
                    appColors.forEach { color ->
                        val interactionSource = remember(color) { MutableInteractionSource() }
                        Box(
                            modifier = Modifier
                                .size(40.dp)
                                .background(color, CircleShape)
                                .border(
                                    width = if (selectedAppColor == color) 3.dp else 0.dp,
                                    color = MaterialTheme.colorScheme.onSurface,
                                    shape = CircleShape
                                )
                                .clickable(interactionSource = interactionSource, indication = null) { 
                                    selectedAppColor = color 
                                    isNotificationActive = true // Auto-trigger to show color change
                                }
                        )
                    }
                }
            }

            Card(colors = CardDefaults.cardColors(containerColor = MaterialTheme.colorScheme.surface.copy(alpha = 0.9f))) {
                Column(modifier = Modifier.padding(16.dp)) {
                    Text("Corner Radius Match: ${hardwareCornerRadius.toInt()}px", style = MaterialTheme.typography.labelLarge)
                    Slider(
                        value = hardwareCornerRadius,
                        onValueChange = { hardwareCornerRadius = it },
                        valueRange = 0f..300f
                    )
                }
            }
        }
    }
}

// 4. The AGSL Render Component
@RequiresApi(Build.VERSION_CODES.TIRAMISU)
@Composable
fun AmbientEdgeLighting(
    modifier: Modifier = Modifier,
    cornerRadius: Float = 120f,
    appColor: Color 
) {
    var time by remember { mutableFloatStateOf(0f) }
    
    LaunchedEffect(Unit) {
        val startTime = System.nanoTime()
        while (true) {
            awaitFrame()
            time = (System.nanoTime() - startTime) / 1_000_000_000f
        }
    }

    val shader = remember { RuntimeShader(AMBIENT_EDGE_SHADER) }
    val shaderBrush = remember(shader) { ShaderBrush(shader) }

    Box(
        modifier = modifier
            .fillMaxSize()
            .drawWithCache {
                shader.setFloatUniform("in_Resolution", size.width, size.height)
                shader.setFloatUniform("in_Time", time)
                shader.setFloatUniform("in_CornerRadius", cornerRadius)
                shader.setFloatUniform("in_AppColor", appColor.red, appColor.green, appColor.blue)
                
                onDrawBehind {
                    drawRect(brush = shaderBrush)
                }
            }
    )
}
