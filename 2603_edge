// 1. The Tunable Lava Shader
const val AMBIENT_EDGE_SHADER = """
    uniform float2 in_Resolution;
    uniform float in_Time;
    uniform float in_CornerRadius; 
    uniform half3 in_AppColor; 
    
    // New Tunable Uniforms
    uniform float in_Speed;
    uniform float in_Spread; // Controls thickness
    uniform float in_Amplitude; // Controls how deep the lava pushes inward
    uniform float in_NoiseScale; // Controls the size of the lava waves

    float hash(vec2 p) {
        return fract(sin(dot(p, vec2(12.9898, 78.233))) * 43758.5453);
    }

    float noise(vec2 p) {
        vec2 i = floor(p);
        vec2 f = fract(p);
        f = f * f * (3.0 - 2.0 * f);
        float a = hash(i);
        float b = hash(i + vec2(1.0, 0.0));
        float c = hash(i + vec2(0.0, 1.0));
        float d = hash(i + vec2(1.0, 1.0));
        return mix(mix(a, b, f.x), mix(c, d, f.x), f.y);
    }

    float fBm(vec2 p) {
        float f = 0.0;
        f += 0.5000 * noise(p); p = p * 2.02;
        f += 0.2500 * noise(p); p = p * 2.03;
        f += 0.1250 * noise(p); p = p * 2.01;
        return f / 0.875;
    }

    float sdRoundRect(vec2 p, vec2 b, float r) {
        vec2 d = abs(p) - b + vec2(r);
        return min(max(d.x, d.y), 0.0) + length(max(d, 0.0)) - r;
    }

    half4 main(in float2 fragCoord) {
        vec2 p = fragCoord - (in_Resolution.xy * 0.5);
        vec2 b = in_Resolution.xy * 0.5;
        
        float distFromEdge = -sdRoundRect(p, b, in_CornerRadius); 
        float clampedDist = max(distFromEdge, 0.0);
        
        vec2 uv = fragCoord / in_Resolution.xy;
        
        // GLOBAL NOISE MAPPING (Tuned by UI)
        vec2 noiseUV = uv * vec2(in_NoiseScale, in_NoiseScale * 2.0); 
        
        float time = in_Time * in_Speed; 
        float flow1 = fBm(noiseUV + vec2(time * 0.5, -time * 0.8));
        float flow2 = fBm(noiseUV * 1.5 - vec2(-time * 0.3, time * 1.1));
        
        float complexNoise = pow((flow1 + flow2) * 0.5, 2.0); 
        
        // SPATIAL DISTORTION (Tuned by UI)
        float distortedDist = max(clampedDist - (complexNoise * in_Amplitude), 0.0);
        
        // CORE GEOMETRY (Thickness Tuned by UI)
        // We invert the spread so a higher UI slider value = a thicker, wider glow
        float decayFactor = 1.0 / in_Spread;
        float baseGlow = exp(-distortedDist * decayFactor); 
        
        float edgeCore = exp(-clampedDist * 0.5);   
        float finalLavaPresence = max(baseGlow, edgeCore);
        
        // TEMPERATURE GRADIENT
        vec3 deepRootColor = vec3(in_AppColor) * 0.25; 
        deepRootColor = mix(deepRootColor, vec3(0.0, 0.0, 0.1), 0.3); 
        
        // Dynamically widen the color band based on the thickness slider
        float colorMix1 = 1.0 - smoothstep(0.0, in_Spread * 2.0, distortedDist);
        vec3 midRangeColor = mix(deepRootColor, vec3(in_AppColor), colorMix1);
        
        float coreShift = smoothstep(0.0, 2.0, clampedDist); 
        vec3 pureColor = mix(vec3(1.0), midRangeColor, coreShift);
        
        // ALPHA FINALIZATION
        float topBias = mix(0.15, 1.0, uv.y); 
        float pixelAlpha = finalLavaPresence * topBias;
        pixelAlpha *= 0.95; 
        
        float screenMask = clamp(distFromEdge * 10.0, 0.0, 1.0);
        float finalAlpha = pixelAlpha * screenMask;
        
        return half4(pureColor * finalAlpha, finalAlpha);
    }
"""

