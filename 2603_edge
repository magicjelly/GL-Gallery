// 1. The Updated AGSL Shader Code (Fixed Negative Thickness Triangles)
const val WAVE_EDGE_SHADER = """
    uniform float2 in_Resolution;
    uniform float in_Time;
    uniform float in_MessageCount; 
    uniform float in_CornerRadius; 

    // Signed Distance Field (SDF) for a rounded box
    float sdRoundRect(vec2 p, vec2 b, float r) {
        vec2 d = abs(p) - b + vec2(r);
        return min(max(d.x, d.y), 0.0) + length(max(d, 0.0)) - r;
    }

    half4 main(in float2 fragCoord) {
        vec2 p = fragCoord - (in_Resolution.xy * 0.5);
        vec2 b = in_Resolution.xy * 0.5;
        
        float d = sdRoundRect(p, b, in_CornerRadius);
        float distFromEdge = -d;
        
        vec2 uv = fragCoord / in_Resolution.xy;
        vec2 centered = uv - 0.5;
        float angle = atan(centered.y, centered.x);
        
        float baseAmplitude = 15.0; 
        
        float freq1 = floor(2.0 + (in_MessageCount * 1.0)); 
        float freq2 = max(1.0, floor(freq1 * 0.5)); 
        
        float activeSpeed = in_Time * (2.0 + in_MessageCount * 0.5);
        
        // THE FIX: Add 1.0 and multiply by 0.5 to map the wave from [-1.0, 1.0] to [0.0, 1.0].
        // Now the wave strictly bulges inward and never subtracts thickness.
        float wave1 = (sin(angle * freq1 + activeSpeed) + 1.0) * 0.5;
        float wave2 = (sin(angle * freq2 - (activeSpeed * 1.2)) + 1.0) * 0.5;
        float combinedWave = (wave1 + wave2) * 0.5 * baseAmplitude;
        
        // Adjusted base thickness down slightly since the wave now only expands
        float baseThickness = 12.0; 
        float edgeThickness = baseThickness + (combinedWave * (in_MessageCount * 1.5));
        
        float core = 1.0 - smoothstep(0.0, edgeThickness * 0.4, distFromEdge);
        float glow = 1.0 - smoothstep(0.0, edgeThickness * 2.5, distFromEdge);
        
        float screenMask = step(0.0, distFromEdge);
        
        vec3 calmColor = vec3(0.0, 0.6, 1.0);
        vec3 agitatedColor = vec3(1.0, 0.1, 0.4);
        float mixFactor = clamp((in_MessageCount - 1.0) / 4.0, 0.0, 1.0);
        vec3 currentColor = mix(calmColor, agitatedColor, mixFactor);
        
        vec3 finalColor = (currentColor * glow * 0.8) + (vec3(1.0) * core);
        
        return half4(finalColor * glow * screenMask, glow * screenMask);
    }
"""


// 2. The Main Activity Entry Point
class MainActivity : ComponentActivity() {
    override fun onCreate(savedInstanceState: Bundle?) {
        super.onCreate(savedInstanceState)
        setContent {
            MaterialTheme {
                Surface(
                    modifier = Modifier.fillMaxSize(),
                    color = MaterialTheme.colorScheme.background
                ) {
                    if (Build.VERSION.SDK_INT >= Build.VERSION_CODES.TIRAMISU) {
                        EdgeLightingPrototypeScreen()
                    } else {
                        Box(modifier = Modifier.fillMaxSize(), contentAlignment = Alignment.Center) {
                            Text("AGSL requires Android 13+")
                        }
                    }
                }
            }
        }
    }
}

// 3. The Interactive Prototype Screen
@RequiresApi(Build.VERSION_CODES.TIRAMISU)
@Composable
fun EdgeLightingPrototypeScreen() {
    var incomingMessages by remember { mutableFloatStateOf(1f) }
    var hardwareCornerRadius by remember { mutableFloatStateOf(120f) }

    Box(modifier = Modifier.fillMaxSize()) {
        SmartEdgeLighting(
            messageCount = incomingMessages,
            cornerRadius = hardwareCornerRadius
        )

        Column(
            modifier = Modifier
                .align(Alignment.Center)
                .padding(32.dp),
            horizontalAlignment = Alignment.CenterHorizontally
        ) {
            Text(
                text = "Simulated Messages: ${incomingMessages.toInt()}",
                color = MaterialTheme.colorScheme.onBackground
            )
            Slider(
                value = incomingMessages,
                onValueChange = { incomingMessages = it },
                valueRange = 1f..10f,
                steps = 8
            )
            
            Spacer(modifier = Modifier.height(32.dp))
            
            Text(
                text = "Hardware Corner Radius: ${hardwareCornerRadius.toInt()}px",
                color = MaterialTheme.colorScheme.onBackground
            )
            Slider(
                value = hardwareCornerRadius,
                onValueChange = { hardwareCornerRadius = it },
                valueRange = 0f..300f
            )
        }
    }
}

// 4. The AGSL Render Component
@RequiresApi(Build.VERSION_CODES.TIRAMISU)
@Composable
fun SmartEdgeLighting(
    modifier: Modifier = Modifier,
    messageCount: Float = 1f,
    cornerRadius: Float = 120f
) {
    var time by remember { mutableFloatStateOf(0f) }
    
    LaunchedEffect(Unit) {
        val startTime = System.nanoTime()
        while (true) {
            awaitFrame()
            time = (System.nanoTime() - startTime) / 1_000_000_000f
        }
    }

    val shader = remember { RuntimeShader(WAVE_EDGE_SHADER) }
    val shaderBrush = remember(shader) { ShaderBrush(shader) }

    Box(
        modifier = modifier
            .fillMaxSize()
            .drawWithCache {
                shader.setFloatUniform("in_Resolution", size.width, size.height)
                shader.setFloatUniform("in_Time", time)
                shader.setFloatUniform("in_MessageCount", messageCount)
                shader.setFloatUniform("in_CornerRadius", cornerRadius)
                
                onDrawBehind {
                    drawRect(brush = shaderBrush)
                }
            }
    )
}
