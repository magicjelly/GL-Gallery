const val AMBIENT_EDGE_SHADER = """
    uniform float2 in_Resolution;
    uniform float in_Time;
    uniform float in_CornerRadius; 
    uniform half3 in_AppColor; // Extracted App Icon Color

    float sdRoundRect(vec2 p, vec2 b, float r) {
        vec2 d = abs(p) - b + vec2(r);
        return min(max(d.x, d.y), 0.0) + length(max(d, 0.0)) - r;
    }

    half4 main(in float2 fragCoord) {
        vec2 p = fragCoord - (in_Resolution.xy * 0.5);
        vec2 b = in_Resolution.xy * 0.5;
        
        float d = sdRoundRect(p, b, in_CornerRadius);
        float distFromEdge = -d; 
        
        vec2 uv = fragCoord / in_Resolution.xy;
        
        float coreThickness = 2.0;  
        float glowThickness = 35.0; 
        
        float core = 1.0 - smoothstep(0.0, coreThickness, distFromEdge);
        float glow = 1.0 - smoothstep(0.0, glowThickness, distFromEdge);
        
        float topBias = mix(0.1, 1.0, uv.y); 
        float breathAlpha = (sin(in_Time * 3.0) + 1.0) * 0.5;
        
        // Apply the dynamic App Color passed from Jetpack Compose
        vec3 finalColor = (vec3(in_AppColor) * glow * 1.5) + (vec3(1.0) * core);
        
        float lightPresence = max(glow, core);
        float pixelAlpha = lightPresence * breathAlpha * topBias;
        float screenMask = step(0.0, distFromEdge);
        
        return half4(finalColor * pixelAlpha * screenMask, pixelAlpha * screenMask);
    }
"""

@RequiresApi(Build.VERSION_CODES.TIRAMISU)
@Composable
fun EdgeLightingTransparencyTest() {
    var hardwareCornerRadius by remember { mutableFloatStateOf(120f) }
    
    // Simulate extracting colors from app icons
    val appColors = listOf(
        Color(0xFF1999FF), // Default Cyan
        Color(0xFF25D366), // WhatsApp Green
        Color(0xFFEA4335), // Gmail Red
        Color(0xFFFFFC00), // Snapchat Yellow
        Color(0xFFE1306C)  // Instagram Magenta
    )
    var selectedAppColor by remember { mutableStateOf(appColors[0]) }

    Box(modifier = Modifier.fillMaxSize()) {
        
        LazyColumn(
            modifier = Modifier.fillMaxSize(),
            contentPadding = PaddingValues(horizontal = 16.dp, vertical = 64.dp),
            verticalArrangement = Arrangement.spacedBy(12.dp)
        ) {
            items(20) { index ->
                Card(
                    modifier = Modifier.fillMaxWidth().height(80.dp),
                    colors = CardDefaults.cardColors(containerColor = MaterialTheme.colorScheme.surfaceVariant)
                ) {
                    Box(modifier = Modifier.fillMaxSize(), contentAlignment = Alignment.CenterStart) {
                        Text(
                            text = "Active App Content #$index",
                            modifier = Modifier.padding(16.dp),
                            style = MaterialTheme.typography.bodyLarge
                        )
                    }
                }
            }
        }

        // Pass the selected color to the shader wrapper
        AmbientEdgeLighting(
            modifier = Modifier.fillMaxSize(),
            cornerRadius = hardwareCornerRadius,
            appColor = selectedAppColor
        )

        Column(
            modifier = Modifier
                .align(Alignment.BottomCenter)
                .padding(bottom = 48.dp)
                .fillMaxWidth(0.9f),
            horizontalAlignment = Alignment.CenterHorizontally,
            verticalArrangement = Arrangement.spacedBy(16.dp)
        ) {
            // App Color Selector UI
            Card(colors = CardDefaults.cardColors(containerColor = MaterialTheme.colorScheme.surface.copy(alpha = 0.9f))) {
                Row(
                    modifier = Modifier.fillMaxWidth().padding(16.dp),
                    horizontalArrangement = Arrangement.SpaceEvenly
                ) {
                    appColors.forEach { color ->
                        Box(
                            modifier = Modifier
                                .size(40.dp)
                                .background(color, CircleShape)
                                .border(
                                    width = if (selectedAppColor == color) 3.dp else 0.dp,
                                    color = MaterialTheme.colorScheme.onSurface,
                                    shape = CircleShape
                                )
                                .clickable { selectedAppColor = color }
                        )
                    }
                }
            }

            // Radius Slider UI
            Card(colors = CardDefaults.cardColors(containerColor = MaterialTheme.colorScheme.surface.copy(alpha = 0.9f))) {
                Column(modifier = Modifier.padding(16.dp)) {
                    Text("Corner Radius Match: ${hardwareCornerRadius.toInt()}px", style = MaterialTheme.typography.labelLarge)
                    Slider(
                        value = hardwareCornerRadius,
                        onValueChange = { hardwareCornerRadius = it },
                        valueRange = 0f..300f
                    )
                }
            }
        }
    }
}

@RequiresApi(Build.VERSION_CODES.TIRAMISU)
@Composable
fun AmbientEdgeLighting(
    modifier: Modifier = Modifier,
    cornerRadius: Float = 120f,
    appColor: Color // New parameter to receive the Compose Color
) {
    var time by remember { mutableFloatStateOf(0f) }
    
    LaunchedEffect(Unit) {
        val startTime = System.nanoTime()
        while (true) {
            awaitFrame()
            time = (System.nanoTime() - startTime) / 1_000_000_000f
        }
    }

    val shader = remember { RuntimeShader(AMBIENT_EDGE_SHADER) }
    val shaderBrush = remember(shader) { ShaderBrush(shader) }

    Box(
        modifier = modifier
            .fillMaxSize()
            .drawWithCache {
                shader.setFloatUniform("in_Resolution", size.width, size.height)
                shader.setFloatUniform("in_Time", time)
                shader.setFloatUniform("in_CornerRadius", cornerRadius)
                
                // Inject the App Color into the AGSL uniform.
                // Compose Color values (.red, .green, .blue) are 0.0 to 1.0 Floats, matching AGSL half3 perfectly.
                shader.setFloatUniform("in_AppColor", appColor.red, appColor.green, appColor.blue)
                
                onDrawBehind {
                    drawRect(brush = shaderBrush)
                }
            }
    )
}
