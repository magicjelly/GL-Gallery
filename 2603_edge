import androidx.compose.ui.Modifier
import androidx.compose.ui.text.font.FontWeight
import androidx.compose.ui.unit.dp

@Composable
fun TabMediaPlayer(
    state: EngineState,
    mediaPlayer: MediaPlayer
) {
    Column(
        modifier = Modifier.fillMaxWidth(),
        verticalArrangement = Arrangement.spacedBy(8.dp)
    ) {
        Card(colors = CardDefaults.cardColors(containerColor = MaterialTheme.colorScheme.surface.copy(alpha = 0.9f))) {
            Column(modifier = Modifier.fillMaxWidth().padding(16.dp), horizontalAlignment = Alignment.CenterHorizontally) {
                Text("Now Playing", style = MaterialTheme.typography.labelMedium, fontWeight = FontWeight.Bold)
                Spacer(modifier = Modifier.height(8.dp))
                
                Slider(
                    value = if (state.mediaDuration > 0) state.currentPosition.toFloat() / state.mediaDuration.toFloat() else 0f,
                    onValueChange = { 
                        val newPos = (it * state.mediaDuration).toInt()
                        state.currentPosition = newPos
                        try { mediaPlayer.seekTo(newPos) } catch(e: Exception) {}
                    },
                    modifier = Modifier.fillMaxWidth()
                )
                
                Row(modifier = Modifier.fillMaxWidth(), horizontalArrangement = Arrangement.SpaceEvenly) {
                    Button(
                        onClick = { 
                            try { 
                                mediaPlayer.start() 
                                state.isPlaying = true
                                state.fluidVolumeTarget = 1f 
                            } catch(e: Exception) { 
                                state.isPlaying = true
                                state.fluidVolumeTarget = 1f 
                            } 
                        },
                        colors = ButtonDefaults.buttonColors(containerColor = MaterialTheme.colorScheme.primary)
                    ) {
                        Text("Start")
                    }
                    Button(
                        onClick = { 
                            try { 
                                mediaPlayer.pause() 
                                state.isPlaying = false
                                state.fluidVolumeTarget = 0f 
                            } catch(e: Exception) {
                                state.isPlaying = false
                                state.fluidVolumeTarget = 0f
                            }
                        },
                        colors = ButtonDefaults.buttonColors(containerColor = MaterialTheme.colorScheme.secondary)
                    ) {
                        Text("Pause")
                    }
                    Button(
                        onClick = { 
                            try { 
                                mediaPlayer.pause()
                                mediaPlayer.seekTo(0)
                                state.currentPosition = 0
                                state.isPlaying = false
                                state.fluidVolumeTarget = 0f 
                            } catch(e: Exception) {
                                state.currentPosition = 0
                                state.isPlaying = false
                                state.fluidVolumeTarget = 0f
                            }
                        },
                        colors = ButtonDefaults.buttonColors(containerColor = MaterialTheme.colorScheme.error)
                    ) {
                        Text("Stop")
                    }
                }
            }
        }
        
        TuningSlider("Speed", state.flowSpeed, 0.1f..5.0f) { state.flowSpeed = it }
        TuningSlider("Thickness", state.thickness, 10f..100f) { state.thickness = it }
        TuningSlider("Amplitude", state.amplitude, 10f..200f) { state.amplitude = it }
        TuningSlider("Noise Scale", state.noiseScale, 0.5f..10.0f) { state.noiseScale = it }
    }
}



