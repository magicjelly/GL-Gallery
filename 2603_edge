        vec2 touchVec = fragCoord - in_TouchPos;
        float tensionWidth = in_Resolution.x * 0.28; 
        float distToTouch = length(touchVec);
        
        float rawElevation = exp(-(distToTouch * distToTouch) / (tensionWidth * tensionWidth)) * in_TouchActive * in_FluidVolume;
        float elevation = rawElevation * smoothstep(tensionWidth * 1.5, tensionWidth * 1.0, distToTouch);

        float voidRadius = tensionWidth * in_EffectSize;
        float eventHorizon = 1.0 - smoothstep(voidRadius, voidRadius + 8.0, distToTouch);
        
        float dentWidth = voidRadius * 1.5;
        float dent = exp(-(distToTouch * distToTouch) / (dentWidth * dentWidth));
        
        float distToLeftRight = min(fragCoord.x, in_Resolution.x - fragCoord.x);
        float distToBottom = in_Resolution.y - fragCoord.y;
        float edgeAnchor = smoothstep(0.0, in_Resolution.x * 0.1, distToLeftRight) * smoothstep(0.0, in_Resolution.y * 0.1, distToBottom);

        vec2 gradient = -2.0 * touchVec / (tensionWidth * tensionWidth) * elevation;
        gradient += -10.0 * (touchVec / dentWidth) * dent * elevation * (1.0 - eventHorizon);
        gradient *= edgeAnchor; 
        
        vec3 normal = normalize(vec3(-gradient.x, -gradient.y, 0.008));
        float normalizedAngle = normal.z;

        float baseRefraction = 400.0 * elevation * edgeAnchor; 
        float chromaticSpread = length(normal.xy) * (150.0 + (elevation * 200.0)) * elevation * edgeAnchor;
        
        vec2 safeNormal = normalize(normal.xy + vec2(0.0001)); 
        vec2 warpedCoordR = fragCoord + (normal.xy * baseRefraction) + (safeNormal * chromaticSpread);
        vec2 warpedCoordG = fragCoord + (normal.xy * baseRefraction);
        vec2 warpedCoordB = fragCoord + (normal.xy * baseRefraction) - (safeNormal * chromaticSpread);
        
        vec2 minBounds = vec2(3.0);
        vec2 maxBounds = in_Resolution.xy - vec2(3.0);

        vec2 coordR = clamp(warpedCoordR, minBounds, maxBounds);
        vec2 coordG = clamp(warpedCoordG, minBounds, maxBounds);
        vec2 coordB = clamp(warpedCoordB, minBounds, maxBounds);

        float bgR = in_Background.eval(coordR).r;
        float bgG = in_Background.eval(coordG).g;
        float bgB = in_Background.eval(coordB).b;
        vec3 refractedBG = vec3(bgR, bgG, bgB);
        
        float luma = dot(refractedBG, vec3(0.299, 0.587, 0.114));
        float darknessAdaptation = smoothstep(0.4, 0.0, luma); 

        float vignette = smoothstep(tensionWidth * 3.5, tensionWidth * 0.5, distToTouch);
        refractedBG *= mix(1.0, vignette, elevation * 0.9);

        vec2 normalizedVec = touchVec / tensionWidth;
        vec3 starlight = drawCinematicOrbs(normalizedVec, in_Time, in_WavePhase, in_TransferDirection, elevation, in_AppColor, darknessAdaptation, in_EffectSize);

        vec3 lightDir = normalize(vec3(-1.0, -1.0, 1.0)); 
        float spec = pow(max(dot(normal, lightDir), 0.0), 80.0) * (2.0 + darknessAdaptation) * elevation;
        vec3 specularLight = vec3(1.0) * spec * (1.0 - eventHorizon); 
        
        float fresnel = pow(1.0 - normalizedAngle, 8.0);
        vec3 rimLight = vec3(in_AppColor) * fresnel * (4.0 + darknessAdaptation) * elevation * dent * (1.0 - eventHorizon);
        
        vec3 finalColor = refractedBG + starlight + specularLight + rimLight;
        finalColor = mix(finalColor, vec3(0.0, 0.0, 0.0), eventHorizon * elevation);
        
        return half4(half3(finalColor * screenMask), half(screenMask));
    }
"""

const val WAVE_SHADER = """
