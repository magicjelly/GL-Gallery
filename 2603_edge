import androidx.compose.ui.graphics.ShaderBrush
import androidx.compose.ui.unit.dp
import kotlinx.coroutines.android.awaitFrame

// 1. The Transparent "Ambient Glass" Shader
const val AMBIENT_EDGE_SHADER = """
    uniform float2 in_Resolution;
    uniform float in_Time;
    uniform float in_CornerRadius; 

    float sdRoundRect(vec2 p, vec2 b, float r) {
        vec2 d = abs(p) - b + vec2(r);
        return min(max(d.x, d.y), 0.0) + length(max(d, 0.0)) - r;
    }

    half4 main(in float2 fragCoord) {
        vec2 p = fragCoord - (in_Resolution.xy * 0.5);
        vec2 b = in_Resolution.xy * 0.5;
        
        float d = sdRoundRect(p, b, in_CornerRadius);
        float distFromEdge = -d; 
        
        vec2 uv = fragCoord / in_Resolution.xy;
        
        float coreThickness = 2.0;  
        float glowThickness = 35.0; 
        
        float core = 1.0 - smoothstep(0.0, coreThickness, distFromEdge);
        float glow = 1.0 - smoothstep(0.0, glowThickness, distFromEdge);
        
        // Spatial Gradient (fixed to anchor at the top)
        float topBias = mix(0.1, 1.0, uv.y); 
        
        // Graceful Easing
        float breathAlpha = (sin(in_Time * 3.0) + 1.0) * 0.5;
        
        vec3 premiumColor = vec3(0.85, 0.92, 1.0);
        
        // THE FIX: Calculate the actual structural opacity of the light
        // If there is no core and no glow, structureAlpha is 0.0.
        float structureAlpha = max(core, glow);
        
        // Multiply our structural alpha by the animation and gradient
        float finalAlpha = structureAlpha * breathAlpha * topBias;
        
        // Calculate the base color
        vec3 baseColor = (premiumColor * glow * 0.5) + (vec3(1.0) * core);
        
        float screenMask = step(0.0, distFromEdge);
        
        // Pre-multiply the alpha against the final color
        return half4(baseColor * finalAlpha * screenMask, finalAlpha * screenMask);
    }
"""


// 2. Main Activity
class MainActivity : ComponentActivity() {
    override fun onCreate(savedInstanceState: Bundle?) {
        super.onCreate(savedInstanceState)
        setContent {
            MaterialTheme {
                Surface(
                    modifier = Modifier.fillMaxSize(),
                    color = MaterialTheme.colorScheme.background
                ) {
                    if (Build.VERSION.SDK_INT >= Build.VERSION_CODES.TIRAMISU) {
                        PremiumEdgeLightingScreen()
                    } else {
                        Box(modifier = Modifier.fillMaxSize(), contentAlignment = Alignment.Center) {
                            Text("AGSL requires Android 13+")
                        }
                    }
                }
            }
        }
    }
}

// 3. The Prototype Screen
@RequiresApi(Build.VERSION_CODES.TIRAMISU)
@Composable
fun PremiumEdgeLightingScreen() {
    var hardwareCornerRadius by remember { mutableFloatStateOf(120f) }

    Box(modifier = Modifier.fillMaxSize()) {
        AmbientEdgeLighting(cornerRadius = hardwareCornerRadius)

        Column(
            modifier = Modifier
                .align(Alignment.Center)
                .padding(32.dp),
            horizontalAlignment = Alignment.CenterHorizontally
        ) {
            Text(
                text = "Hardware Corner Radius: ${hardwareCornerRadius.toInt()}px",
                color = MaterialTheme.colorScheme.onBackground
            )
            Slider(
                value = hardwareCornerRadius,
                onValueChange = { hardwareCornerRadius = it },
                valueRange = 0f..300f
            )
        }
    }
}

// 4. The AGSL Render Component
@RequiresApi(Build.VERSION_CODES.TIRAMISU)
@Composable
fun AmbientEdgeLighting(
    modifier: Modifier = Modifier,
    cornerRadius: Float = 120f
) {
    var time by remember { mutableFloatStateOf(0f) }
    
    LaunchedEffect(Unit) {
        val startTime = System.nanoTime()
        while (true) {
            awaitFrame()
            time = (System.nanoTime() - startTime) / 1_000_000_000f
        }
    }

    val shader = remember { RuntimeShader(AMBIENT_EDGE_SHADER) }
    val shaderBrush = remember(shader) { ShaderBrush(shader) }

    Box(
        modifier = modifier
            .fillMaxSize()
            .drawWithCache {
                shader.setFloatUniform("in_Resolution", size.width, size.height)
                shader.setFloatUniform("in_Time", time)
                shader.setFloatUniform("in_CornerRadius", cornerRadius)
                
                onDrawBehind {
                    drawRect(brush = shaderBrush)
                }
            }
    )
}
