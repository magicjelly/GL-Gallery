        vec2 d = abs(p) - b + vec2(r); return min(max(d.x, d.y), 0.0) + length(max(d, 0.0)) - r;
    }

    vec3 drawCinematicOrbs(vec2 uv, float time, float phase, float direction, float elevation, half3 appColor, float lumaAdapt, float effectSize) {
        float starlight = 0.0;
        for (float i = 0.0; i < 24.0; i++) {
            float h1 = fract(sin(i * 7.13) * 268.53);
            float h2 = fract(sin(i * 13.7) * 412.11);
            
            float rawProgress = fract(h1 + (phase * 0.008));
            float gravityFall = pow(rawProgress, 5.0); 
            
            float startR = (direction > 0.0) ? 2.2 : 0.0;
            float endR = (direction > 0.0) ? 0.0 : 2.2;
            float currentR = mix(startR, endR, gravityFall);
            
            float currentAngle = (h2 * 6.28318) + (time * 0.05) - (1.5 / (currentR + 0.2));
            vec2 orbPos = vec2(cos(currentAngle), sin(currentAngle)) * currentR;
            float dist = length(uv - orbPos);
            
            float scaleBase = mix(1.0, 0.3, gravityFall);
            float core = exp(-dist * mix(50.0, 80.0, h1) / scaleBase) * 3.5;
            float halo = exp(-dist * mix(12.0, 30.0, h2) / scaleBase) * 1.5;
            
            float fadeOutInner = smoothstep(effectSize * 0.7, effectSize * 2.5, currentR);
            float fadeInOuter = smoothstep(2.2, 1.5, currentR);
            float orbMask = fadeOutInner * fadeInOuter;
            
            starlight += (core + halo) * orbMask;
        }
        vec3 hotWhite = vec3(1.0, 0.98, 0.95);
        vec3 finalOrbColor = mix(vec3(appColor), hotWhite, 0.8);
        return finalOrbColor * starlight * elevation * (1.0 + lumaAdapt);
    }

    half4 main(in float2 fragCoord) {
        vec2 p = fragCoord - (in_Resolution.xy * 0.5); vec2 b = in_Resolution.xy * 0.5;
        float distFromEdge = -sdRoundRect(p, b, in_CornerRadius); 
