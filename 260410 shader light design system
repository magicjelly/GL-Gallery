// AGSL Shader: The Math behind the "Living Substrate"
@org.intellij.lang.annotations.Language("AGSL")
const val PERIMETER_SHADER = """
    uniform float2 resolution;
    uniform float time;
    uniform int scenario; 
    uniform float2 touchPos;
    
    // 1. Viscosity Engine
    float smin(float a, float b, float k) {
        float h = clamp(0.5 + 0.5 * (b - a) / k, 0.0, 1.0);
        return mix(b, a, h) - k * h * (1.0 - h);
    }
    
    // 2. Procedural Noise (For Caustics/Turbulence)
    float hash(float2 p) {
        return fract(sin(dot(p, float2(12.9898, 78.233))) * 43758.5453);
    }
    float noise(float2 p) {
        float2 i = floor(p);
        float2 f = fract(p);
        float2 u = f * f * (3.0 - 2.0 * f);
        return mix(mix(hash(i + float2(0.0,0.0)), hash(i + float2(1.0,0.0)), u.x),
                   mix(hash(i + float2(0.0,1.0)), hash(i + float2(1.0,1.0)), u.x), u.y);
    }

    // Distance to edge (SDF)
    float sdEdge(float2 p, float2 res) {
        float dTop = p.y;
        float dBottom = res.y - p.y;
        float dLeft = p.x;
        float dRight = res.x - p.x;
        return min(min(dTop, dBottom), min(dLeft, dRight));
    }

    half4 main(float2 fragCoord) {
        float2 uv = fragCoord / resolution;
        float edgeDist = sdEdge(fragCoord, resolution);
        
        half3 color = half3(0.0);
        float alpha = 0.0;
        
        if (scenario == 0) {
            // TIER 3 HERO MOMENT: Symbiotic Share (Chromatic Dispersion & Caustics)
            float rightEdge = resolution.x - fragCoord.x;
            
            // Internal Turbulence 
            float turbulence = noise(uv * 10.0 + time * 2.0) * 30.0;
            float baseShape = length(fragCoord - float2(resolution.x, resolution.y*0.5)) - 150.0;
            
            // Chromatic Dispersion Offset (Simulating high-energy data transfer)
            float dispersion = 8.0 * sin(time * 5.0); 
            
            // Calculate fluid mass for R, G, B separately to create spectrum
            float fluidR = smin(rightEdge + turbulence, baseShape + dispersion, 80.0);
            float fluidG = smin(rightEdge + turbulence, baseShape, 80.0);
            float fluidB = smin(rightEdge + turbulence, baseShape - dispersion, 80.0);
            
            // Additive blending for the glowing core
            if (fluidR < 40.0) { color.r = 1.0 - (fluidR / 40.0); alpha = max(alpha, color.r); }
            if (fluidG < 40.0) { color.g = 0.8 - (fluidG / 40.0); alpha = max(alpha, color.g); }
            if (fluidB < 40.0) { color.b = 1.0 - (fluidB / 40.0); alpha = max(alpha, color.b); }
            
            // Specular core blowout
            float core = smin(rightEdge, baseShape, 40.0);
            if (core < 10.0) {
                color += half3(0.5); 
            }
        } 
        else if (scenario == 1) {
            // TIER 2 SYSTEM STATE: Spatial Tether (Top Edge Focus)
            float topEdge = fragCoord.y;
            float focusPoint = length(fragCoord - float2(resolution.x * 0.5, 0.0));
            float flare = smin(topEdge, focusPoint - (sin(time*8.0)*10.0 + 50.0), 100.0);
            if (flare < 30.0) {
                color = half3(1.0, 0.8, 0.2); 
                alpha = 1.0 - (flare / 30.0);
            }
        }
        else if (scenario == 2) {
            // TIER 2 SYSTEM STATE: Cognitive Vessel (Bottom AI Swirl)
            float bottomDist = resolution.y - fragCoord.y;
            float cornerL = length(fragCoord - float2(0.0, resolution.y));
            float cornerR = length(fragCoord - float2(resolution.x, resolution.y));
            float swirl = smin(cornerL, cornerR, 300.0 + sin(time*3.0)*100.0);
            float finalAI = smin(bottomDist, swirl - 100.0, 150.0);
            if (finalAI < 60.0) {
                color = half3(0.8, 0.2, 1.0); 
                alpha = 1.0 - (finalAI / 60.0);
            }
        }
        else if (scenario == 3) {
            // TIER 1 UTILITY: Continuous Canvas Pull (Quick Panel / Gestures)
            float topEdge = fragCoord.y;
            float dropDist = length(fragCoord - touchPos);
            // Dynamic viscosity based on how far it's pulled
            float viscosity = max(50.0, touchPos.y * 0.5); 
            
            // Clean, polite, heavy glass. No chromatic aberration here.
            float surfaceTension = smin(topEdge, dropDist - 60.0, viscosity);
            
            if (surfaceTension < 20.0) {
                color = half3(0.1, 0.1, 0.15); // Frosted Dark UI Material
                alpha = 0.90; 
                
                // Sub-surface light reflection
                float reflection = noise(uv * 20.0 - time) * 0.1;
                color += half3(reflection);
            }
        }
        
        // Universal Glass Refraction Edge (Applies to all tiers)
        float innerHighlight = smoothstep(0.0, 5.0, edgeDist);
        color += half3(innerHighlight * 0.15 * alpha);

        return half4(color * alpha, alpha);
    }
"""

@RequiresApi(Build.VERSION_CODES.TIRAMISU)
@Composable
fun PerimeterPrototypeApp() {
    var selectedScenario by remember { mutableIntStateOf(0) }
    var touchPosition by remember { mutableStateOf(Offset(0f, 0f)) }
    var screenSize by remember { mutableStateOf(IntSize.Zero) }

    // Shader Setup
    val runtimeShader = remember { RuntimeShader(PERIMETER_SHADER) }
    val time by rememberInfiniteTransition(label = "time").animateFloat(
        initialValue = 0f,
        targetValue = 100f,
        animationSpec = infiniteRepeatable(tween(100000, easing = LinearEasing)),
        label = "time_anim"
    )

    // Update Uniforms
    runtimeShader.setFloatUniform("resolution", screenSize.width.toFloat(), screenSize.height.toFloat())
    runtimeShader.setFloatUniform("time", time)
    runtimeShader.setIntUniform("scenario", selectedScenario)
    
    // Spring physics for the drop handle (Canvas Pull scenario)
    val animatedTouchX by animateFloatAsState(
        targetValue = touchPosition.x,
        animationSpec = spring(dampingRatio = Spring.DampingRatioMediumBouncy, stiffness = Spring.StiffnessLow),
        label = "touchX"
    )
    val animatedTouchY by animateFloatAsState(
        targetValue = if (touchPosition.y > 0f) touchPosition.y else -100f,
        animationSpec = spring(dampingRatio = Spring.DampingRatioMediumBouncy, stiffness = Spring.StiffnessMedium),
        label = "touchY"
    )
    runtimeShader.setFloatUniform("touchPos", animatedTouchX, animatedTouchY)

    Box(
        modifier = Modifier
            .fillMaxSize()
            .onSizeChanged { screenSize = it }
    ) {
        // 1. Placeholder Wallpaper Layer
        Image(
            painter = painterResource(id = android.R.drawable.sym_def_app_icon), // REPLACE with your wallpaper_placeholder drawable ID
            contentDescription = "Wallpaper",
            contentScale = ContentScale.Crop,
            modifier = Modifier.fillMaxSize()
        )

        // 2. The Fluid Perimeter Layer (AGSL RenderNode)
        Box(
            modifier = Modifier
                .fillMaxSize()
                .pointerInput(selectedScenario) {
                    // Touch physics are only active during Scenario 3: Canvas Pull
                    if (selectedScenario == 3) {
                        detectDragGestures(
                            onDragStart = { touchPosition = it },
                            onDragEnd = { touchPosition = Offset(screenSize.width / 2f, -100f) }, // Snap back up
                            onDragCancel = { touchPosition = Offset(screenSize.width / 2f, -100f) }
                        ) { change, dragAmount ->
                            change.consume()
                            touchPosition = Offset(
                                x = touchPosition.x + dragAmount.x,
                                y = touchPosition.y + dragAmount.y
                            )
                        }
                    }
                }
                .background(ShaderBrush(runtimeShader))
        )

        // 3. UX Control Panel
        ControlPanel(
            selectedScenario = selectedScenario,
            onScenarioSelected = { selectedScenario = it },
            modifier = Modifier.align(Alignment.BottomCenter)
        )
    }
}

@Composable
fun ControlPanel(
    selectedScenario: Int,
    onScenarioSelected: (Int) -> Unit,
    modifier: Modifier = Modifier
) {
    val scenarios = listOf("Share", "Tether", "AI Vessel", "Canvas Pull")
    
    Surface(
        modifier = modifier
            .padding(bottom = 48.dp)
            .wrapContentSize(),
        shape = CircleShape,
        color = Color.Black.copy(alpha = 0.6f),
        contentColor = Color.White
    ) {
        Row(
            modifier = Modifier.padding(horizontal = 8.dp, vertical = 8.dp),
            horizontalArrangement = Arrangement.spacedBy(8.dp)
        ) {
            scenarios.forEachIndexed { index, name ->
                FilterChip(
                    selected = selectedScenario == index,
                    onClick = { onScenarioSelected(index) },
                    label = { Text(name) },
                    colors = FilterChipDefaults.filterChipColors(
                        selectedContainerColor = Color.White,
                        selectedLabelColor = Color.Black
                    ),
                    shape = CircleShape
                )
            }
        }
    }
}
