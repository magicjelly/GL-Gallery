// The Acrylic Refraction Shader
@org.intellij.lang.annotations.Language("AGSL")
const val ACRYLIC_SHADER = """
    uniform shader background; // THIS IS THE WALLPAPER/UI BENEATH
    uniform float2 resolution;
    uniform float time;
    uniform int scenario;
    uniform float2 touchPos;

    // Polynomial smooth minimum (Viscosity)
    float smin(float a, float b, float k) {
        float h = clamp(0.5 + 0.5 * (b - a) / k, 0.0, 1.0);
        return mix(b, a, h) - k * h * (1.0 - h);
    }
    
    // Procedural Noise for internal material imperfections
    float hash(float2 p) { return fract(sin(dot(p, float2(12.9898, 78.233))) * 43758.5453); }
    float noise(float2 p) {
        float2 i = floor(p); float2 f = fract(p);
        float2 u = f * f * (3.0 - 2.0 * f);
        return mix(mix(hash(i + float2(0.0,0.0)), hash(i + float2(1.0,0.0)), u.x),
                   mix(hash(i + float2(0.0,1.0)), hash(i + float2(1.0,1.0)), u.x), u.y);
    }

    // Calculate the distance field (shape) of the fluid
    float getFluidSDF(float2 p) {
        if (scenario == 0) { // Symbiotic Share (Right Edge)
            float rightEdge = resolution.x - p.x;
            float turbulence = noise(p / resolution * 10.0 + time * 2.0) * 20.0;
            float baseShape = length(p - float2(resolution.x, resolution.y*0.5)) - 150.0;
            return smin(rightEdge + turbulence, baseShape, 60.0);
        } else if (scenario == 3) { // Canvas Pull (Top Edge)
            float topEdge = p.y;
            float dropDist = length(p - touchPos);
            float viscosity = max(50.0, touchPos.y * 0.5); 
            return smin(topEdge, dropDist - 60.0, viscosity);
        }
        return p.y; // Fallback
    }

    // Calculate the surface normal (slope) for refraction
    float2 getNormal(float2 p) {
        float e = 1.0; // Sample distance
        float d = getFluidSDF(p);
        float dx = getFluidSDF(p + float2(e, 0.0)) - d;
        float dy = getFluidSDF(p + float2(0.0, e)) - d;
        return normalize(float2(dx, dy) + 0.0001); // avoid div by zero
    }

    half4 main(float2 fragCoord) {
        float d = getFluidSDF(fragCoord);

        // 1. BOUNDARY CHECK: If outside the fluid, just draw the wallpaper normally.
        // We use 30.0 as the outer boundary of our shape.
        if (d > 30.0) {
            return background.eval(fragCoord);
        }

        // 2. THE ACRYLIC EFFECT (Inside the fluid bounds)
        float2 normal = getNormal(fragCoord);
        
        // Refraction math: bend the coordinate based on the slope of the fluid
        // The closer to the center (lower 'd'), the stronger the bend.
        float thickness = 40.0; 
        float2 refractedCoord = fragCoord - normal * thickness * (1.0 - max(d, 0.0)/30.0);
        
        // Sample the wallpaper at the BENT coordinate
        half4 materialColor = background.eval(refractedCoord);

        // 3. SPECULAR HIGHLIGHT (The shiny glass edge)
        // Simulate a light source from the top left
        float2 lightDir = normalize(float2(-1.0, -1.0)); 
        float diffuse = max(dot(normal, lightDir), 0.0);
        // Extremely tight specular exponent for a sharp glass reflection
        float specular = pow(diffuse, 30.0) * 0.9; 

        // 4. CHROMATIC DISPERSION (Edge rainbow on fast data transfer)
        if (scenario == 0) {
            float edgeFactor = smoothstep(10.0, 30.0, d);
            half4 rSample = background.eval(refractedCoord + normal * 10.0 * edgeFactor);
            half4 bSample = background.eval(refractedCoord - normal * 10.0 * edgeFactor);
            materialColor.rgb = half3(rSample.r, materialColor.g, bSample.b);
            
            // Add a slight blue-ish energy tint for the transfer
            materialColor.rgb += half3(0.0, 0.1, 0.2); 
        } else if (scenario == 3) {
            // Dark frosted tint for the UI pull
            materialColor.rgb *= 0.7; // Darken the refracted background slightly
        }

        // Add the shiny reflection on top of the material
        materialColor.rgb += half3(specular);

        // Anti-alias the outer edge to blend perfectly with the un-distorted wallpaper
        float edgeAlpha = smoothstep(30.0, 28.0, d);
        
        // Blend the acrylic material over the raw background
        return mix(background.eval(fragCoord), materialColor, edgeAlpha);
    }
"""

@RequiresApi(Build.VERSION_CODES.TIRAMISU)
@Composable
fun PerimeterPrototypeApp() {
    var selectedScenario by remember { mutableIntStateOf(3) } // Default to Canvas Pull
    var touchPosition by remember { mutableStateOf(Offset(0f, 0f)) }
    var screenSize by remember { mutableStateOf(IntSize.Zero) }

    val runtimeShader = remember { RuntimeShader(ACRYLIC_SHADER) }
    val time by rememberInfiniteTransition(label = "time").animateFloat(
        initialValue = 0f,
        targetValue = 100f,
        animationSpec = infiniteRepeatable(tween(100000, easing = LinearEasing)),
        label = "time_anim"
    )

    // Update Uniforms
    runtimeShader.setFloatUniform("resolution", screenSize.width.toFloat(), screenSize.height.toFloat())
    runtimeShader.setFloatUniform("time", time)
    runtimeShader.setIntUniform("scenario", selectedScenario)
    
    val animatedTouchX by animateFloatAsState(
        targetValue = touchPosition.x,
        animationSpec = spring(dampingRatio = Spring.DampingRatioMediumBouncy, stiffness = Spring.StiffnessLow), label = "x"
    )
    val animatedTouchY by animateFloatAsState(
        targetValue = if (touchPosition.y > 0f) touchPosition.y else -100f,
        animationSpec = spring(dampingRatio = Spring.DampingRatioMediumBouncy, stiffness = Spring.StiffnessMedium), label = "y"
    )
    runtimeShader.setFloatUniform("touchPos", animatedTouchX, animatedTouchY)

    Box(
        modifier = Modifier
            .fillMaxSize()
            .onSizeChanged { screenSize = it }
            .pointerInput(selectedScenario) {
                if (selectedScenario == 3) {
                    detectDragGestures(
                        onDragStart = { touchPosition = it },
                        onDragEnd = { touchPosition = Offset(screenSize.width / 2f, -100f) },
                        onDragCancel = { touchPosition = Offset(screenSize.width / 2f, -100f) }
                    ) { change, dragAmount ->
                        change.consume()
                        touchPosition = Offset(touchPosition.x + dragAmount.x, touchPosition.y + dragAmount.y)
                    }
                }
            }
    ) {
        // THE MAGIC HAPPENS HERE: 
        // We apply the RenderEffect to the Box containing the Image.
        // This takes the Image, feeds it into the "background" uniform of our shader, 
        // runs our acrylic math, and renders the result.
        Box(
            modifier = Modifier
                .fillMaxSize()
                .graphicsLayer {
                    renderEffect = RenderEffect.createRuntimeShaderEffect(
                        runtimeShader,
                        "background" // Matches the uniform name in AGSL
                    ).asComposeRenderEffect()
                }
        ) {
            Image(
                painter = painterResource(id = android.R.drawable.sym_def_app_icon), // REPLACE WITH YOUR WALLPAPER
                contentDescription = "Wallpaper",
                contentScale = ContentScale.Crop,
                modifier = Modifier.fillMaxSize()
            )
            
            // You can add other UI elements here (like icons or text). 
            // The shader will refract them too, making the acrylic look incredibly real!
        }

        ControlPanel(
            selectedScenario = selectedScenario,
            onScenarioSelected = { selectedScenario = it },
            modifier = Modifier.align(Alignment.BottomCenter)
        )
    }
}

@Composable
fun ControlPanel(
    selectedScenario: Int,
    onScenarioSelected: (Int) -> Unit,
    modifier: Modifier = Modifier
) {
    // Simplified to the two most impactful visual tests for Acrylic
    val scenarios = listOf("Hero Share", "Canvas Pull")
    val actualIndices = listOf(0, 3) 
    
    Surface(
        modifier = modifier
            .padding(bottom = 48.dp)
            .wrapContentSize(),
        shape = CircleShape,
        color = Color.Black.copy(alpha = 0.6f),
        contentColor = Color.White
    ) {
        Row(
            modifier = Modifier.padding(horizontal = 8.dp, vertical = 8.dp),
            horizontalArrangement = Arrangement.spacedBy(8.dp)
        ) {
            scenarios.forEachIndexed { idx, name ->
                FilterChip(
                    selected = selectedScenario == actualIndices[idx],
                    onClick = { onScenarioSelected(actualIndices[idx]) },
                    label = { Text(name) },
                    colors = FilterChipDefaults.filterChipColors(
                        selectedContainerColor = Color.White,
                        selectedLabelColor = Color.Black
                    ),
                    shape = CircleShape
                )
            }
        }
    }
}
