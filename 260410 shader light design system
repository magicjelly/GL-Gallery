@RequiresApi(Build.VERSION_CODES.TIRAMISU)
class MainActivity : ComponentActivity() {
    override fun onCreate(savedInstanceState: Bundle?) {
        super.onCreate(savedInstanceState)
        // Note: For best results in production, enable WindowCompat.setDecorFitsSystemWindows(window, false)
        // to draw under the status bar.
        setContent {
            MaterialTheme {
                PerimeterPrototypeApp()
            }
        }
    }
}

@RequiresApi(Build.VERSION_CODES.TIRAMISU)
@Composable
fun PerimeterPrototypeApp() {
    var selectedScenario by remember { mutableIntStateOf(1) } // Default to Notify
    var touchPosition by remember { mutableStateOf(Offset(0f, 0f)) }
    var touchVelocity by remember { mutableStateOf(Offset(0f, 0f)) }

    val runtimeShader = remember { RuntimeShader(PHOTONIC_GLASS_SHADER) }
    val time by rememberInfiniteTransition(label = "time").animateFloat(
        initialValue = 0f,
        targetValue = 100f,
        animationSpec = infiniteRepeatable(tween(100000, easing = LinearEasing)),
        label = "time"
    )
    
    val animatedVelX by animateFloatAsState(targetValue = touchVelocity.x, label = "vx")
    val animatedVelY by animateFloatAsState(targetValue = touchVelocity.y, label = "vy")

    val animatedTouchX by animateFloatAsState(
        targetValue = touchPosition.x,
        animationSpec = spring(dampingRatio = 0.6f, stiffness = 200f), label = "tx"
    )
    val animatedTouchY by animateFloatAsState(
        targetValue = if (touchPosition.y > 0f) touchPosition.y else -150f,
        animationSpec = spring(dampingRatio = 0.6f, stiffness = 200f), label = "ty"
    )

    Box(
        modifier = Modifier
            .fillMaxSize()
            .pointerInput(selectedScenario) {
                // Enable touch physics for Volume (2) and Canvas Pull (3)
                if (selectedScenario == 2 || selectedScenario == 3) { 
                    detectDragGestures(
                        onDragStart = { 
                            touchPosition = it
                            touchVelocity = Offset.Zero
                        },
                        onDragEnd = { 
                            touchPosition = Offset(size.width / 2f, -150f)
                            touchVelocity = Offset.Zero
                        },
                        onDragCancel = { 
                            touchPosition = Offset(size.width / 2f, -150f)
                            touchVelocity = Offset.Zero
                        }
                    ) { change, dragAmount ->
                        change.consume()
                        touchPosition = Offset(touchPosition.x + dragAmount.x, touchPosition.y + dragAmount.y)
                        touchVelocity = dragAmount 
                    }
                }
            }
    ) {
        // The RenderEffect Layer: Bends the Image beneath it using the AGSL math
        Box(
            modifier = Modifier
                .fillMaxSize()
                .graphicsLayer {
                    // Updating Uniforms inside graphicsLayer forces frame-by-frame redraws in Compose
                    if (size.width > 0f && size.height > 0f) {
                        runtimeShader.setFloatUniform("resolution", size.width, size.height)
                        runtimeShader.setFloatUniform("time", time)
                        runtimeShader.setIntUniform("scenario", selectedScenario)
                        runtimeShader.setFloatUniform("touchVelocity", animatedVelX, animatedVelY)
                        runtimeShader.setFloatUniform("touchPos", animatedTouchX, animatedTouchY)
                        
                        renderEffect = RenderEffect.createRuntimeShaderEffect(
                            runtimeShader,
                            "background" 
                        ).asComposeRenderEffect()
                    }
                }
        ) {
            Image(
                // IMPORTANT: Replace this ID with your actual high-res wallpaper drawable
                // e.g., painterResource(id = R.drawable.wallpaper_placeholder)
                painter = painterResource(id = android.R.drawable.sym_def_app_icon), 
                contentDescription = "Wallpaper",
                contentScale = ContentScale.Crop,
                modifier = Modifier.fillMaxSize()
            )
        }

        ControlPanel(
            selectedScenario = selectedScenario,
            onScenarioSelected = { 
                selectedScenario = it
                // Reset touch position when swapping scenarios to prevent visual jumps
                touchPosition = Offset(0f, -150f)
            },
            modifier = Modifier.align(Alignment.BottomCenter)
        )
    }
}

// ---------------------------------------------------------------------------
// 3. UI CONTROLS
// ---------------------------------------------------------------------------
@Composable
fun ControlPanel(
    selectedScenario: Int,
    onScenarioSelected: (Int) -> Unit,
    modifier: Modifier = Modifier
) {
    val scenarios = listOf("Share", "Notify", "Volume", "Pull")
    
    Surface(
        modifier = modifier
            .padding(bottom = 48.dp)
            .wrapContentSize(),
        shape = CircleShape,
        color = Color.Black.copy(alpha = 0.6f),
        contentColor = Color.White
    ) {
        Row(
            modifier = Modifier.padding(horizontal = 8.dp, vertical = 8.dp),
            horizontalArrangement = Arrangement.spacedBy(8.dp)
        ) {
            scenarios.forEachIndexed { idx, name ->
                FilterChip(
                    selected = selectedScenario == idx,
                    onClick = { onScenarioSelected(idx) },
                    label = { Text(name) },
                    colors = FilterChipDefaults.filterChipColors(
                        selectedContainerColor = Color.White,
                        selectedLabelColor = Color.Black
                    ),
                    shape = CircleShape
                )
            }
        }
    }
}
